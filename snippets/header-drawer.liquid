{% comment %}
  Clean luxury drawer menu with collapsible categories
{% endcomment %}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>
    
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container">
          
          <!-- Navigation -->
          <nav class="drawer-nav">
            {%- for link in section.settings.menu.links -%}
              
              {%- if link.links != blank -%}
                {%- comment -%} Category with collapsible subcategories {%- endcomment -%}
                <details class="nav-category" data-category="{{ forloop.index }}">
                  <summary class="category-title">
                    {{ link.title | escape }}
                    <svg class="category-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6l4 4 4-4"/>
                    </svg>
                  </summary>
                  <ul class="category-links">
                    {%- for childlink in link.links -%}
                      <li>
                        <a 
                          href="{{ childlink.url }}"
                          {% if childlink.current %}aria-current="page" class="active"{% endif %}
                        >
                          {{ childlink.title | escape }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </details>
                
              {%- else -%}
                {%- comment -%} Single link {%- endcomment -%}
                <div class="nav-single">
                  <a 
                    href="{{ link.url }}"
                    {% if link.current %}aria-current="page" class="active"{% endif %}
                  >
                    {{ link.title | escape }}
                  </a>
                </div>
              {%- endif -%}
              
            {%- endfor -%}
          </nav>

          <!-- Track Package Button -->
          <div class="drawer-footer">
            <!-- Track Package Button with Truck Icon -->
            <a href="https://rangtarini.shiprocket.co/tracking" class="track-btn" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m-4 0v-5m4 5v-5m6 5a2 2 0 104 0m-4 0a2 2 0 114 0m-4 0v-5m4 5v-5"/>
              </svg>
              <span>Track Package</span>
            </a>
          </div>

        </div>
      </div>
    </div>
  </details>
</header-drawer>