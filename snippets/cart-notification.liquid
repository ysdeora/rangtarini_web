{% comment %}
  Renders cart notification

  Accepts:
  - color_scheme: {String} sets the color scheme of the notification (optional)
  - desktop_menu_type: {String} passes the desktop menu type which allows us to use the right css class (optional)

  Usage:
  {% render 'cart-notification' %}
{% endcomment %}

<cart-notification>
  <div class="cart-notification-wrapper">
    <div
      id="cart-notification"
      class="cart-notification focus-inset"
      aria-modal="true"
      aria-label="{{ 'general.cart.item_added' | t }}"
      role="dialog"
      tabindex="-1"
    >
      {%- comment -%} CSS is loaded eagerly in <head> (layout/theme.liquid) for the notification cart type {%- endcomment -%}

      {%- comment -%} Header row: circle checkmark + "Added to your bag" + close × {%- endcomment -%}
      <div class="cart-notification__header">
        <span class="cart-notification__heading">
          <span class="rt-cn__check-circle" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </span>
          {{ 'general.cart.item_added' | t }}
        </span>
        <button
          type="button"
          class="cart-notification__close"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      {%- comment -%} Product row — AJAX-updated by cart-notification.js {%- endcomment -%}
      <div id="cart-notification-product" class="cart-notification-product"></div>

      {%- comment -%} Subtotal row — updated via cartUpdate PubSub subscriber {%- endcomment -%}
      <div id="cart-notification-subtotal" class="rt-cn-subtotal">
        <span class="rt-cn-subtotal__label">{{ 'general.cart.bag_subtotal' | t: count: cart.item_count }}</span>
        <span class="rt-cn-subtotal__price">{% render 'rt-money', amount: cart.total_price %}</span>
      </div>

      {%- comment -%} Actions {%- endcomment -%}
      <div class="cart-notification__links">
        <a
          href="{{ routes.cart_url }}"
          id="cart-notification-button"
          class="rt-cn-btn rt-cn-btn--outline"
        >
          {{- 'general.cart.view_bag' | t: count: cart.item_count -}}
        </a>
        <form action="{{ routes.cart_url }}" method="post" id="cart-notification-form">
          <button class="rt-cn-btn rt-cn-btn--solid" name="checkout">
            {{ 'sections.cart.checkout' | t }} →
          </button>
        </form>
        <button type="button" class="rt-cn-btn rt-cn-btn--ghost">{{ 'general.continue_shopping' | t }}</button>
      </div>
    </div>
  </div>
</cart-notification>
{% style %}
  .cart-notification { display: none; }
  /* Instant feedback while the add-to-cart request is in flight */
  #cart-notification[data-loading] #cart-notification-product {
    min-height: 88px;
    background: linear-gradient(90deg, rgba(10,10,10,0.05) 25%, rgba(10,10,10,0.10) 37%, rgba(10,10,10,0.05) 63%);
    background-size: 400% 100%;
    animation: rt-cn-shimmer 1.2s ease infinite;
  }
  @keyframes rt-cn-shimmer { from { background-position: 100% 0; } to { background-position: -100% 0; } }
  @media (prefers-reduced-motion: reduce) {
    #cart-notification[data-loading] #cart-notification-product { animation: none; }
  }
{% endstyle %}
