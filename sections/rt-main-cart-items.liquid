{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
<script>
  customElements.whenDefined('cart-items').then(function() {
    var el = document.querySelector('cart-items');
    if (!el) return;
    el.getSectionsToRender = function() {
      return [
        { id: 'main-cart-items', section: document.getElementById('main-cart-items').dataset.id, selector: '.js-contents' },
        { id: 'main-cart-footer', section: document.getElementById('main-cart-footer').dataset.id, selector: '.js-contents' }
      ];
    };
  });

  document.addEventListener('DOMContentLoaded', function() {
    subscribe(PUB_SUB_EVENTS.cartUpdate, function(event) {
      if (!event || !event.cartData) return;
      var count = event.cartData.item_count;
      var numEl = document.querySelector('.rt-cart__count-num');
      var labelEl = document.querySelector('.rt-cart__count-label');
      if (numEl) numEl.textContent = (count < 10 ? '0' : '') + count;
      if (labelEl) labelEl.textContent = count === 1 ? 'Piece' : 'Pieces';
    });
  });
</script>

<style>
  /* ── Shell ── */
  .rt-cart { background: var(--rt-paper); }

  /* ── Sub-bar ── */
  .rt-cart__subbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 28px 14px;
    border-bottom: 1px solid var(--rt-ink);
  }
  .rt-cart__breadcrumb {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rt-cart__bc-item {
    font-family: var(--rt-font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.55;
  }
  .rt-cart__bc-sep {
    font-family: var(--rt-font-mono);
    font-size: 10px;
    color: var(--rt-ink);
    opacity: 0.3;
  }
  .rt-cart__bc-current { opacity: 1; }
  .rt-cart__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--rt-ink);
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    transition: opacity 160ms;
  }
  .rt-cart__back:hover { opacity: 0.5; }

  /* ── Hero ── */
  .rt-cart__hd {
    padding: 34px 28px 28px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-bottom: 1px solid var(--rt-ink);
    flex-wrap: wrap;
    gap: 16px;
  }
  .rt-cart__eyebrow {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
    display: block;
    margin: 0 0 12px;
  }
  .rt-cart__title-row {
    display: flex;
    align-items: baseline;
    gap: 18px;
    flex-wrap: wrap;
  }
  .rt-cart__title {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(52px, 7vw, 96px);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--rt-ink);
    margin: 0;
  }
  .rt-cart__title-deva {
    font-family: var(--rt-font-deva);
    font-size: 34px;
    font-weight: 500;
    line-height: 1.1;
    color: var(--rt-gold);
  }
  .rt-cart__count-wrap { text-align: right; }
  .rt-cart__count-num {
    font-family: var(--rt-font-grotesk);
    font-size: 40px;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 0.92;
    text-transform: uppercase;
    color: var(--rt-ink);
    display: block;
  }
  .rt-cart__count-label {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
    display: block;
    margin-top: 4px;
  }

  /* ── Empty state ── */
  .rt-cart__empty { border-bottom: 1px solid var(--rt-ink); }
  .rt-cart__empty-hero {
    padding: 96px 28px 88px;
    border-bottom: 1px solid var(--rt-ink);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .rt-cart__empty-eyebrow {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
  }
  .rt-cart__empty-display {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(48px, 7vw, 104px);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--rt-ink);
    margin: 0;
  }
  .rt-cart__empty-deva {
    font-family: var(--rt-font-deva);
    font-size: 30px;
    font-weight: 500;
    color: var(--rt-gold);
  }
  .rt-cart__empty-body {
    font-family: var(--rt-font-grotesk);
    font-size: 15px;
    color: var(--rt-ink);
    opacity: 0.8;
    max-width: 42ch;
    line-height: 1.6;
    margin: 0;
  }
  .rt-cart__empty-cta {
    margin-top: 12px;
    background: var(--rt-ink);
    color: var(--rt-paper);
    text-decoration: none;
    padding: 16px 30px;
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    transition: opacity 180ms;
  }
  .rt-cart__empty-cta:hover { opacity: 0.75; }
  .rt-cart__login-note {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    color: var(--rt-ink);
    opacity: 0.55;
    line-height: 1.6;
  }
  .rt-cart__empty-suggest { padding: 48px 28px 56px; }
  .rt-cart__suggest-label {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
    display: block;
    margin-bottom: 24px;
  }
  .rt-cart__suggest-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  /* ── Main body ── */
  .rt-cart__body {
    display: grid;
    grid-template-columns: 1.55fr 0.85fr;
    gap: 56px;
    align-items: start;
    padding: 36px 28px 48px;
    border-bottom: 1px solid var(--rt-ink);
  }
  .rt-cart__left {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* ── Line item ── */
  .rt-citem {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    gap: 22px;
    padding: 24px 0;
    border-bottom: 1px solid rgba(10,10,10,0.18);
    align-items: start;
  }
  .rt-citem:last-child { border-bottom: none; }
  .rt-citem__img-link {
    display: block;
    width: 96px;
    aspect-ratio: 1 / 1.18;
    overflow: hidden;
    border: 1px solid var(--rt-ink);
    flex-shrink: 0;
  }
  .rt-citem__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .rt-citem__details {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .rt-citem__name-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .rt-citem__name {
    font-family: var(--rt-font-grotesk);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--rt-ink);
    text-decoration: none;
    display: block;
    line-height: 1.2;
    transition: opacity 160ms;
  }
  .rt-citem__name:hover { opacity: 0.55; }
  .rt-citem__deva {
    font-family: var(--rt-font-deva);
    font-size: 16px;
    font-weight: 500;
    color: var(--rt-gold);
    line-height: 1.1;
  }
  .rt-citem__sku {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.55;
  }
  .rt-citem__variant {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    color: var(--rt-ink);
    opacity: 0.75;
    margin: 0;
  }
  .rt-citem__stock {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
  }
  .rt-citem__stock-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #2f5a3f;
    flex-shrink: 0;
  }
  .rt-citem__stock-label {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.6;
  }
  .rt-citem__actions {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: auto;
    flex-wrap: wrap;
  }

  /* Qty stepper */
  quantity-input.rt-cart-qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--rt-ink);
    height: 36px;
  }
  .rt-cart-qty .quantity__button {
    width: 36px;
    height: 100%;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--rt-ink);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 140ms;
    flex-shrink: 0;
    padding: 0;
  }
  .rt-cart-qty .quantity__button svg { width: 10px; height: 10px; }
  .rt-cart-qty .quantity__button:hover { opacity: 0.35; }
  .rt-cart-qty .quantity__input {
    width: 40px;
    text-align: center;
    border: none;
    border-left: 1px solid var(--rt-ink);
    border-right: 1px solid var(--rt-ink);
    background: none;
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--rt-ink);
    height: 100%;
    -moz-appearance: textfield;
    appearance: textfield;
    padding: 0;
  }
  .rt-cart-qty .quantity__input::-webkit-outer-spin-button,
  .rt-cart-qty .quantity__input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  .rt-citem__remove-btn {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.7;
    text-decoration: underline;
    text-underline-offset: 3px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 160ms;
  }
  .rt-citem__remove-btn:hover { opacity: 1; }

  /* Price col */
  .rt-citem__price-col {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    min-width: 110px;
    text-align: right;
  }
  .rt-citem__total {
    font-family: var(--rt-font-grotesk);
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--rt-ink);
    margin: 0;
  }
  .rt-citem__total--old {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    font-weight: 400;
    color: var(--rt-ink);
    opacity: 0.45;
    text-decoration: line-through;
    display: block;
    margin-bottom: 2px;
  }
  .rt-citem__unit {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.5;
    margin-top: 8px;
  }

  /* Errors */
  .rt-citem__error {
    grid-column: 2 / -1;
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    color: #b91c1c;
    letter-spacing: 0.05em;
  }
  .rt-citem__error:empty { display: none; }

  /* Loading state — subtle dim, no overlay spinner */
  #main-cart-items.cart__items--disabled { opacity: 0.6; pointer-events: none; transition: opacity 200ms; }

  /* Cart-level discounts */
  .rt-cart__discounts { display: flex; flex-direction: column; gap: 8px; }
  .rt-cart__discount-item {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    color: var(--rt-ink);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rt-cart__discount-item svg { width: 14px; height: 14px; opacity: 0.5; }

  /* Continue shopping */
  .rt-cart__continue {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--rt-ink);
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    transition: opacity 160ms;
  }
  .rt-cart__continue:hover { opacity: 0.5; }

  /* ── RIGHT column ── */
  .rt-cart__right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Order summary box ── */
  .rt-cart__summary { border: 1px solid var(--rt-ink); }
  .rt-cart__summary-hd {
    padding: 16px 20px;
    border-bottom: 1px solid var(--rt-ink);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .rt-cart__summary-title {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--rt-ink);
  }
  .rt-cart__summary-count {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.55;
  }
  .rt-cart__summary-rows { padding: 12px 20px; display: flex; flex-direction: column; }
  .rt-cart__summary-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 9px 0;
  }
  .rt-cart__summary-row-label {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.8;
  }
  .rt-cart__summary-row-val {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    font-weight: 600;
    color: var(--rt-ink);
  }
  .rt-cart__summary-row-val--accent { color: #7a5e2c; }
  .rt-cart__summary-divider { height: 1px; background: var(--rt-ink); margin: 10px 0; }
  .rt-cart__summary-total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 4px 0;
  }
  .rt-cart__summary-total-label {
    font-family: var(--rt-font-grotesk);
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--rt-ink);
    text-transform: uppercase;
  }
  .rt-cart__summary-total-amount {
    font-family: var(--rt-font-grotesk);
    font-size: 28px;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--rt-ink);
  }
  .rt-cart__summary-footer {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
    padding-bottom: 4px;
  }
  .rt-cart__summary-tax {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.5;
  }
  .rt-cart__summary-saved {
    font-family: var(--rt-font-grotesk);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    color: #7a5e2c;
  }
  .rt-cart__summary-actions {
    padding: 0 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rt-cart__checkout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    width: 100%;
    background: var(--rt-ink);
    color: var(--rt-paper);
    border: 1px solid var(--rt-ink);
    padding: 16px 22px;
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 180ms;
    text-align: center;
  }
  .rt-cart__checkout:hover { opacity: 0.75; }
  .rt-cart__checkout[disabled] { opacity: 0.35; cursor: default; }
  .rt-cart__payment-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    opacity: 0.65;
  }
  .rt-cart__payment-dot { opacity: 0.4; }
  .rt-cart__secure-note {
    text-align: center;
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    color: var(--rt-ink);
    opacity: 0.55;
    line-height: 1.5;
    margin: 0;
  }
  #cart-errors {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    color: #b91c1c;
    letter-spacing: 0.04em;
  }
  #cart-errors:empty { display: none; }
  .rt-cart__dynamic { margin-top: 4px; }

  /* ── Trust badges ── */
  .rt-cart__trust {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--rt-ink);
  }
  .rt-cart__trust-cell {
    padding: 14px 16px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .rt-cart__trust-cell:nth-child(odd)  { border-right: 1px solid var(--rt-ink); }
  .rt-cart__trust-cell:nth-child(n+3)  { border-top: 1px solid var(--rt-ink); }
  .rt-cart__trust-check {
    color: var(--rt-gold);
    font-size: 13px;
    line-height: 1.2;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .rt-cart__trust-key {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    font-weight: 700;
    color: var(--rt-ink);
    line-height: 1.25;
    display: block;
  }
  .rt-cart__trust-sub {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.55;
    display: block;
    margin-top: 3px;
  }

  /* ── Upsell ── */
  .rt-cart__upsell {
    border-bottom: 1px solid var(--rt-ink);
    padding: 56px 28px 52px;
    background: var(--rt-paper-warm);
  }
  .rt-cart__upsell-hd {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 28px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .rt-cart__upsell-eyebrow {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
    display: block;
    margin-bottom: 12px;
  }
  .rt-cart__upsell-title {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(34px, 4.4vw, 60px);
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--rt-ink);
    margin: 0;
  }
  .rt-cart__upsell-sub {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    color: var(--rt-ink);
    opacity: 0.7;
    max-width: 40ch;
    line-height: 1.5;
  }
  .rt-cart__upsell-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .rt-cart__upsell-card { display: flex; flex-direction: column; }
  .rt-cart__upsell-img-link {
    display: block;
    position: relative;
    aspect-ratio: 1 / 1.18;
    overflow: hidden;
    border: 1px solid var(--rt-ink);
  }
  .rt-cart__upsell-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .rt-cart__upsell-img--alt { opacity: 0; }
  @media screen and (min-width: 750px) {
    .rt-cart__upsell-img-link:hover .rt-cart__upsell-img:first-child:not(:only-child) { opacity: 0; }
    .rt-cart__upsell-img-link:hover .rt-cart__upsell-img--alt { opacity: 1; transform: scale(1.03); }
  }
  .rt-cart__upsell-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 12px;
    gap: 10px;
  }
  .rt-cart__upsell-name {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    font-weight: 600;
    color: var(--rt-ink);
    text-decoration: none;
    transition: opacity 160ms;
  }
  .rt-cart__upsell-name:hover { opacity: 0.55; }
  .rt-cart__upsell-price {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    font-weight: 700;
    color: var(--rt-ink);
    white-space: nowrap;
  }
  .rt-cart__upsell-variant {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.55;
    margin-top: 4px;
  }

  /* ── Empty / filled state ── */
  cart-items.is-empty .rt-cart__hd          { border-bottom: none; }
  cart-items.is-empty .rt-cart__count-wrap  { display: none; }
  cart-items.is-empty .rt-cart__main        { display: none; }
  cart-items:not(.is-empty) .rt-cart__empty { display: none; }

  /* ── Responsive ── */

  /* Tablet: collapse body to single column early so summary doesn't get squeezed */
  @media (max-width: 899px) {
    .rt-cart__body {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .rt-cart__right { max-width: 480px; }
    .rt-cart__upsell-grid  { grid-template-columns: repeat(2, 1fr); }
    .rt-cart__suggest-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile */
  @media (max-width: 749px) {
    .rt-cart__subbar {
      padding: 10px 16px;
      flex-wrap: wrap;
      gap: 6px;
    }
    .rt-cart__bc-item, .rt-cart__bc-sep { font-size: 9px; }

    .rt-cart__hd { padding: 22px 16px 18px; gap: 12px; }
    .rt-cart__title { font-size: clamp(34px, 9vw, 52px); }
    .rt-cart__title-deva { font-size: 22px; }
    .rt-cart__count-num { font-size: 32px; }

    .rt-cart__body { padding: 20px 16px 36px; gap: 28px; }

    /* Cart item: 2-col grid (img | details), price spans full width below */
    .rt-citem {
      grid-template-columns: 76px 1fr;
      grid-template-rows: auto auto;
      gap: 8px 14px;
    }
    .rt-citem__img-col  { grid-column: 1; grid-row: 1; }
    .rt-citem__img-link { width: 76px; }
    .rt-citem__details  { grid-column: 2; grid-row: 1; }
    .rt-citem__price-col {
      grid-column: 1 / span 2;
      grid-row: 2;
      flex-direction: row;
      justify-content: space-between;
      align-items: baseline;
      text-align: left;
      min-width: 0;
      padding-top: 2px;
    }
    .rt-citem__error  { grid-column: 1 / span 2; }
    .rt-citem__total  { font-size: 18px; }
    .rt-citem__name   { font-size: 15px; }

    .rt-cart__right { max-width: none; }
    .rt-cart__summary-total-amount { font-size: 22px; }
    .rt-cart__checkout { font-size: 11px; padding: 14px 16px; }
    .rt-cart__payment-strip { font-size: 9px; gap: 7px; }

    .rt-cart__empty-hero    { padding: 48px 16px 48px; }
    .rt-cart__empty-display { font-size: clamp(38px, 10vw, 60px); }
    .rt-cart__empty-suggest { padding: 28px 16px 40px; }
    .rt-cart__suggest-grid  { grid-template-columns: repeat(2, 1fr); gap: 12px; }

    .rt-cart__upsell { padding: 36px 16px 36px; }
    .rt-cart__upsell-grid  { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .rt-cart__upsell-title { font-size: clamp(28px, 8vw, 40px); }
    .rt-cart__upsell-hd    { flex-direction: column; gap: 6px; align-items: flex-start; }
    .rt-cart__upsell-sub   { display: none; }
  }
</style>

<cart-items class="rt-cart{% if cart == empty %} is-empty{% endif %}">

  {%- comment -%} Sub-bar {%- endcomment -%}
  <div class="rt-cart__subbar">
    <div class="rt-cart__breadcrumb">
      <span class="rt-cart__bc-item">{{ shop.name | escape }}</span>
      <span class="rt-cart__bc-sep">/</span>
      <span class="rt-cart__bc-item">{{ 'general.navigation.shop' | t | default: 'Shop' }}</span>
      <span class="rt-cart__bc-sep">/</span>
      <span class="rt-cart__bc-item rt-cart__bc-current">Your bag</span>
    </div>
    <a href="{{ routes.all_products_collection_url }}" class="rt-cart__back">
      <span aria-hidden="true" style="font-size:14px;">←</span>
      {{ 'general.continue_shopping' | t }}
    </a>
  </div>

  {%- comment -%} Hero {%- endcomment -%}
  <div class="rt-cart__hd">
    <div>
      <span class="rt-cart__eyebrow">Index 01 — Review your order</span>
      <div class="rt-cart__title-row">
        <h1 class="rt-cart__title">Your bag.</h1>
        <span class="rt-cart__title-deva" aria-hidden="true">झोला</span>
      </div>
    </div>
    <div class="rt-cart__count-wrap">
      <span class="rt-cart__count-num">{{ cart.item_count | prepend: '0' | slice: -2, 2 }}</span>
      <span class="rt-cart__count-label">
        {%- if cart.item_count == 1 -%}Piece{%- else -%}Pieces{%- endif -%}
      </span>
    </div>
  </div>

  {%- comment -%} Empty state {%- endcomment -%}
  <div class="rt-cart__empty">
    <div class="rt-cart__empty-hero">
      <span class="rt-cart__empty-eyebrow">Index 01 — Nothing here yet</span>
      <p class="rt-cart__empty-display">Your bag<br>is empty.</p>
      <span class="rt-cart__empty-deva" aria-hidden="true">रंगतारिणी</span>
      <p class="rt-cart__empty-body">Heirloom-grade pieces, hand-set in Jaipur. Start with a piece below — or browse the full edit.</p>
      <a href="{{ routes.all_products_collection_url }}" class="rt-cart__empty-cta">
        {{ 'general.continue_shopping' | t }} <span aria-hidden="true" style="font-size:14px;">→</span>
      </a>
      {%- if shop.customer_accounts_enabled and customer == null -%}
        <p class="rt-cart__login-note">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    {%- if section.settings.upsell_collection != blank -%}
      {%- assign upsell_coll_empty = collections[section.settings.upsell_collection] -%}
      {%- if upsell_coll_empty != blank -%}
        <div class="rt-cart__empty-suggest">
          <span class="rt-cart__suggest-label">Bestsellers to begin with</span>
          <div class="rt-cart__suggest-grid">
            {%- for product in upsell_coll_empty.products limit: 4 -%}
              <div class="rt-cart__upsell-card">
                <a href="{{ product.url }}" class="rt-cart__upsell-img-link">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="300"
                      height="{{ 300 | divided_by: product.featured_image.aspect_ratio | ceil }}"
                      class="rt-cart__upsell-img">
                    {%- if product.media[1] -%}
                      <img
                        src="{{ product.media[1] | image_url: width: 600 }}"
                        alt="{{ product.media[1].alt | escape }}"
                        loading="lazy"
                        width="300"
                        height="{{ 300 | divided_by: product.media[1].aspect_ratio | ceil }}"
                        class="rt-cart__upsell-img rt-cart__upsell-img--alt">
                    {%- endif -%}
                  {%- endif -%}
                </a>
                <div class="rt-cart__upsell-info">
                  <a href="{{ product.url }}" class="rt-cart__upsell-name">{{ product.title | escape }}</a>
                  <span class="rt-cart__upsell-price">{{ product.price | money }}</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- comment -%}
    Main content — non-empty cart.
    The ENTIRE two-column body lives inside #main-cart-items .js-contents so
    a single AJAX section render updates both the items list and the order
    summary in one shot. Dawn's getSectionInnerHTML(html, '.js-contents')
    picks the first (and only) .js-contents in the section — which is this one.
  {%- endcomment -%}
  <div class="rt-cart__main">
    <form action="{{ routes.cart_url }}" class="critical-hidden" method="post" id="cart">
      <div id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">

          {%- liquid
            assign mrp_total = 0
            for item in cart.items
              assign mrp_total = mrp_total | plus: item.original_line_price
            endfor
            assign cart_savings = mrp_total | minus: cart.total_price
            assign free_ship_threshold = 350000
            assign shipping_free = false
            if cart.total_price >= free_ship_threshold
              assign shipping_free = true
            endif
          -%}

          <div class="rt-cart__body">

            {%- comment -%} LEFT — items {%- endcomment -%}
            <div class="rt-cart__left">

              <div class="rt-cart__items-list">
                {%- for item in cart.items -%}

                  <div class="rt-citem" id="CartItem-{{ item.index | plus: 1 }}">

                    <div class="rt-citem__img-col">
                      {%- if item.image -%}
                        <a href="{{ item.url }}" class="rt-citem__img-link" aria-hidden="true" tabindex="-1">
                          <img
                            src="{{ item.image | image_url: width: 300 }}"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="150"
                            height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                            class="rt-citem__img">
                        </a>
                      {%- endif -%}
                    </div>

                    <div class="rt-citem__details">
                      <div class="rt-citem__name-row">
                        <a href="{{ item.url }}" class="rt-citem__name">{{ item.product.title | escape }}</a>
                        {%- assign deva_name = item.product.metafields.custom.deva_name -%}
                        {%- if deva_name != blank -%}
                          <span class="rt-citem__deva" aria-hidden="true">{{ deva_name }}</span>
                        {%- endif -%}
                      </div>

                      {%- if item.product.has_only_default_variant == false -%}
                        {%- for option in item.options_with_values -%}
                          <p class="rt-citem__variant">{{ option.name }}: {{ option.value }}</p>
                        {%- endfor -%}
                      {%- endif -%}

                      {%- for property in item.properties -%}
                        {%- assign property_first_char = property.first | slice: 0 -%}
                        {%- if property.last != blank and property_first_char != '_' -%}
                          <p class="rt-citem__variant">{{ property.first }}: {{ property.last }}</p>
                        {%- endif -%}
                      {%- endfor -%}

                      {%- if item.variant.available -%}
                        <div class="rt-citem__stock">
                          <span class="rt-citem__stock-dot" aria-hidden="true"></span>
                          <span class="rt-citem__stock-label">In stock</span>
                        </div>
                      {%- endif -%}

                      <div class="rt-citem__actions">
                        <quantity-popover>
                          <div class="quantity-popover-container">
                            <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
                              {{ 'products.product.quantity.label' | t }}
                            </label>
                            <quantity-input class="quantity cart-quantity rt-cart-qty">
                              <button class="quantity__button" name="minus" type="button">
                                <span class="visually-hidden">{{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}</span>
                                <span class="svg-wrapper">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
                              </button>
                              <input
                                class="quantity__input"
                                data-quantity-variant-id="{{ item.variant.id }}"
                                type="number"
                                name="updates[]"
                                value="{{ item.quantity }}"
                                {% # theme-check-disable %}
                                data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                min="0"
                                data-min="{{ item.variant.quantity_rule.min }}"
                                {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                                step="{{ item.variant.quantity_rule.increment }}"
                                {% # theme-check-enable %}
                                aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                id="Quantity-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}">
                              <button class="quantity__button" name="plus" type="button">
                                <span class="visually-hidden">{{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}</span>
                                <span class="svg-wrapper">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                              </button>
                            </quantity-input>
                          </div>
                          <div class="rt-citem__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                            <small class="cart-item__error-text"></small>
                          </div>
                        </quantity-popover>

                        {%- assign can_remove = item.instructions.can_remove | default: true -%}
                        {%- if can_remove -%}
                          <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                            <a
                              href="{{ item.url_to_remove }}"
                              class="rt-citem__remove-btn"
                              aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}">
                              {{ 'sections.cart.remove' | t }}
                            </a>
                          </cart-remove-button>
                        {%- endif -%}
                      </div>
                    </div>

                    <div class="rt-citem__price-col">
                      <div>
                        {%- if item.original_line_price != item.final_line_price -%}
                          <span class="rt-citem__total--old">{{ item.original_line_price | money }}</span>
                          <p class="rt-citem__total">{{ item.final_line_price | money }}</p>
                        {%- else -%}
                          <p class="rt-citem__total">{{ item.original_line_price | money }}</p>
                        {%- endif -%}
                      </div>
                      {%- if item.quantity > 1 -%}
                        <span class="rt-citem__unit">{{ item.final_price | money }} ea</span>
                      {%- endif -%}
                    </div>

                  </div>

                {%- endfor -%}
              </div>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="rt-cart__discounts">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <p class="rt-cart__discount-item">
                      {{- 'icon-discount.svg' | inline_asset_content -}}
                      {{ discount.title | escape }}
                      <span>(−{{ discount.total_allocated_amount | money }})</span>
                    </p>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <a href="{{ routes.all_products_collection_url }}" class="rt-cart__continue">
                <span aria-hidden="true" style="font-size:14px;">←</span>
                {{ 'general.continue_shopping' | t }}
              </a>

            </div>

            {%- comment -%} RIGHT — order summary + trust badges {%- endcomment -%}
            <div class="rt-cart__right">

              <div class="rt-cart__summary">
                <div class="rt-cart__summary-hd">
                  <span class="rt-cart__summary-title">Order summary</span>
                  <span class="rt-cart__summary-count">
                    {{ cart.item_count }} {%- if cart.item_count == 1 %} line{%- else %} lines{%- endif -%}
                  </span>
                </div>

                <div class="rt-cart__summary-rows">
                  <div class="rt-cart__summary-row">
                    <span class="rt-cart__summary-row-label">Subtotal (MRP)</span>
                    <span class="rt-cart__summary-row-val">{{ mrp_total | money }}</span>
                  </div>

                  {%- if cart_savings > 0 -%}
                    <div class="rt-cart__summary-row">
                      <span class="rt-cart__summary-row-label">Catalog savings</span>
                      <span class="rt-cart__summary-row-val rt-cart__summary-row-val--accent">− {{ cart_savings | money }}</span>
                    </div>
                  {%- endif -%}

                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="rt-cart__summary-row">
                      <span class="rt-cart__summary-row-label">{{ discount.title | escape }}</span>
                      <span class="rt-cart__summary-row-val rt-cart__summary-row-val--accent">− {{ discount.total_allocated_amount | money }}</span>
                    </div>
                  {%- endfor -%}

                  <div class="rt-cart__summary-row">
                    <span class="rt-cart__summary-row-label">Shipping</span>
                    <span class="rt-cart__summary-row-val">
                      {%- if shipping_free -%}Free{%- else -%}Calculated at checkout{%- endif -%}
                    </span>
                  </div>

                  <div class="rt-cart__summary-divider"></div>

                  <div class="rt-cart__summary-total-row">
                    <span class="rt-cart__summary-total-label">Total</span>
                    <span class="rt-cart__summary-total-amount">{{ cart.total_price | money_with_currency }}</span>
                  </div>

                  <div class="rt-cart__summary-footer">
                    <span class="rt-cart__summary-tax">
                      {%- if cart.taxes_included -%}
                        Incl. of all taxes
                      {%- else -%}
                        Excl. taxes
                      {%- endif -%}
                    </span>
                    {%- if cart_savings > 0 -%}
                      <span class="rt-cart__summary-saved">You save {{ cart_savings | money }}</span>
                    {%- endif -%}
                  </div>
                </div>

                <div class="rt-cart__summary-actions">
                  <button
                    type="submit"
                    id="checkout"
                    class="rt-cart__checkout"
                    name="checkout"
                    {% if cart == empty %}disabled{% endif %}>
                    {{ 'sections.cart.checkout' | t }} <span aria-hidden="true" style="font-size:15px;">→</span>
                  </button>

                  {%- if additional_checkout_buttons -%}
                    <div class="rt-cart__dynamic additional-checkout-buttons">
                      {{ content_for_additional_checkout_buttons }}
                    </div>
                  {%- endif -%}

                  <div class="rt-cart__payment-strip" aria-label="Accepted payment methods">
                    <span>UPI</span>
                    <span class="rt-cart__payment-dot" aria-hidden="true">·</span>
                    <span>Cards</span>
                    <span class="rt-cart__payment-dot" aria-hidden="true">·</span>
                    <span>Banking</span>
                  </div>

                  <p class="rt-cart__secure-note">Secure checkout · 7-day exchange</p>

                  <div id="cart-errors" role="alert"></div>
                </div>
              </div>

              <div class="rt-cart__trust" aria-label="Trust badges">
                <div class="rt-cart__trust-cell">
                  <span class="rt-cart__trust-check" aria-hidden="true">✓</span>
                  <div>
                    <span class="rt-cart__trust-key">Easy 7-Day Exchange</span>
                    <span class="rt-cart__trust-sub">Unworn · tag intact</span>
                  </div>
                </div>
                <div class="rt-cart__trust-cell">
                  <span class="rt-cart__trust-check" aria-hidden="true">✓</span>
                  <div>
                    <span class="rt-cart__trust-key">Secure Checkout</span>
                    <span class="rt-cart__trust-sub">256-bit encrypted</span>
                  </div>
                </div>
                <div class="rt-cart__trust-cell">
                  <span class="rt-cart__trust-check" aria-hidden="true">✓</span>
                  <div>
                    <span class="rt-cart__trust-key">Trusted by 1000+</span>
                    <span class="rt-cart__trust-sub">Verified buyers</span>
                  </div>
                </div>
                <div class="rt-cart__trust-cell">
                  <span class="rt-cart__trust-check" aria-hidden="true">✓</span>
                  <div>
                    <span class="rt-cart__trust-key">BIS 925 Hallmarked</span>
                    <span class="rt-cart__trust-sub">Certified silver</span>
                  </div>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
        {{ 'accessibility.loading' | t }}
      </p>

    </form>
  </div>

  {%- comment -%} Upsell row — outside form and js-contents, static {%- endcomment -%}
  {%- if section.settings.show_upsell and section.settings.upsell_collection != blank -%}
    {%- assign upsell_coll = collections[section.settings.upsell_collection] -%}
    {%- if upsell_coll != blank and upsell_coll.products.size > 0 -%}
      <div class="rt-cart__upsell">
        <div class="rt-cart__upsell-hd">
          <div>
            <span class="rt-cart__upsell-eyebrow">Index 02 — Complete the set</span>
            <h2 class="rt-cart__upsell-title">You might also<br>pair with.</h2>
          </div>
          <p class="rt-cart__upsell-sub">Hand-set in the same Jaipur karkhana. Layer, stack, gift.</p>
        </div>
        <div class="rt-cart__upsell-grid">
          {%- for product in upsell_coll.products limit: 4 -%}
            <div class="rt-cart__upsell-card">
              <a href="{{ product.url }}" class="rt-cart__upsell-img-link">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="300"
                    height="{{ 300 | divided_by: product.featured_image.aspect_ratio | ceil }}"
                    class="rt-cart__upsell-img">
                  {%- if product.media[1] -%}
                    <img
                      src="{{ product.media[1] | image_url: width: 600 }}"
                      alt="{{ product.media[1].alt | escape }}"
                      loading="lazy"
                      width="300"
                      height="{{ 300 | divided_by: product.media[1].aspect_ratio | ceil }}"
                      class="rt-cart__upsell-img rt-cart__upsell-img--alt">
                  {%- endif -%}
                {%- endif -%}
              </a>
              <div class="rt-cart__upsell-info">
                <a href="{{ product.url }}" class="rt-cart__upsell-name">{{ product.title | escape }}</a>
                <span class="rt-cart__upsell-price">{{ product.price | money }}</span>
              </div>
              {%- if product.variants.first.sku != blank -%}
                <span class="rt-cart__upsell-variant">{{ product.variants.first.sku }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}

</cart-items>

{% schema %}
{
  "name": "RT Cart Items",
  "class": "rt-cart-section",
  "settings": [
    {
      "type": "header",
      "content": "Upsell section"
    },
    {
      "type": "checkbox",
      "id": "show_upsell",
      "label": "Show 'pair with' upsell",
      "default": true
    },
    {
      "type": "collection",
      "id": "upsell_collection",
      "label": "Upsell collection (shows first 4 products)"
    }
  ]
}
{% endschema %}
