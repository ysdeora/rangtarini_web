{%- comment -%}
  New Arrivals — auto-detects newest products from all collections
  sorted by creation date. No dedicated collection needed.
{%- endcomment -%}

{%- assign product_limit    = 8 -%}
{%- assign days_threshold   = section.settings.days_new | default: 60 -%}
{%- assign now_unix          = 'now' | date: '%s' | plus: 0 -%}
{%- assign threshold_seconds = days_threshold | times: 86400 -%}

{%- comment -%} Sort all products newest-first {%- endcomment -%}
{%- assign all_sorted = collections.all.products | sort: 'created_at' | reverse -%}

{%- comment -%} Build a filtered array of products within the date window {%- endcomment -%}
{%- assign new_products = '' | split: '' -%}
{%- for product in all_sorted -%}
  {%- assign product_unix = product.created_at | date: '%s' | plus: 0 -%}
  {%- assign age_seconds   = now_unix | minus: product_unix -%}
  {%- if age_seconds <= threshold_seconds -%}
    {%- assign new_products = new_products | concat: product -%}
  {%- endif -%}
  {%- if new_products.size >= product_limit -%}{%- break -%}{%- endif -%}
{%- endfor -%}

{%- comment -%}
  Fallback: if nothing qualifies (e.g. all products older than threshold),
  just show the most recent N regardless of date.
{%- endcomment -%}
{%- if new_products.size < 4 -%}
  {%- assign new_products = all_sorted | slice: 0, product_limit -%}
{%- endif -%}

<style>
  .na-section {
    padding: 72px 28px 64px;
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
  }
  .na-hd {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 36px;
    gap: 24px;
    flex-wrap: wrap;
  }
  .na-eyebrow {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.72;
    margin: 0 0 12px;
  }
  .na-heading {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(48px, 6vw, 88px);
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--rt-ink);
    margin: 0;
  }
  .na-subhead {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--rt-ink);
    opacity: 0.7;
    margin: 12px 0 0;
    max-width: 46ch;
    letter-spacing: 0;
  }
  .na-cta-link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 220ms;
  }
  .na-cta-link:hover { opacity: 0.6; }

  .na-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .na-card {
    display: block;
    text-decoration: none;
    color: var(--rt-ink);
  }
  .na-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1.18;
  }
  .na-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.5s ease, transform 0.6s ease;
  }
  .na-img--secondary { opacity: 0; }
  .na-card:hover .na-img--primary   { opacity: 0; }
  .na-card:hover .na-img--secondary { opacity: 1; transform: scale(1.03); }
  .na-card:hover .na-img--primary:only-child { opacity: 1; transform: scale(1.03); }

  .na-add-btn {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    background: var(--rt-paper);
    color: var(--rt-ink);
    border: 1px solid var(--rt-ink);
    padding: 10px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 240ms, transform 240ms;
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    display: block;
  }
  .na-card:hover .na-add-btn {
    opacity: 1;
    transform: translateY(0);
  }

  .na-soldout-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--rt-paper);
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    z-index: 3;
  }

  .na-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 14px;
    gap: 8px;
  }
  .na-name {
    font-family: var(--rt-font-grotesk);
    font-size: 14px;
    font-weight: 500;
    color: var(--rt-ink);
    margin: 0;
    letter-spacing: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .na-price-row {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    font-weight: 600;
    color: var(--rt-ink);
    margin: 0;
    white-space: nowrap;
    letter-spacing: 0;
  }
  .na-price-compare {
    text-decoration: line-through;
    opacity: 0.72;
    margin-right: 4px;
    font-size: 0.9em;
  }

  .na-empty {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    color: var(--rt-ink);
    opacity: 0.55;
    padding: 40px 0;
  }

  @media (max-width: 990px) {
    .na-grid { grid-template-columns: repeat(2, 1fr); gap: 18px; }
    .na-section { padding: 48px 20px 40px; }
  }
  @media (max-width: 749px) {
    .na-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .na-section { padding: 40px 16px 32px; }
    .na-heading { font-size: 40px; }
    .na-add-btn { display: none; }
    .na-card:hover .na-img--primary   { opacity: 1; }
    .na-card:hover .na-img--secondary { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .na-img { transition: none; }
    .na-add-btn { transition: none; }
  }
</style>

<section class="na-section" aria-labelledby="na-heading">

  <div class="na-hd">
    <div>
      <p class="na-eyebrow">{{ section.settings.eyebrow | default: 'Latest drop · This season' }}</p>
      <h2 class="na-heading rt-mask" id="na-heading"><span>{{ section.settings.heading | default: 'New in.' }}</span></h2>
    </div>
    <a
      href="{{ section.settings.cta_url | default: '/collections/all?sort_by=created-descending' }}"
      class="na-cta-link"
    >{{ section.settings.cta_label | default: 'View all' }} →</a>
  </div>

  {%- if new_products.size > 0 -%}
    <div class="na-grid">
      {%- for product in new_products -%}
        {%- assign primary_img   = product.featured_image -%}
        {%- assign secondary_img = product.images[1] -%}
        {%- assign on_sale = false -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign on_sale = true -%}
        {%- endif -%}

        <a href="{{ product.url }}"
           class="na-card"
           data-rt-reveal
           style="--rt-reveal-delay: {{ forloop.index0 | times: 60 }}ms"
           aria-label="{{ product.title | escape }}, {{ product.price_min | money_without_trailing_zeros }}">

          <div class="na-media">
            {%- if primary_img -%}
              <img
                class="na-img na-img--primary"
                src="{{ primary_img | image_url: width: 600 }}"
                srcset="{{ primary_img | image_url: width: 300 }} 300w,
                        {{ primary_img | image_url: width: 500 }} 500w,
                        {{ primary_img | image_url: width: 700 }} 700w"
                sizes="(max-width: 749px) 50vw, (max-width: 990px) 50vw, 25vw"
                alt="{{ product.title | escape }}"
                loading="lazy"
                decoding="async"
                width="{{ primary_img.width }}"
                height="{{ primary_img.height }}">
            {%- else -%}
              <div class="na-img na-img--primary" aria-hidden="true"></div>
            {%- endif -%}

            {%- if secondary_img -%}
              <img
                class="na-img na-img--secondary"
                src="{{ secondary_img | image_url: width: 600 }}"
                srcset="{{ secondary_img | image_url: width: 300 }} 300w,
                        {{ secondary_img | image_url: width: 500 }} 500w,
                        {{ secondary_img | image_url: width: 700 }} 700w"
                sizes="(max-width: 749px) 50vw, (max-width: 990px) 50vw, 25vw"
                alt=""
                loading="lazy"
                decoding="async"
                width="{{ secondary_img.width }}"
                height="{{ secondary_img.height }}"
                aria-hidden="true">
            {%- endif -%}

            {%- if product.available -%}
              <div class="na-add-btn" aria-hidden="true">
                Add — {{ product.price_min | money_without_trailing_zeros }}
              </div>
            {%- else -%}
              <div class="na-soldout-overlay">Sold Out</div>
            {%- endif -%}
          </div>

          <div class="na-info">
            <h3 class="na-name">{{ product.title | escape }}</h3>
            <p class="na-price-row">
              {%- if on_sale -%}
                <span class="na-price-compare">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
              {%- endif -%}
              {{ product.price_min | money_without_trailing_zeros }}
            </p>
          </div>
        </a>
      {%- endfor -%}
    </div>

  {%- else -%}
    <p class="na-empty">New pieces are on their way. Check back soon.</p>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "New Arrivals",
  "tag": "div",
  "class": "new-arrivals-section",
  "limit": 1,
  "templates": ["index"],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Just In"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The latest additions to our collection — handcrafted, just for you."
    },
    {
    "type": "range",
    "id": "days_new",
    "label": "Show products added within (days)",
    "info": "Products created within this many days will appear. Falls back to the most recent products if none qualify.",
    "min": 30,
    "max": 180,
    "step": 30,
    "default": 60
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View All New Arrivals"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link",
      "info": "Leave blank to default to all products sorted by newest."
    }
  ],
  "presets": [
    {
      "name": "New Arrivals"
    }
  ]
}
{% endschema %}
