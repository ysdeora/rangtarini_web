<style>
  .rt-cl {
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
    padding: 72px 28px 80px;
  }

  /* ── Header ── */
  .rt-cl__hd {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 48px;
    flex-wrap: wrap;
    gap: 24px;
  }
  .rt-cl__eyebrow {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
    display: block;
    margin: 0 0 12px;
  }
  .rt-cl__display {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(48px, 6vw, 88px);
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    line-height: 0.92;
    color: var(--rt-ink);
    margin: 0;
  }
  .rt-cl__total {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.6;
    align-self: flex-end;
    padding-bottom: 6px;
  }

  /* ── Grid ── */
  .rt-cl__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  /* ── Tile ── */
  .rt-cl__tile {
    text-decoration: none;
    color: var(--rt-ink);
    display: block;
  }
  .rt-cl__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1.25;
    background: rgba(10, 10, 10, 0.05);
  }
  .rt-cl__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 540ms ease;
  }
  .rt-cl__tile:hover .rt-cl__img {
    transform: scale(1.04);
  }
  .rt-cl__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--rt-paper);
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 3px 8px;
    color: var(--rt-ink);
    z-index: 2;
  }

  /* placeholder when no image */
  .rt-cl__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rt-cl__placeholder svg {
    width: 40px;
    height: 40px;
    opacity: 0.18;
  }

  /* ── Info bar ── */
  .rt-cl__info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--rt-ink);
  }
  .rt-cl__name {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(14px, 1.6vw, 22px);
    font-weight: 700;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--rt-ink);
    margin: 0;
    line-height: 1.1;
  }
  .rt-cl__meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
  }
  .rt-cl__count {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
  }
  .rt-cl__arrow {
    font-size: 15px;
    display: inline-block;
    transition: transform 200ms ease;
    line-height: 1;
  }
  .rt-cl__tile:hover .rt-cl__arrow {
    transform: translateX(4px);
  }

  /* ── Pagination ── */
  .rt-cl__pagination {
    margin-top: 56px;
    padding-top: 28px;
    border-top: 1px solid var(--rt-ink);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .rt-cl__pag-link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 180ms;
  }
  .rt-cl__pag-link:hover { opacity: 1; }
  .rt-cl__pag-info {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.45;
  }

  /* ── Responsive ── */
  @media (max-width: 990px) {
    .rt-cl { padding: 48px 20px 60px; }
    .rt-cl__grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  }
  @media (max-width: 749px) {
    .rt-cl { padding: 40px 16px 48px; }
    .rt-cl__display { font-size: 40px; }
    .rt-cl__grid { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .rt-cl__hd { margin-bottom: 32px; }
    .rt-cl__count { display: none; }
    .rt-cl__name { font-size: 13px; }
    .rt-cl__info { margin-top: 12px; padding-top: 10px; }
  }
</style>

{%- paginate collections by 24 -%}

<section class="rt-cl">

  <div class="rt-cl__hd">
    <div>
      <span class="rt-cl__eyebrow">{{ section.settings.eyebrow | default: '— All Collections' }}</span>
      <h1 class="rt-cl__display">{{ section.settings.heading | default: 'The archive.' }}</h1>
    </div>
    <span class="rt-cl__total">{{ paginate.items }} {{ 'collections' | t: count: paginate.items }}</span>
  </div>

  <div class="rt-cl__grid">
    {%- for collection in sorted_collections -%}
      {%- assign idx = forloop.index | plus: paginate.current_offset -%}
      <a href="{{ collection.url }}" class="rt-cl__tile">

        <div class="rt-cl__media">
          {%- if collection.featured_image -%}
            <img
              src="{{ collection.featured_image | image_url: width: 800 }}"
              srcset="{{ collection.featured_image | image_url: width: 400 }} 400w,
                      {{ collection.featured_image | image_url: width: 800 }} 800w,
                      {{ collection.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 749px) 50vw, (max-width: 990px) 50vw, 33vw"
              alt="{{ collection.title | escape }}"
              class="rt-cl__img"
              loading="lazy"
              decoding="async"
              width="{{ collection.featured_image.width }}"
              height="{{ collection.featured_image.height }}">
          {%- else -%}
            <div class="rt-cl__placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="0"/>
                <path d="M3 9l4-4 4 4 4-4 4 4"/>
                <circle cx="8" cy="14" r="2"/>
              </svg>
            </div>
          {%- endif -%}
          <span class="rt-cl__badge">{{ idx | prepend: '0' | slice: -2, 2 }} / {{ paginate.items | prepend: '0' | slice: -2, 2 }}</span>
        </div>

        <div class="rt-cl__info">
          <h2 class="rt-cl__name">{{ collection.title | escape }}</h2>
          <div class="rt-cl__meta">
            {%- if collection.all_products_count > 0 -%}
              <span class="rt-cl__count">{{ collection.all_products_count }} pieces</span>
            {%- endif -%}
            <span class="rt-cl__arrow">→</span>
          </div>
        </div>

      </a>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div class="rt-cl__pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="rt-cl__pag-link">← Previous</a>
      {%- else -%}
        <span></span>
      {%- endif -%}
      <span class="rt-cl__pag-info">{{ paginate.current_page }} / {{ paginate.pages }}</span>
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="rt-cl__pag-link">Next →</a>
      {%- else -%}
        <span></span>
      {%- endif -%}
    </div>
  {%- endif -%}

</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "RT Collections List",
  "class": "rt-cl-section",
  "presets": [{ "name": "RT Collections List" }],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "— All Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Display heading",
      "default": "The archive."
    },
    {
      "type": "select",
      "id": "sort",
      "label": "Sort by",
      "default": "alphabetical",
      "options": [
        { "value": "alphabetical",          "label": "A–Z" },
        { "value": "alphabetical_reversed", "label": "Z–A" },
        { "value": "date_reversed",         "label": "Newest first" },
        { "value": "date",                  "label": "Oldest first" },
        { "value": "products_high",         "label": "Most products" },
        { "value": "products_low",          "label": "Fewest products" }
      ]
    }
  ]
}
{% endschema %}
