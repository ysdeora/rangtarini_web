<style>
  .rt-trust {
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .rt-trust__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 11px;
    padding: 18px 16px;
    border-right: 1px solid rgba(10,10,10,0.12);
    text-align: left;
  }
  .rt-trust__item:last-child { border-right: none; }
  .rt-trust__icon {
    flex: none;
    width: 22px;
    height: 22px;
    color: var(--rt-gold);
  }
  .rt-trust__icon svg { width: 100%; height: 100%; display: block; }
  .rt-trust__text {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    line-height: 1.3;
  }

  @media (min-width: 750px) and (max-width: 1024px) {
    .rt-trust__text { font-size: 10px; letter-spacing: 0.1em; }
    .rt-trust__item { gap: 8px; padding: 16px 10px; }
  }

  @media (max-width: 749px) {
    .rt-trust { grid-template-columns: 1fr 1fr; }
    .rt-trust__item {
      padding: 14px 12px;
      border-bottom: 1px solid rgba(10,10,10,0.12);
      gap: 9px;
    }
    .rt-trust__item:nth-child(2) { border-right: none; }
    .rt-trust__item:nth-child(3),
    .rt-trust__item:nth-child(4) { border-bottom: none; }
    .rt-trust__text { font-size: 10px; letter-spacing: 0.1em; }
    .rt-trust__icon { width: 19px; height: 19px; }
  }
</style>

<section class="rt-trust">
  {%- for block in section.blocks -%}
    <div class="rt-trust__item" {{ block.shopify_attributes }}>
      <span class="rt-trust__icon" aria-hidden="true">
        {%- case block.settings.icon -%}
          {%- when 'shipping' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M1 4h13v11H1zM14 8h4l3 3v4h-7zM6 18.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zM17 18.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"/></svg>
          {%- when 'exchange' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 8h13l-3-3M21 16H8l3 3"/></svg>
          {%- when 'polish' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2l2.4 5 5.6.6-4 4 1 5.4L12 19l-5 3 1-5.4-4-4 5.6-.6z"/></svg>
          {%- else -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5z"/></svg>
        {%- endcase -%}
      </span>
      <span class="rt-trust__text">{{ block.settings.text | escape }}</span>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Trust Strip",
  "class": "rt-trust-section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            {"value": "shield", "label": "Shield (hallmark)"},
            {"value": "shipping", "label": "Shipping"},
            {"value": "exchange", "label": "Exchange"},
            {"value": "polish", "label": "Polish / shine"}
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "BIS Hallmarked · 925 Silver"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        {"type": "item", "settings": {"icon": "shield", "text": "BIS Hallmarked · 925 Silver"}},
        {"type": "item", "settings": {"icon": "shipping", "text": "Free Shipping · Pan-India"}},
        {"type": "item", "settings": {"icon": "exchange", "text": "7-Day Easy Exchange"}},
        {"type": "item", "settings": {"icon": "polish", "text": "Lifetime Polish & Resizing"}}
      ]
    }
  ]
}
{% endschema %}
