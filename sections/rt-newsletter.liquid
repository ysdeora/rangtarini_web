<style>
  .rt-nl {
    background: var(--rt-ink);
    color: var(--rt-paper);
    border-bottom: 1px solid var(--rt-line-paper);
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: clamp(24px, 4vw, 56px);
    padding: clamp(30px, 4vw, 46px) var(--rt-pad);
  }
  .rt-nl__lead { min-width: 0; }
  .rt-nl__eyebrow {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-gold);
    margin: 0 0 8px;
  }
  .rt-nl__title {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(22px, 2.6vw, 36px);
    font-weight: 900;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    line-height: 0.98;
    color: var(--rt-paper);
    margin: 0;
  }
  .rt-nl__deva {
    font-family: var(--rt-font-deva);
    font-size: 0.62em;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--rt-gold);
    margin-left: 12px;
    white-space: nowrap;
  }
  .rt-nl__body {
    font-family: var(--rt-font-grotesk);
    font-size: 12.5px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--rt-paper);
    opacity: 0.6;
    margin: 10px 0 0;
    max-width: 460px;
  }
  .rt-nl__right { justify-self: end; min-width: min(420px, 100%); }
  .rt-nl__form {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--rt-line-paper);
  }
  .rt-nl__input {
    flex: 1;
    border: 0;
    padding: 14px 16px;
    background: transparent;
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--rt-paper);
    outline: none;
    min-width: 0;
  }
  .rt-nl__input::placeholder {
    color: rgba(239, 236, 228, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 10.5px;
  }
  .rt-nl__submit {
    border: 0;
    border-left: 1px solid var(--rt-line-paper);
    background: transparent;
    color: var(--rt-paper);
    cursor: pointer;
    padding: 0 22px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--rt-font-grotesk);
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    white-space: nowrap;
    transition: background 240ms var(--rt-ez), color 240ms var(--rt-ez);
  }
  .rt-nl__submit:hover { background: var(--rt-gold); color: var(--rt-ink); }
  .rt-nl__success {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-gold);
    margin-top: 12px;
    animation: rt-nl-success 600ms var(--rt-ez) both;
  }
  @keyframes rt-nl-success {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 749px) {
    .rt-nl { grid-template-columns: 1fr; gap: 20px; }
    .rt-nl__right { justify-self: stretch; min-width: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .rt-nl__success { animation: none; }
  }
</style>

<section class="rt-nl">
  <div class="rt-nl__lead">
    <p class="rt-nl__eyebrow">{{ section.settings.eyebrow | default: 'The Rangtarini Circle' }}</p>
    <h2 class="rt-nl__title">{{ section.settings.heading | default: 'Subscribe.' }}<span class="rt-nl__deva">रंगतारिणी</span></h2>
    {%- if section.settings.body != blank -%}
      <p class="rt-nl__body">{{ section.settings.body }}</p>
    {%- endif -%}
  </div>

  <div class="rt-nl__right">
    {%- form 'customer', id: 'rt-nl-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="rt-nl__form">
        <input
          type="email"
          name="contact[email]"
          id="rt-nl-email"
          class="rt-nl__input"
          placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}"
          required
          autocomplete="email">
        <button type="submit" class="rt-nl__submit">
          {{ section.settings.button_label | default: 'Subscribe' }}
          <span aria-hidden="true">→</span>
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <div class="rt-nl__success">Subscribed — welcome to the Circle.</div>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "class": "rt-nl-section",
  "presets": [{"name": "Newsletter"}],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Rangtarini Circle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "One thoughtful email a fortnight — drops, the journal from the karkhana, and members-only edits. ₹500 off your first order over ₹3,500."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ]
}
{% endschema %}
