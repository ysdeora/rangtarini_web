      "label": "Image (overrides collection image)"
    },
    {
      "type": "text",
      "id": "gold_image_alt",
      "label": "Image alt text"
    },
    {
      "type": "video",
      "id": "gold_video",
      "label": "Background video (optional, overrides image)"
    },
    {
      "type": "text",
      "id": "gold_kicker",
      "label": "Kicker",
      "default": "01 — In gold"
    },
    {
      "type": "text",
      "id": "gold_label",
      "label": "Label",
      "default": "Gold Plated"
    },
    {
      "type": "text",
      "id": "gold_tagline",
      "label": "Tagline",
      "default": "22k gold over 925 sterling silver — heirloom warmth, everyday wear."
    },
    {
      "type": "text",
      "id": "gold_cta_label",
      "label": "Button label",
      "default": "Shop Gold"
    },
    {
      "type": "header",
      "content": "Right panel — Silver 925"
    },
    {
      "type": "collection",
      "id": "silver_collection",
      "label": "Silver collection (sets link + fallback image)"
    },
    {
      "type": "image_picker",
      "id": "silver_image",
      "label": "Image (overrides collection image)"
    },
    {
      "type": "text",
      "id": "silver_image_alt",
      "label": "Image alt text"
    },
    {
      "type": "video",
      "id": "silver_video",
      "label": "Background video (optional, overrides image)"
    },
    {
      "type": "text",
      "id": "silver_kicker",
      "label": "Kicker",
      "default": "02 — In silver"
    },
    {
      "type": "text",
      "id": "silver_label",
      "label": "Label",
      "default": "Silver 925"
    },
    {
      "type": "text",
      "id": "silver_tagline",
      "label": "Tagline",
      "default": "Hallmarked 925 sterling — pure, hypoallergenic, made to last."
    },
    {
      "type": "text",
      "id": "silver_cta_label",
      "label": "Button label",
      "default": "Shop Silver"
    }
  ]
}
{% endschema %}
