{%- assign rt_words  = article.content | strip_html | split: ' ' | size -%}
{%- assign rt_read   = rt_words | divided_by: 200 | at_least: 1 -%}
{%- assign rt_dek    = article.excerpt | default: '' | strip_html -%}
{%- assign rt_tag    = article.tags.first | default: '' -%}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;1,400;1,500&display=swap" rel="stylesheet" media="print" onload="this.media='all'">

<style>
  /* ── Tokens ── */
  .rt-art {
    --ra-serif:    'Cormorant Garamond', Georgia, serif;
    --ra-mono:     ui-monospace, 'SF Mono', Menlo, monospace;
    --ra-measure:  68ch;
    --ra-size:     19px;
    --ra-soft:     #1f1c17;
    --ra-muted:    #4a463d;
    --ra-line:     rgba(10,10,10,0.14);
    background: var(--rt-paper);
  }

  /* ── Progress bar ── */
  .rt-art__prog {
    position: fixed; top: 0; left: 0; right: 0;
    height: 3px; z-index: 300; pointer-events: none;
  }
  .rt-art__prog-fill {
    height: 100%; width: 0%;
    background: var(--rt-gold, #b59159);
    transition: width 80ms linear;
  }

  /* ── Breadcrumb ── */
  .rt-art__bc {
    padding: 15px 22px 13px;
    border-bottom: 1px solid var(--ra-line);
    display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
    background: var(--rt-paper);
  }
  .rt-art__bc-link {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 500;
    color: var(--rt-ink); text-decoration: none; opacity: 0.6;
    transition: opacity 160ms;
  }
  .rt-art__bc-link:hover { opacity: 1; }
  .rt-art__bc-sep { opacity: 0.3; font-size: 12px; }
  .rt-art__bc-cur {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700;
    color: var(--rt-ink);
  }

  /* ── Masthead ── */
  .rt-art__header { border-bottom: 1px solid var(--rt-ink); background: var(--rt-paper); }
  .rt-art__masthead {
    max-width: 820px; margin: 0 auto;
    padding: 56px 22px 46px; text-align: center;
  }
  .rt-art__cat {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.32em; text-transform: uppercase; font-weight: 700;
    color: var(--rt-gold, #b59159); display: block; margin-bottom: 22px;
  }
  .rt-art__title {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(34px, 5.6vw, 60px);
    font-weight: 800; letter-spacing: -0.035em; line-height: 1.04;
    color: var(--rt-ink); margin: 0;
  }
  .rt-art__dek {
    font-family: var(--ra-serif);
    font-size: clamp(18px, 2.4vw, 23px);
    line-height: 1.5; font-style: italic;
    color: var(--rt-ink); opacity: 0.72;
    max-width: 54ch; margin: 24px auto 0;
  }
  .rt-art__meta {
    display: flex; gap: 14px; align-items: center;
    justify-content: center; margin-top: 30px; flex-wrap: wrap;
  }
  .rt-art__meta-it {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--rt-ink); opacity: 0.65;
  }
  .rt-art__meta-sep { opacity: 0.3; }

  /* ── Hero (below masthead) ── */
  .rt-art__hero {
    border-top: 1px solid var(--rt-ink);
    aspect-ratio: 16 / 7; overflow: hidden;
    background: rgba(10,10,10,0.06); position: relative;
  }
  .rt-art__hero-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  /* ── Reading grid ── */
  .rt-art__grid {
    display: grid;
    grid-template-columns: 220px minmax(0, var(--ra-measure)) 220px;
    justify-content: center; gap: 56px;
    max-width: 1280px; margin: 0 auto;
    padding: 56px 22px 8px;
  }
  .rt-art__col { min-width: 0; }

  /* ── TOC ── */
  .rt-art__toc { font-size: 13px; }
  .rt-art__toc-inner { position: sticky; top: 96px; }
  .rt-art__toc-hd {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--rt-ink); opacity: 0.55;
    display: block; margin-bottom: 14px; padding-left: 16px;
  }
  .rt-art__toc-list { list-style: none; margin: 0 0 24px; padding: 0; }
  .rt-art__toc-a {
    display: block; font-family: var(--rt-font-grotesk);
    font-size: 12.5px; line-height: 1.45; letter-spacing: 0.01em;
    color: var(--rt-ink); opacity: 0.55; text-decoration: none;
    padding: 7px 0 7px 16px;
    border-left: 1px solid var(--ra-line);
    transition: opacity 160ms, border-color 160ms;
  }
  .rt-art__toc-a:hover { opacity: 1; }
  .rt-art__toc-a.is-active {
    opacity: 1; border-left-color: var(--rt-ink); font-weight: 600;
  }
  .rt-art__toc-a--h3 { font-size: 11.5px; padding-left: 26px; }

  /* TOC share */
  .rt-art__toc-share { margin-top: 8px; }
  .rt-art__sbtns { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
  .rt-art__sbtn {
    border: 1px solid var(--ra-line); padding: 7px 10px;
    text-decoration: none; color: var(--rt-ink); opacity: 0.65;
    font-family: var(--rt-font-grotesk); font-size: 9px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600;
    background: transparent; cursor: pointer; transition: opacity 180ms, background 180ms;
  }
  .rt-art__sbtn:hover { opacity: 1; }
  .rt-art__sbtn.is-copied {
    background: var(--rt-ink); color: var(--rt-paper);
    border-color: var(--rt-ink); opacity: 1;
  }

  /* ── Prose ── */
  .rt-art__prose {
    font-family: var(--rt-font-grotesk);
    font-size: var(--ra-size); line-height: 1.78;
    color: var(--ra-soft);
    counter-reset: h2c;
  }
  .rt-art__prose > * { margin-top: 0; }
  .rt-art__prose > * + * { margin-top: 1.55em; }
  .rt-art__prose > *:first-child { margin-top: 0; }

  .rt-art__prose h2 {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(26px, 3.2vw, 33px);
    font-weight: 800; letter-spacing: -0.025em; line-height: 1.1;
    color: var(--rt-ink); margin-top: 2.4em;
    scroll-margin-top: 96px; counter-increment: h2c;
  }
  .rt-art__prose h2::before {
    content: "0" counter(h2c) " —";
    display: block; font-family: var(--ra-mono);
    font-size: 11px; font-weight: 400; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--rt-gold, #b59159);
    margin-bottom: 14px;
  }
  .rt-art__prose h3 {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(18px, 2.2vw, 21px);
    font-weight: 700; letter-spacing: -0.01em; line-height: 1.25;
    color: var(--rt-ink); margin-top: 2em;
    scroll-margin-top: 96px;
  }
  .rt-art__prose h4 {
    font-family: var(--rt-font-grotesk); font-size: 1.05rem;
    font-weight: 700; color: var(--rt-ink); margin-top: 1.8em;
  }
  .rt-art__prose p {
    font-size: var(--ra-size); line-height: 1.78;
    color: var(--ra-soft); margin: 0 0 1.55em;
  }
  .rt-art__prose a {
    color: inherit; text-decoration: underline;
    text-decoration-color: var(--rt-gold, #b59159);
    text-underline-offset: 3px; text-decoration-thickness: 1.5px;
    transition: color 160ms;
  }
  .rt-art__prose a:hover { color: #7a5e2c; }
  .rt-art__prose strong, .rt-art__prose b { font-weight: 600; color: var(--rt-ink); }
  .rt-art__prose em, .rt-art__prose i { font-style: italic; }

  .rt-art__prose ul, .rt-art__prose ol {
    padding-left: 0; list-style: none; margin: 0 0 1.55em;
  }
  .rt-art__prose li {
    position: relative; padding-left: 28px; margin-bottom: 0.7em;
    font-size: var(--ra-size); color: var(--ra-soft); line-height: 1.72;
  }
  .rt-art__prose ul li::before {
    content: ""; position: absolute; left: 4px; top: 0.62em;
    width: 7px; height: 7px; background: var(--rt-gold, #b59159);
  }
  .rt-art__prose ol { counter-reset: olc; }
  .rt-art__prose ol li { counter-increment: olc; }
  .rt-art__prose ol li::before {
    content: counter(olc, decimal-leading-zero);
    position: absolute; left: 0; top: 0.04em;
    font-family: var(--ra-mono); font-size: 0.72em;
    letter-spacing: 0.04em; color: #7a5e2c;
  }

  .rt-art__prose blockquote {
    font-family: var(--ra-serif);
    font-size: clamp(22px, 3.2vw, 30px);
    line-height: 1.35; font-weight: 500; font-style: italic;
    color: var(--rt-ink); padding: 6px 0 6px 28px;
    border-left: 2px solid var(--rt-gold, #b59159);
    margin: 2.4em 0;
  }
  .rt-art__prose blockquote p { margin: 0; font-size: inherit; line-height: inherit; color: inherit; }

  .rt-art__prose img { max-width: 100%; height: auto; display: block; margin: 2.4em auto; }
  .rt-art__prose figure { margin: 2.4em 0; }
  .rt-art__prose figcaption {
    font-family: var(--ra-mono); font-size: 10.5px;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--ra-muted); margin-top: 12px; line-height: 1.6;
  }
  .rt-art__prose hr { border: none; border-top: 1px solid var(--rt-ink); opacity: 0.18; margin: 3em 0; }
  .rt-art__prose code {
    font-family: var(--ra-mono); font-size: 0.875rem;
    background: rgba(10,10,10,0.07); padding: 2px 6px;
  }
  .rt-art__prose pre { background: rgba(10,10,10,0.07); padding: 20px 24px; overflow-x: auto; margin: 1.75em 0; }
  .rt-art__prose pre code { background: none; padding: 0; }

  .rt-art__prose table { width: 100%; border-collapse: collapse; margin: 2em 0; font-size: 0.9375rem; }
  .rt-art__prose th, .rt-art__prose td {
    text-align: left; padding: 16px 18px;
    border: 1px solid var(--ra-line); vertical-align: top;
    font-size: 14.5px; line-height: 1.5;
  }
  .rt-art__prose thead th {
    font-family: var(--ra-mono); font-size: 11px;
    letter-spacing: 0.16em; text-transform: uppercase; font-weight: 400;
    color: var(--rt-ink); border-bottom: 1px solid var(--rt-ink);
    background: rgba(10,10,10,0.03);
  }
  .rt-art__prose tbody th {
    font-family: var(--ra-mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase; font-weight: 400;
    color: var(--ra-muted); white-space: nowrap; width: 1%;
    background: rgba(0,0,0,0.015);
  }

  /* Callout — merchant wraps in <div class="callout"> in RTE */
  .rt-art__prose .callout {
    border-top: 1px solid var(--rt-ink); border-bottom: 1px solid var(--rt-ink);
    padding: 26px 0; margin: 2.4em 0;
  }
  .rt-art__prose .callout-label {
    font-family: var(--ra-mono); font-size: 11px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: #7a5e2c; margin-bottom: 16px; display: block;
  }

  /* ── Author bio ── */
  .rt-art__author {
    border-top: 1px solid var(--rt-ink);
    margin-top: 56px; padding-top: 32px;
    display: flex; gap: 20px; align-items: flex-start; flex-wrap: wrap;
  }
  .rt-art__author-ava {
    width: 60px; height: 60px; flex-shrink: 0;
    background: rgba(10,10,10,0.08);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--rt-font-grotesk); font-size: 13px;
    font-weight: 700; letter-spacing: 0.1em; color: var(--rt-ink); opacity: 0.7;
  }
  .rt-art__author-name {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.24em; text-transform: uppercase;
    font-weight: 700; color: var(--rt-ink); display: block;
  }
  .rt-art__author-bio {
    font-family: var(--rt-font-grotesk); font-size: 14px;
    line-height: 1.6; color: var(--ra-muted);
    margin: 8px 0 0; max-width: 56ch;
  }

  /* ── Share block (body) ── */
  .rt-art__share {
    border-top: 1px solid var(--rt-ink); padding: 28px 0;
    display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
    margin-top: 40px;
  }
  .rt-art__share-lbl {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.28em; text-transform: uppercase;
    font-weight: 600; color: var(--rt-ink); opacity: 0.4;
  }

  /* ── Footer back ── */
  .rt-art__back {
    padding: 28px 28px; border-top: 1px solid var(--rt-ink);
  }
  .rt-art__back a {
    font-family: var(--rt-font-grotesk); font-size: 11px;
    letter-spacing: 0.28em; text-transform: uppercase; font-weight: 600;
    color: var(--rt-ink); text-decoration: none; opacity: 0.45;
    transition: opacity 160ms; display: inline-flex; align-items: center; gap: 8px;
  }
  .rt-art__back a:hover { opacity: 1; }

  /* ── Related ── */
  .rt-art__related { border-top: 1px solid var(--rt-ink); padding: 48px 22px 64px; }
  .rt-art__related-hd {
    max-width: 1200px; margin: 0 auto 28px;
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
  }
  .rt-art__related-h {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 900; letter-spacing: -0.03em; text-transform: uppercase;
    line-height: 0.92; color: var(--rt-ink); margin: 0;
  }
  .rt-art__related-all {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.26em; text-transform: uppercase; font-weight: 700;
    color: var(--rt-ink); text-decoration: none;
    border-bottom: 1px solid var(--rt-ink); padding-bottom: 4px;
    transition: opacity 160ms;
  }
  .rt-art__related-all:hover { opacity: 0.6; }
  .rt-art__rel-grid {
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px;
  }
  .rt-art__rel-card {
    display: flex; flex-direction: column;
    text-decoration: none; color: var(--rt-ink);
  }
  .rt-art__rel-media {
    position: relative; overflow: hidden;
    aspect-ratio: 3 / 2; background: rgba(10,10,10,0.06);
  }
  .rt-art__rel-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 600ms cubic-bezier(0.2,0.7,0.2,1);
  }
  .rt-art__rel-card:hover .rt-art__rel-img { transform: scale(1.04); }
  .rt-art__rel-ph {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
  }
  .rt-art__rel-ph svg { opacity: 0.15; }
  .rt-art__rel-badge {
    position: absolute; top: 12px; left: 12px;
    font-family: var(--rt-font-grotesk); font-size: 9px;
    letter-spacing: 0.28em; text-transform: uppercase; font-weight: 700;
    background: var(--rt-paper); color: var(--rt-ink); padding: 4px 9px;
  }
  .rt-art__rel-title {
    font-family: var(--rt-font-grotesk); font-size: 20px;
    font-weight: 700; letter-spacing: -0.02em; line-height: 1.16;
    margin: 16px 0 0; color: var(--rt-ink);
  }
  .rt-art__rel-foot {
    margin-top: 14px; display: flex; justify-content: space-between;
    align-items: center; border-top: 1px solid var(--ra-line); padding-top: 14px;
  }
  .rt-art__rel-read {
    font-family: var(--rt-font-grotesk); font-size: 9px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--rt-ink); opacity: 0.6;
  }
  .rt-art__rel-arrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.24em; text-transform: uppercase; font-weight: 600;
  }
  .rt-art__rel-arrow span { transition: transform 220ms; }
  .rt-art__rel-card:hover .rt-art__rel-arrow span { transform: translateX(3px); }

  /* ── Comments ── */
  .rt-art__comments { padding: 48px 28px 72px; max-width: 720px; }
  .rt-art__comments-title {
    font-family: var(--rt-font-grotesk); font-size: clamp(24px, 3vw, 40px);
    font-weight: 900; letter-spacing: -0.025em; text-transform: uppercase;
    color: var(--rt-ink); margin: 0 0 32px;
  }
  .rt-art__comment { padding: 24px 0; border-top: 1px solid var(--rt-ink); }
  .rt-art__comment p {
    font-family: var(--rt-font-grotesk); font-size: 15px;
    line-height: 1.75; color: var(--rt-ink); opacity: 0.8; margin: 0 0 10px;
  }
  .rt-art__comment-author {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--rt-ink); opacity: 0.45;
  }
  .rt-art__form-title {
    font-family: var(--rt-font-grotesk); font-size: clamp(20px, 2.5vw, 32px);
    font-weight: 800; letter-spacing: -0.02em; text-transform: uppercase;
    color: var(--rt-ink); margin: 48px 0 28px;
  }
  .rt-art__field { margin-bottom: 16px; }
  .rt-art__field label {
    font-family: var(--rt-font-grotesk); font-size: 10px;
    letter-spacing: 0.24em; text-transform: uppercase; font-weight: 600;
    color: var(--rt-ink); opacity: 0.5; display: block; margin-bottom: 8px;
  }
  .rt-art__field input, .rt-art__field textarea {
    width: 100%; border: 1px solid var(--rt-ink); background: none;
    font-family: var(--rt-font-grotesk); font-size: 14px; color: var(--rt-ink);
    padding: 12px 16px; outline: none; -webkit-appearance: none;
  }
  .rt-art__field textarea { resize: vertical; min-height: 120px; }
  .rt-art__field input::placeholder, .rt-art__field textarea::placeholder { opacity: 0.35; }
  .rt-art__field-err { font-family: var(--rt-font-grotesk); font-size: 11px; color: #b91c1c; margin-top: 6px; }
  .rt-art__submit {
    background: var(--rt-ink); color: var(--rt-paper); border: none;
    padding: 16px 32px; font-family: var(--rt-font-grotesk); font-size: 11px;
    letter-spacing: 0.28em; text-transform: uppercase; font-weight: 700;
    cursor: pointer; transition: opacity 180ms; margin-top: 8px;
  }
  .rt-art__submit:hover { opacity: 0.75; }
  .rt-art__row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .rt-art__msg { font-family: var(--rt-font-grotesk); font-size: 13px; color: var(--rt-ink); opacity: 0.65; padding: 12px 0; letter-spacing: 0.04em; }
  .rt-art__msg--ok { color: #166534; opacity: 1; }
  .rt-art__msg--err { color: #b91c1c; opacity: 1; }

  /* ── Responsive ── */
  @media (max-width: 1080px) {
    .rt-art__grid { grid-template-columns: minmax(0, var(--ra-measure)); gap: 0; padding-top: 44px; }
    .rt-art__toc, .rt-art__spacer { display: none; }
  }
  @media (max-width: 990px) {
    .rt-art__rel-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .rt-art__row2 { grid-template-columns: 1fr; }
  }
  @media (max-width: 749px) {
    .rt-art__hero { aspect-ratio: 16 / 9; }
    .rt-art__masthead { padding: 36px 20px 32px; }
    .rt-art__title { font-size: clamp(28px, 8vw, 44px); }
    .rt-art__dek { font-size: 18px; }
    .rt-art__grid { padding: 36px 20px 8px; }
    .rt-art__prose { font-size: 17px; }
    .rt-art__prose p, .rt-art__prose li { font-size: 17px; }
    .rt-art__prose h2 { font-size: 24px; }
    .rt-art__related { padding: 40px 20px 56px; }
    .rt-art__rel-grid { grid-template-columns: 1fr; gap: 32px; }
    .rt-art__comments { padding: 36px 20px 56px; }
    .rt-art__row2 { grid-template-columns: 1fr; }
    .rt-art__back { padding: 24px 20px; }
  }
</style>

{%- comment -%} Progress bar {%- endcomment -%}
<div class="rt-art__prog" aria-hidden="true">
  <div class="rt-art__prog-fill" id="rt-art-prog-fill"></div>
</div>

<article class="rt-art" id="rt-article">

  {%- comment -%} ── 1. MASTHEAD (title block, always first) ── {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'title' -%}
      <header class="rt-art__header" {{ block.shopify_attributes }}>

        <div class="rt-art__bc">
          <a href="{{ routes.root_url }}" class="rt-art__bc-link">Rangtarini</a>
          <span class="rt-art__bc-sep">/</span>
          <a href="{{ blog.url }}" class="rt-art__bc-link">{{ blog.title | escape }}</a>
          {%- if rt_tag != '' -%}
            <span class="rt-art__bc-sep">/</span>
            <span class="rt-art__bc-cur">{{ rt_tag | escape }}</span>
          {%- endif -%}
        </div>

        <div class="rt-art__masthead">
          {%- if rt_tag != '' -%}
            <span class="rt-art__cat">{{ rt_tag | escape }}</span>
          {%- endif -%}
          <h1 class="rt-art__title">{{ article.title | escape }}</h1>
          {%- if rt_dek != '' -%}
            <p class="rt-art__dek">{{ rt_dek | truncate: 280 }}</p>
          {%- endif -%}
          <div class="rt-art__meta">
            {%- if block.settings.blog_show_author and article.author != blank -%}
              <span class="rt-art__meta-it">{{ article.author | escape }}</span>
              <span class="rt-art__meta-sep">·</span>
            {%- endif -%}
            {%- if block.settings.blog_show_date -%}
              <time class="rt-art__meta-it" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                {{- article.published_at | date: '%B %-d, %Y' -}}
              </time>
              <span class="rt-art__meta-sep">·</span>
            {%- endif -%}
            <span class="rt-art__meta-it">{{ rt_read }} min read</span>
          </div>
        </div>

      </header>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} ── 2. HERO IMAGE (always below masthead) ── {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'featured_image' and article.image -%}
      <div class="rt-art__hero" {{ block.shopify_attributes }}>
        <img
          srcset="{%- if article.image.width >= 750 -%}{{ article.image | image_url: width: 750 }} 750w,{%- endif -%}
                  {%- if article.image.width >= 1200 -%}{{ article.image | image_url: width: 1200 }} 1200w,{%- endif -%}
                  {%- if article.image.width >= 1800 -%}{{ article.image | image_url: width: 1800 }} 1800w,{%- endif -%}
                  {%- if article.image.width >= 2400 -%}{{ article.image | image_url: width: 2400 }} 2400w,{%- endif -%}
                  {{ article.image | image_url }} {{ article.image.width }}w"
          src="{{ article.image | image_url: width: 1600 }}"
          sizes="100vw"
          alt="{{ article.image.alt | escape }}"
          class="rt-art__hero-img"
          loading="eager"
          fetchpriority="high"
          width="{{ article.image.width }}"
          height="{{ article.image.height }}">
      </div>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} ── 3. READING GRID ── {%- endcomment -%}
  <div class="rt-art__grid">

    {%- comment -%} TOC — JS-populated {%- endcomment -%}
    <nav class="rt-art__toc" id="rt-art-toc" aria-label="On this page">
      <div class="rt-art__toc-inner">
        <span class="rt-art__toc-hd">On this page</span>
        <ul class="rt-art__toc-list" id="rt-art-toc-list"></ul>
        <div class="rt-art__toc-share">
          <span class="rt-art__toc-hd">{{ 'blogs.article.share' | t }}</span>
          <div class="rt-art__sbtns">
            {%- assign _url = request.origin | append: article.url | url_encode -%}
            {%- assign _ttl = article.title | escape | url_encode -%}
            <a href="https://wa.me/?text={{ _ttl }}%20{{ _url }}"
               class="rt-art__sbtn" target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp">WA</a>
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ _url }}"
               class="rt-art__sbtn" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">FB</a>
            <a href="https://x.com/intent/tweet?url={{ _url }}&text={{ _ttl }}"
               class="rt-art__sbtn" target="_blank" rel="noopener noreferrer" aria-label="Share on X">X</a>
            <button type="button" class="rt-art__sbtn" id="rt-art-copy" aria-label="Copy link">Link</button>
          </div>
        </div>
      </div>
    </nav>

    {%- comment -%} Main column {%- endcomment -%}
    <main class="rt-art__col" id="rt-art-col">

      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when '@app' -%}
            <div {{ block.shopify_attributes }}>{% render block %}</div>

          {%- when 'content' -%}
            <div class="rt-art__prose" id="rt-art-prose" {{ block.shopify_attributes }}>
              {{ article.content }}
            </div>

            {%- if article.author != blank and block.settings.show_author -%}
              <div class="rt-art__author">
                <div class="rt-art__author-ava" aria-hidden="true">
                  {{- article.author | split: ' ' | first | slice: 0, 1 | upcase -}}{{- article.author | split: ' ' | last | slice: 0, 1 | upcase -}}
                </div>
                <div style="flex:1;min-width:200px;">
                  <span class="rt-art__author-name">{{ article.author | escape }}</span>
                  {%- if block.settings.author_bio != blank -%}
                    <p class="rt-art__author-bio">{{ block.settings.author_bio | escape }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}

          {%- when 'share' -%}
            <div class="rt-art__share" {{ block.shopify_attributes }}>
              <span class="rt-art__share-lbl">{{ block.settings.share_label | default: 'Share' | escape }}</span>
              {%- assign share_url = request.origin | append: article.url -%}
              {%- render 'share-button', block: block, share_link: share_url -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}

    </main>

    <div class="rt-art__spacer" aria-hidden="true"></div>
  </div>

  {%- comment -%} ── Back link ── {%- endcomment -%}
  <div class="rt-art__back">
    <a href="{{ blog.url }}">← {{ blog.title | escape }}</a>
  </div>

  {%- comment -%} ── Related articles ── {%- endcomment -%}
  {%- assign _shown = 0 -%}
  {%- assign _has_rel = false -%}
  {%- for rel in blog.articles -%}
    {%- if rel.url != article.url and _shown < 3 -%}
      {%- assign _shown = _shown | plus: 1 -%}
      {%- assign _has_rel = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if _has_rel -%}
    <section class="rt-art__related">
      <div class="rt-art__related-hd">
        <h2 class="rt-art__related-h">Keep reading.</h2>
        <a href="{{ blog.url }}" class="rt-art__related-all">{{ 'blogs.article.back_to_blog' | t }} <span>→</span></a>
      </div>
      <div class="rt-art__rel-grid">
        {%- assign _s2 = 0 -%}
        {%- for rel in blog.articles -%}
          {%- if rel.url != article.url and _s2 < 3 -%}
            {%- assign _s2 = _s2 | plus: 1 -%}
            {%- assign _rw = rel.content | strip_html | split: ' ' | size -%}
            {%- assign _rr = _rw | divided_by: 200 | at_least: 1 -%}
            <a href="{{ rel.url }}" class="rt-art__rel-card">
              <div class="rt-art__rel-media">
                {%- if rel.image -%}
                  <img
                    src="{{ rel.image | image_url: width: 600 }}"
                    srcset="{{ rel.image | image_url: width: 400 }} 400w, {{ rel.image | image_url: width: 700 }} 700w"
                    sizes="(max-width: 749px) 100vw, 33vw"
                    alt="{{ rel.image.alt | escape }}"
                    class="rt-art__rel-img"
                    loading="lazy" decoding="async"
                    width="{{ rel.image.width }}"
                    height="{{ rel.image.height }}">
                {%- else -%}
                  <div class="rt-art__rel-ph">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18"/><path d="M3 9l4-4 4 4 4-4 4 4"/><circle cx="8" cy="14" r="2"/>
                    </svg>
                  </div>
                {%- endif -%}
                {%- if rel.tags.size > 0 -%}
                  <span class="rt-art__rel-badge">{{ rel.tags.first | escape }}</span>
                {%- endif -%}
              </div>
              <h3 class="rt-art__rel-title">{{ rel.title | escape }}</h3>
              <div class="rt-art__rel-foot">
                <span class="rt-art__rel-read">{{ _rr }} min</span>
                <span class="rt-art__rel-arrow">Read <span>→</span></span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ── Comments ── {%- endcomment -%}
  {%- if blog.comments_enabled? -%}
    <div class="rt-art__comments" id="comments">

      {%- if article.comments_count > 0 -%}
        <h2 class="rt-art__comments-title" id="Comments-{{ article.id }}" tabindex="-1">
          {{ article.comments_count }} {{ article.comments_count | pluralize: 'Comment', 'Comments' }}
        </h2>
        {%- paginate article.comments by 5 -%}
          {%- if comment.status == 'pending' and comment.content -%}
            <div class="rt-art__comment">
              <p>{{ comment.content }}</p>
              <span class="rt-art__comment-author">{{ comment.author }}</span>
            </div>
          {%- endif -%}
          {%- for comment in article.comments -%}
            <div class="rt-art__comment" id="{{ comment.id }}">
              <p>{{ comment.content }}</p>
              <span class="rt-art__comment-author">
                {{ comment.author }}
                <span style="opacity:0.4;margin-left:8px;">{{ comment.created_at | time_tag: format: 'date' }}</span>
              </span>
            </div>
          {%- endfor -%}
          {%- if paginate.pages > 1 -%}
            {%- render 'pagination', paginate: paginate, anchor: '#Comments-' | append: article.id -%}
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}

      {%- form 'new_comment', article -%}
        {%- liquid
          assign post_message = 'blogs.article.success'
          if blog.moderated? and comment.status == 'unapproved'
            assign post_message = 'blogs.article.success_moderated'
          endif
        -%}
        <h2 class="rt-art__form-title">{{ 'blogs.article.comment_form_title' | t }}</h2>
        {%- if form.posted_successfully? -%}
          <p class="rt-art__msg rt-art__msg--ok">{{ post_message | t }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="rt-art__msg rt-art__msg--err">{{ 'templates.contact.form.error_heading' | t }}</p>
        {%- endif -%}
        <div class="rt-art__row2">
          <div class="rt-art__field">
            <label for="CommentForm-author">{{ 'blogs.article.name' | t }} *</label>
            <input type="text" name="comment[author]" id="CommentForm-author"
              value="{{ form.author }}" autocomplete="name" required aria-required="true"
              {% if form.errors contains 'author' %}aria-invalid="true"{% endif %}
              placeholder="{{ 'blogs.article.name' | t }}">
            {%- if form.errors contains 'author' -%}
              <p class="rt-art__field-err">{{ form.errors.messages.author }}</p>
            {%- endif -%}
          </div>
          <div class="rt-art__field">
            <label for="CommentForm-email">{{ 'blogs.article.email' | t }} *</label>
            <input type="email" name="comment[email]" id="CommentForm-email"
              value="{{ form.email }}" autocomplete="email" required aria-required="true"
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
              placeholder="{{ 'blogs.article.email' | t }}">
            {%- if form.errors contains 'email' -%}
              <p class="rt-art__field-err">{{ form.errors.messages.email }}</p>
            {%- endif -%}
          </div>
        </div>
        <div class="rt-art__field">
          <label for="CommentForm-body">{{ 'blogs.article.message' | t }} *</label>
          <textarea name="comment[body]" id="CommentForm-body" rows="5"
            required aria-required="true"
            {% if form.errors contains 'body' %}aria-invalid="true"{% endif %}
            placeholder="{{ 'blogs.article.message' | t }}">{{ form.body }}</textarea>
          {%- if form.errors contains 'body' -%}
            <p class="rt-art__field-err">{{ form.errors.messages.body }}</p>
          {%- endif -%}
        </div>
        {%- if blog.moderated? -%}
          <p class="rt-art__msg">{{ 'blogs.article.moderated' | t }}</p>
        {%- endif -%}
        <button type="submit" class="rt-art__submit">{{ 'blogs.article.post' | t }} →</button>
      {%- endform -%}

    </div>
  {%- endif -%}

</article>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

<script>
(function () {
  'use strict';

  /* ── Progress bar ── */
  var fill = document.getElementById('rt-art-prog-fill');
  var col  = document.getElementById('rt-art-col');
  if (fill && col) {
    function tick() {
      var start   = col.offsetTop;
      var total   = col.offsetHeight - window.innerHeight;
      var scrolled = window.scrollY - start;
      var pct = total > 0 ? Math.min(1, Math.max(0, scrolled / total)) : 0;
      fill.style.width = (pct * 100) + '%';
    }
    var pending = false;
    window.addEventListener('scroll', function () {
      if (!pending) { pending = true; requestAnimationFrame(function () { tick(); pending = false; }); }
    }, { passive: true });
    window.addEventListener('resize', tick);
    tick();
  }

  /* ── TOC generation ── */
  var prose   = document.getElementById('rt-art-prose');
  var tocList = document.getElementById('rt-art-toc-list');
  if (prose && tocList) {
    var headings = prose.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      var tocNav = document.getElementById('rt-art-toc');
      if (tocNav) tocNav.style.display = 'none';
    } else {
      var items = [];
      headings.forEach(function (h, i) {
        if (!h.id) {
          h.id = 'rt-h' + i + '-' + h.textContent.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').slice(0, 40);
        }
        var li = document.createElement('li');
        var a  = document.createElement('a');
        a.href      = '#' + h.id;
        a.className = 'rt-art__toc-a' + (h.tagName === 'H3' ? ' rt-art__toc-a--h3' : '');
        a.textContent = h.textContent.trim();
        li.appendChild(a);
        tocList.appendChild(li);
        items.push({ el: h, a: a });
      });
      if (items.length) items[0].a.classList.add('is-active');
      window.addEventListener('scroll', function () {
        var cur = items[0];
        items.forEach(function (it) {
          if (it.el.getBoundingClientRect().top <= 140) cur = it;
        });
        items.forEach(function (it) { it.a.classList.toggle('is-active', it === cur); });
      }, { passive: true });
    }
  }

  /* ── Copy link ── */
  var copyBtn = document.getElementById('rt-art-copy');
  if (copyBtn) {
    copyBtn.addEventListener('click', function () {
      var url = window.location.href;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url).catch(function () {});
      } else {
        var ta = document.createElement('textarea');
        ta.value = url; ta.style.cssText = 'position:fixed;opacity:0';
        document.body.appendChild(ta); ta.select();
        try { document.execCommand('copy'); } catch (e) {}
        document.body.removeChild(ta);
      }
      copyBtn.classList.add('is-copied');
      copyBtn.textContent = 'Copied';
      setTimeout(function () { copyBtn.classList.remove('is-copied'); copyBtn.textContent = 'Link'; }, 1600);
    });
  }
}());
</script>

{% schema %}
{
  "name": "RT Article",
  "tag": "section",
  "class": "rt-art-section",
  "blocks": [
    { "type": "@app" },
    {
      "type": "featured_image",
      "name": "Featured image",
      "limit": 1,
      "settings": [
        { "type": "paragraph", "content": "Hero image displays full-width below the article title at 16:7 aspect ratio." }
      ]
    },
    {
      "type": "title",
      "name": "Title & meta",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "blog_show_date",   "label": "Show date",   "default": true  },
        { "type": "checkbox", "id": "blog_show_author", "label": "Show author", "default": false }
      ]
    },
    {
      "type": "content",
      "name": "Article body",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_author",
          "label": "Show author",
          "default": true
        },
        {
          "type": "textarea",
          "id": "author_bio",
          "label": "Author bio",
          "info": "Short description shown below the author name. Leave blank to show name only."
        }
      ]
    },
    {
      "type": "share",
      "name": "Share",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "share_label", "label": "Share label", "default": "Share" }
      ]
    }
  ]
}
{% endschema %}
