{% comment %}
  ╔══════════════════════════════════════════════════════════════╗
  ║  rangtarini-reviews.liquid                                   ║
  ║  Luxury reviews section — Judge.me compatible                ║
  ║  ─────────────────────────────────────────────────────────── ║
  ║  Install: sections/rangtarini-reviews.liquid                 ║
  ║                                                              ║
  ║  Setup:                                                      ║
  ║  1. Add Judge.me review widget app block in theme editor     ║
  ║  2. Judge.me Settings → Widgets → Hide if no reviews: ON     ║
  ║  3. Judge.me Settings → Rich Snippets: Enable                ║
  ╚══════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- assign rt_count = product.metafields.reviews.rating_count | plus: 0 -%}
{%- assign rt_avg   = product.metafields.reviews.rating.value.rating | round: 1 -%}

{%- comment -%} Don't render section at all if no reviews {%- endcomment -%}
{%- if rt_count == 0 and product.metafields.judgeme.badge == blank -%}
  {%- comment -%} Hidden — no social proof yet {%- endcomment -%}
{%- else -%}

<style>
/* ════════════════════════════════════════════════════════
   RANGTARINI — REVIEWS SECTION
   Editorial brutalist — PDP v3 token sync.
   ════════════════════════════════════════════════════════ */
:root {
  --rt-paper:        #efece4;
  --rt-paper-warm:   #e9e3d3;
  --rt-ink:          #0a0a0a;
  --rt-bone:         #cdc6b5;
  --rt-gold:         #b59159;
  --rt-font-grotesk: "Archivo", "Helvetica Neue", Arial, sans-serif;
  --rt-font-mono:    ui-monospace, "SF Mono", Menlo, monospace;
  --rt-font-serif:   "Cormorant Garamond", Georgia, serif;
}

.rt-rev {
  background: var(--rt-paper);
  border-top: 1px solid var(--rt-ink);
  padding: 80px 28px 96px;
}

/* ── Header ── */
.rt-rev__head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
  margin-bottom: 56px;
  padding-bottom: 32px;
  border-bottom: 1px solid var(--rt-ink);
}

.rt-rev__eyebrow {
  font-family: var(--rt-font-grotesk);
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.28em; text-transform: uppercase;
  color: var(--rt-ink); opacity: 0.55;
  display: block; margin-bottom: 12px;
}

.rt-rev__title {
  font-family: var(--rt-font-grotesk);
  font-size: clamp(36px, 5vw, 72px);
  font-weight: 900;
  line-height: 0.92;
  letter-spacing: -0.03em;
  text-transform: uppercase;
  color: var(--rt-ink);
  margin: 0;
}

.rt-rev__summary {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
}

.rt-rev__avg-score {
  font-family: var(--rt-font-serif);
  font-size: 3rem;
  font-weight: 300;
  color: var(--rt-ink);
  line-height: 1;
}

.rt-rev__avg-stars { display: flex; gap: 3px; }
.rt-rev__avg-stars svg { width: 14px; height: 14px; }

.rt-rev__avg-ct {
  font-family: var(--rt-font-mono);
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--rt-ink);
  opacity: 0.5;
}

/* ── Judge.me global overrides ── */
.rt-rev .jdgm-widget {
  font-family: var(--rt-font-grotesk) !important;
  background: transparent !important;
}

.rt-rev .jdgm-star,
.rt-rev [class*='jdgm-'] .jdgm-star,
.rt-rev .jdgm-rev__stars span,
.rt-rev .jdgm-summary__stars span { color: var(--rt-gold) !important; }

.rt-rev .jdgm-summary {
  background: transparent !important;
  border: none !important;
  padding: 0 0 32px !important;
  margin-bottom: 0 !important;
}

.rt-rev .jdgm-summary__avg-score {
  font-family: var(--rt-font-serif) !important;
  font-size: 3.5rem !important;
  font-weight: 300 !important;
  color: var(--rt-ink) !important;
  line-height: 1 !important;
}

.rt-rev .jdgm-summary__rating {
  flex-direction: column !important;
  align-items: flex-start !important;
  gap: 6px !important;
}

.rt-rev .jdgm-histogram__bar {
  background: var(--rt-bone) !important;
  border-radius: 0 !important;
  height: 2px !important;
}

.rt-rev .jdgm-histogram__bar-fill {
  background: var(--rt-gold) !important;
  border-radius: 0 !important;
}

.rt-rev .jdgm-histogram__item-label {
  font-family: var(--rt-font-mono) !important;
  font-size: 10px !important;
  color: var(--rt-ink) !important;
  opacity: 0.5 !important;
  letter-spacing: 0.05em !important;
}

.rt-rev .jdgm-histogram__item-count {
  font-family: var(--rt-font-mono) !important;
  font-size: 10px !important;
  color: var(--rt-ink) !important;
  opacity: 0.5 !important;
}

.rt-rev[data-count="1"] .jdgm-histogram,
.rt-rev[data-count="2"] .jdgm-histogram { display: none !important; }

.rt-rev .jdgm-rev {
  background: transparent !important;
  border: none !important;
  border-bottom: 1px solid var(--rt-bone) !important;
  border-radius: 0 !important;
  box-shadow: none !important;
  padding: 32px 0 !important;
  margin: 0 !important;
}

.rt-rev .jdgm-rev:last-child { border-bottom: none !important; }

.rt-rev .jdgm-rev__author {
  font-family: var(--rt-font-grotesk) !important;
  font-size: 12px !important;
  font-weight: 600 !important;
  letter-spacing: 0.08em !important;
  color: var(--rt-ink) !important;
  text-transform: none !important;
}

.rt-rev .jdgm-rev__buyer-badge {
  font-family: var(--rt-font-mono) !important;
  font-size: 9px !important;
  letter-spacing: 0.12em !important;
  text-transform: uppercase !important;
  color: var(--rt-gold) !important;
  background: transparent !important;
  border: 1px solid var(--rt-gold) !important;
  border-radius: 0 !important;
  padding: 2px 7px !important;
}

.rt-rev .jdgm-rev__timestamp {
  font-family: var(--rt-font-mono) !important;
  font-size: 10px !important;
  color: var(--rt-ink) !important;
  opacity: 0.5 !important;
  letter-spacing: 0.06em !important;
}

.rt-rev .jdgm-rev__body {
  font-family: var(--rt-font-serif) !important;
  font-size: 1.05rem !important;
  line-height: 1.8 !important;
  font-weight: 300 !important;
  color: var(--rt-ink) !important;
  font-style: italic !important;
  margin-top: 12px !important;
}

.rt-rev .jdgm-rev__title {
  font-family: var(--rt-font-grotesk) !important;
  font-size: 12px !important;
  font-weight: 600 !important;
  letter-spacing: 0.06em !important;
  color: var(--rt-ink) !important;
  margin-bottom: 4px !important;
}

.rt-rev .jdgm-rev__pics {
  display: flex !important;
  flex-wrap: wrap !important;
  gap: 8px !important;
  margin-top: 16px !important;
}

.rt-rev .jdgm-rev__pics img {
  width: 110px !important;
  height: 110px !important;
  object-fit: cover !important;
  border-radius: 0 !important;
  border: 1px solid var(--rt-bone) !important;
  cursor: pointer !important;
  transition: transform 0.3s !important;
}
.rt-rev .jdgm-rev__pics img:hover { transform: scale(1.03) !important; }

.rt-rev .jdgm-write-rev-link,
.rt-rev .jdgm-write-rev-link a {
  font-family: var(--rt-font-mono) !important;
  font-size: 10px !important;
  letter-spacing: 0.2em !important;
  text-transform: uppercase !important;
  color: var(--rt-ink) !important;
  text-decoration: underline !important;
  text-underline-offset: 4px !important;
  background: transparent !important;
  border: none !important;
  border-radius: 0 !important;
  padding: 0 !important;
}

.rt-rev .jdgm-paginate {
  display: flex !important;
  gap: 4px !important;
  margin-top: 32px !important;
}

.rt-rev .jdgm-paginate a,
.rt-rev .jdgm-paginate span {
  font-family: var(--rt-font-mono) !important;
  font-size: 10px !important;
  letter-spacing: 0.12em !important;
  text-transform: uppercase !important;
  border: 1px solid var(--rt-bone) !important;
  border-radius: 0 !important;
  color: var(--rt-ink) !important;
  padding: 8px 14px !important;
  text-decoration: none !important;
  transition: background 0.2s, border-color 0.2s !important;
  background: transparent !important;
}

.rt-rev .jdgm-paginate a:hover {
  background: var(--rt-ink) !important;
  color: var(--rt-paper) !important;
  border-color: var(--rt-ink) !important;
}

.rt-rev .jdgm-paginate .jdgm-paginate__current-page {
  background: var(--rt-gold) !important;
  border-color: var(--rt-gold) !important;
  color: var(--rt-paper) !important;
}

.rt-rev .jdgm-branding { opacity: 0.3 !important; }

@media (max-width: 749px) {
  .rt-rev { padding: 52px 20px 72px; }
  .rt-rev__head { flex-direction: column; align-items: flex-start; gap: 16px; margin-bottom: 36px; }
  .rt-rev__summary { align-items: flex-start; }
  .rt-rev .jdgm-rev__pics img { width: 88px !important; height: 88px !important; }
}
</style>

<section
  class="rt-rev"
  id="rt-reviews-section"
  style="scroll-margin-top:80px;"
  aria-label="Customer reviews"
  data-count="{{ rt_count }}"
>

  {%- if rt_count > 0 -%}
    <div class="rt-rev__head">
      <div>
        <span class="rt-rev__eyebrow">What our customers say</span>
        <h2 class="rt-rev__title">{{ section.settings.section_title }}</h2>
      </div>

      <div class="rt-rev__summary">
        <span class="rt-rev__avg-score">{{ rt_avg | default: '—' }}</span>
        <span class="rt-rev__avg-stars" aria-hidden="true">
          {%- assign rt_score_r = rt_avg | round -%}
          {%- for i in (1..5) -%}
            {%- if i <= rt_score_r -%}
              <svg viewBox="0 0 24 24" fill="#C9A84C">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/>
              </svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/>
              </svg>
            {%- endif -%}
          {%- endfor -%}
        </span>
        <span class="rt-rev__avg-ct">{{ rt_count }} {{ rt_count | pluralize: 'review', 'reviews' }}</span>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} App blocks — add Judge.me Review Widget here in theme editor {%- endcomment -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when '@app' -%}
        {%- render block -%}
    {%- endcase -%}
  {%- endfor -%}

  {%- comment -%} Fallback if no app block yet — direct Judge.me snippet call {%- endcomment -%}
  {%- if section.blocks.size == 0 -%}
    {%- if product.metafields.judgeme.badge != blank -%}
      <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}"></div>
    {%- endif -%}
  {%- endif -%}

</section>

{%- endif -%}{%- comment -%} /if rt_count == 0 {%- endcomment -%}

{% schema %}
{
  "name": "Rangtarini Reviews",
  "tag": "section",
  "class": "section",
  "blocks": [
    { "type": "@app" }
  ],
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section heading",
      "default": "Loved by Our Customers",
      "info": "Appears only when the product has at least 1 review"
    }
  ]
}
{% endschema %}
