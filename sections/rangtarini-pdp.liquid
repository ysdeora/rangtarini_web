            {% if current_variant.available %}{% if current_variant.inventory_management == blank %}In stock{% elsif current_variant.inventory_quantity <= 5 and current_variant.inventory_quantity > 0 %}Low stock · {{ current_variant.inventory_quantity }} left{% else %}In stock · ready to ship{% endif %}{% else %}Sold out{% endif %}
          </span>
          <span class="rt-ship-note">Free shipping · pan India</span>
        </div>

        <!-- WhatsApp CTA -->
        {%- if section.settings.whatsapp_number != blank -%}
          <a href="{{ wa_url }}" class="rt-wa-cta" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
              <path d="M16 0C7.163 0 0 7.163 0 16c0 2.82.736 5.466 2.024 7.762L.057 31.887l8.312-2.18A15.93 15.93 0 0016 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333A13.28 13.28 0 019.13 27.42l-.49-.294-5.09 1.337 1.36-4.965-.32-.51A13.28 13.28 0 012.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333z"/>
              <path d="M23.3 19.547c-.375-.188-2.219-1.094-2.563-1.219-.344-.125-.594-.188-.844.188-.25.375-.969 1.219-1.188 1.469-.219.25-.438.281-.813.094-.375-.188-1.583-.583-3.016-1.86-1.115-.993-1.867-2.219-2.086-2.594-.219-.375-.023-.578.164-.765.169-.168.375-.438.563-.657.188-.218.25-.374.375-.624.125-.25.063-.469-.031-.656-.094-.188-.844-2.032-1.157-2.782-.305-.732-.614-.631-.844-.643l-.718-.012a1.376 1.376 0 00-1 .469c-.344.375-1.313 1.281-1.313 3.125s1.344 3.625 1.531 3.875c.188.25 2.646 4.039 6.41 5.664.896.387 1.595.618 2.14.79.899.286 1.717.245 2.364.149.721-.108 2.219-.906 2.532-1.782.312-.875.312-1.625.219-1.781-.094-.156-.344-.25-.719-.438z"/>
            </svg>
            Enquire or Customise
          </a>
        {%- endif -%}

        <!-- Trust grid -->
        <div class="rt-trust-grid" role="list" aria-label="Product guarantees">
          <div class="rt-trust-cell" role="listitem">
            <span class="rt-trust-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2 4 6v6c0 5.25 3.5 9 8 10 4.5-1 8-4.75 8-10V6z"/>
                <polyline points="9,12 11,14 15,10"/>
              </svg>
            </span>
            <span class="rt-trust-k">1 Year</span>
            <span class="rt-trust-v">Warranty</span>
          </div>
          {%- if show_hallmark -%}
          <div class="rt-trust-cell" role="listitem">
            <span class="rt-trust-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round">
                <polygon points="30,6 50,17 50,43 30,54 10,43 10,17"/>
                <polygon points="30,14 44,21.5 44,38.5 30,46 16,38.5 16,21.5" stroke-width="1" stroke-dasharray="2 2"/>
                <text x="30" y="33" text-anchor="middle" font-size="11" font-weight="600" font-family="monospace" fill="currentColor" stroke="none" letter-spacing="0.5">925</text>
              </svg>
            </span>
            <span class="rt-trust-k">925</span>
            <span class="rt-trust-v">Hallmarked</span>
          </div>
          {%- elsif show_service -%}
          <div class="rt-trust-cell" role="listitem">
            <span class="rt-trust-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 20h9"/>
