    { "type": "header",   "content": "Karkhana section" },
    { "type": "text",     "id": "karkhana_eyebrow",    "label": "Eyebrow text",           "default": "Index 04 — How we make everything" },
    { "type": "text",     "id": "karkhana_headline_1", "label": "Headline line 1",         "default": "From the" },
    { "type": "text",     "id": "karkhana_headline_2", "label": "Headline line 2 (gold)",  "default": "karkhana." },
    { "type": "text",     "id": "karkhana_deva",       "label": "Devanagari text",         "default": "रंगतारिणी" },
    { "type": "textarea", "id": "karkhana_copy",       "label": "Body copy (leave blank for default)" },
    { "type": "header",   "content": "Karkhana stats" },
