{% comment %}
  rangtarini-pdp.liquid
  Brutalist editorial PDP — Rangtarini v3 (redesigned 2026-05)
  Matches homepage / collection page aesthetic: Archivo + Devanagari,
  paper/ink palette, hard 1px rules, no rounding.
{% endcomment %}

{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{% unless product.has_only_default_variant %}
  {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
{% endunless %}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>

{%- style -%}
/* ════════════════════════════════════════════════════════
   DESIGN TOKENS
   ════════════════════════════════════════════════════════ */
:root {
  --rt-paper:       #efece4;
  --rt-paper-warm:  #e9e3d3;
  --rt-ink:         #0a0a0a;
  --rt-bone:        #cdc6b5;
  --rt-gold:        #b59159;
  --rt-emerald:     #2f5a3f;
  --rt-ruby:        #8a2a2a;
  --rt-font-grotesk: "Archivo", "Helvetica Neue", Arial, sans-serif;
  --rt-font-deva:    "Noto Serif Devanagari", Georgia, serif;
  --rt-font-mono:    ui-monospace, "SF Mono", Menlo, monospace;
  --rt-font-serif:   "Cormorant Garamond", Georgia, serif;
}

/* Override page background */
.rt-pdp-page { background: var(--rt-paper); }

/* ── Breadcrumb ── */
.rt-bc {
  padding: 14px 28px;
  border-bottom: 1px solid var(--rt-ink);
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--rt-paper);
  flex-wrap: wrap;
  gap: 10px;
}
.rt-bc__path { display: flex; align-items: center; gap: 10px; }
.rt-bc a, .rt-bc span {
  font-family: var(--rt-font-mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--rt-ink);
  text-decoration: none;
  opacity: 0.55;
}
.rt-bc a:hover { opacity: 1; }
.rt-bc__current { opacity: 1 !important; }
.rt-bc__sep { font-size: 11px; opacity: 0.3; }

/* ── Hero PDP grid ── */
.rt-hero-pdp {
  display: grid;
  grid-template-columns: 1.05fr 0.95fr;
  gap: 56px;
  padding: 32px 28px 48px;
  border-bottom: 1px solid var(--rt-ink);
  background: var(--rt-paper);
  align-items: start;
}

/* ── Gallery ── */
.rt-gallery {
  display: grid;
  grid-template-columns: 76px 1fr;
  gap: 14px;
  align-items: start;
}
.rt-thumb-rail {
  display: flex;
  flex-direction: column;
  gap: 10px;
  position: sticky;
  top: 88px;
}
.rt-thumb-btn {
  width: 76px;
  aspect-ratio: 1 / 1.15;
  border: 1px solid rgba(10,10,10,0.18);
  background: var(--rt-paper-warm);
  padding: 0;
  overflow: hidden;
  position: relative;
  cursor: pointer;
  outline: none;
}
.rt-thumb-btn.is-active {
  border-color: var(--rt-ink);
  outline: 2px solid var(--rt-ink);
  outline-offset: -3px;
}
.rt-thumb-btn img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  opacity: 0.78;
}
.rt-thumb-btn.is-active img { opacity: 1; }
.rt-thumb-num {
  position: absolute;
  bottom: 4px; left: 4px;
  font-family: var(--rt-font-mono);
  font-size: 8px;
  letter-spacing: 0.1em;
  background: var(--rt-paper);
  color: var(--rt-ink);
  padding: 1px 4px;
}
.rt-thumb-btn.is-active .rt-thumb-num { background: var(--rt-ink); color: var(--rt-paper); }

/* ── Main image stage ── */
.rt-main-stage {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1 / 1.18;
  border: 1px solid var(--rt-ink);
  background:
    radial-gradient(110% 80% at 50% 30%, rgba(255,255,255,0.5) 0%, rgba(0,0,0,0) 55%),
    var(--rt-paper-warm);
  cursor: zoom-in;
}
.rt-main-stage img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  will-change: transform;
  transition: transform 300ms cubic-bezier(0.2,0.7,0.2,1);
}
.rt-main-stage.is-hovering img { transition: none; }
.rt-stage-badge {
  position: absolute;
  font-family: var(--rt-font-mono);
  font-size: 9px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  padding: 4px 8px;
  pointer-events: none;
  line-height: 1;
}
.rt-stage-sku  { top: 14px; left: 14px; background: var(--rt-paper); color: var(--rt-ink); }
.rt-stage-hint { top: 14px; right: 14px; background: var(--rt-paper); color: var(--rt-ink); border: 1px solid var(--rt-ink); transition: opacity 0.2s; }
.rt-stage-counter {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 10px 14px;
  display: flex; justify-content: space-between; align-items: center;
  background: linear-gradient(0deg, rgba(0,0,0,0.32), transparent);
  pointer-events: none;
}
.rt-stage-counter span {
  font-family: var(--rt-font-mono);
  font-size: 9px; letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.9);
}

/* ── Buy Box ── */
.rt-buybox { display: flex; flex-direction: column; gap: 0; }

.rt-eyebrow {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 18px; gap: 12px;
}
.rt-eyebrow-meta {
  font-family: var(--rt-font-mono);
  font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--rt-ink); opacity: 0.55; display: block;
}
.rt-eyebrow-vendor {
  font-family: var(--rt-font-grotesk);
  font-size: 11px; font-weight: 500; letter-spacing: 0.28em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.65; display: block;
  margin-top: 5px;
}
.rt-stars-link {
  display: inline-flex; align-items: center; gap: 5px;
  text-decoration: none; white-space: nowrap; cursor: pointer;
}
.rt-stars-wrap { position: relative; display: inline-block; font-size: 17px; line-height: 1; letter-spacing: 3px; }
.rt-stars-bg { color: rgba(10,10,10,0.15); display: block; }
.rt-stars-fg {
  position: absolute; inset: 0;
  color: var(--rt-gold);
  white-space: nowrap;
}
.rt-stars-count {
  font-family: var(--rt-font-mono); font-size: 11px; letter-spacing: 0.12em;
  color: var(--rt-ink); opacity: 0.55;
}

/* Title */
.rt-title-block { margin-bottom: 18px; }
.rt-title {
  font-family: var(--rt-font-grotesk);
  font-size: clamp(48px, 6vw, 88px);
  font-weight: 900; line-height: 0.92;
  letter-spacing: -0.04em; text-transform: uppercase;
  color: var(--rt-ink); margin: 0;
}
.rt-title-sub {
  display: flex; align-items: baseline; gap: 14px; margin-top: 12px;
}
.rt-deva {
  font-family: var(--rt-font-deva);
  font-size: 20px; font-weight: 500; line-height: 1.2;
  color: var(--rt-gold);
}
.rt-title-rule { width: 28px; height: 1px; background: var(--rt-ink); opacity: 0.4; flex-shrink: 0; }
.rt-tagline {
  font-family: var(--rt-font-grotesk);
  font-size: 13px; font-weight: 400; color: var(--rt-ink); opacity: 0.8; line-height: 1.4;
}

/* Price */
.rt-price-block {
  display: flex; align-items: baseline; justify-content: space-between;
  padding: 16px 0;
  border-top: 1px solid var(--rt-ink); border-bottom: 1px solid var(--rt-ink);
  margin-bottom: 18px; gap: 12px;
}
.rt-price-left { display: inline-flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
.rt-price-main {
  font-family: var(--rt-font-grotesk);
  font-size: 36px; font-weight: 700; letter-spacing: -0.01em; color: var(--rt-ink);
}
.rt-price-was {
  font-family: var(--rt-font-grotesk);
  font-size: 18px; font-weight: 400; opacity: 0.45;
  text-decoration: line-through; color: var(--rt-ink);
}
.rt-price-save {
  font-family: var(--rt-font-grotesk);
  font-size: 10px; font-weight: 700; letter-spacing: 0.28em; text-transform: uppercase;
  background: var(--rt-gold); color: var(--rt-ink); padding: 4px 8px;
}
.rt-price-tax {
  font-family: var(--rt-font-mono);
  font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--rt-ink); opacity: 0.6; white-space: nowrap;
}

/* Availability badge */
.rt-avail-badge {
  display: flex; align-items: center; gap: 12px;
  padding: 11px 14px; border: 1px solid var(--rt-ink); margin-bottom: 18px;
}
.rt-avail-dot {
  width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0;
  animation: rt-dot-pulse 2.4s ease-in-out infinite;
}
.rt-avail-dot--mto { background: var(--rt-gold); }
.rt-avail-dot--rts { background: var(--rt-emerald); }
@keyframes rt-dot-pulse { 0%,100%{opacity:1;} 50%{opacity:0.25;} }
.rt-avail-copy { display: flex; flex-direction: column; gap: 3px; }
.rt-avail-lbl {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 600;
  letter-spacing: 0.22em; text-transform: uppercase; color: var(--rt-ink);
}
.rt-avail-sub {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
}

/* Variant buttons */
.rt-variants { margin-bottom: 18px; }
.rt-var-header {
  display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px;
}
.rt-var-label {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 700;
  letter-spacing: 0.28em; text-transform: uppercase; color: var(--rt-ink);
}
.rt-var-btns { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 8px; }
.rt-var-btn {
  display: flex; align-items: center; gap: 10px; padding: 10px 12px;
  border: 1px solid var(--rt-ink); background: transparent; color: var(--rt-ink);
  cursor: pointer; text-align: left; transition: background 0.15s, color 0.15s;
}
.rt-var-btn.is-active { background: var(--rt-ink); color: var(--rt-paper); }
.rt-var-swatch {
  width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0;
  border: 1px solid rgba(0,0,0,0.15);
  box-shadow: inset 0 0 0 1.5px rgba(255,255,255,0.35);
}
.rt-var-btn.is-active .rt-var-swatch { border-color: rgba(255,255,255,0.4); }
.rt-var-name {
  font-family: var(--rt-font-grotesk); font-size: 12px; font-weight: 600;
  display: block; line-height: 1;
}
.rt-var-stock {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; display: block; margin-top: 2px; opacity: 0.6;
}
.rt-var-select-hidden { display: none; }

/* Spec grid — what's in the piece */
.rt-spec-grid-wrap {
  border: 1px solid var(--rt-ink); background: var(--rt-paper-warm); margin-bottom: 18px;
}
.rt-spec-grid-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 10px 14px; border-bottom: 1px solid var(--rt-ink);
}
.rt-spec-grid-head-l {
  font-family: var(--rt-font-grotesk); font-size: 10px; font-weight: 700;
  letter-spacing: 0.28em; text-transform: uppercase; color: var(--rt-ink);
}
.rt-spec-grid-head-r {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.5;
}
.rt-spec-grid { display: grid; grid-template-columns: 1fr 1fr; }
.rt-spec-cell {
  padding: 11px 14px; display: flex; flex-direction: column; gap: 4px;
}
.rt-spec-cell:nth-child(odd)  { border-right: 1px solid var(--rt-ink); }
.rt-spec-cell:nth-child(n+3)  { border-top: 1px solid var(--rt-ink); }
.rt-spec-k {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
}
.rt-spec-v { font-family: var(--rt-font-grotesk); font-size: 13px; font-weight: 500; color: var(--rt-ink); }

/* Qty + ATC */
.rt-atc-row {
  display: grid; grid-template-columns: auto 1fr; gap: 8px;
  align-items: stretch; margin-bottom: 10px; min-height: 58px;
}
.rt-qty { display: inline-flex; border: 1px solid var(--rt-ink); align-items: stretch; }
.rt-qty-btn {
  width: 52px; background: transparent; border: 0; font-size: 20px;
  cursor: pointer; color: var(--rt-ink); display: flex; align-items: center; justify-content: center;
}
.rt-qty-sep { width: 1px; background: var(--rt-ink); flex-shrink: 0; }
.rt-qty-num {
  min-width: 52px; padding: 0 8px; display: flex; align-items: center; justify-content: center;
  font-family: var(--rt-font-mono); font-size: 15px; font-weight: 700; color: var(--rt-ink);
}
.rt-atc-main {
  background: var(--rt-ink); color: var(--rt-paper); border: 1px solid var(--rt-ink);
  padding: 0 24px;
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 800;
  letter-spacing: 0.28em; text-transform: uppercase; cursor: pointer;
  display: inline-flex; align-items: center; justify-content: center; gap: 10px;
}
.rt-atc-main:disabled { background: var(--rt-bone); border-color: var(--rt-bone); color: var(--rt-ink); cursor: not-allowed; }

/* Stock + shipping row */
.rt-stock-row {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;
}
.rt-stock-dot {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--rt-font-grotesk); font-size: 12px; font-weight: 500; color: var(--rt-ink);
}
.rt-stock-dot::before {
  content: ''; width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.rt-stock-dot--in::before  { background: var(--rt-emerald); }
.rt-stock-dot--low::before { background: var(--rt-gold); }
.rt-stock-dot--out::before { background: var(--rt-ruby); }
.rt-ship-note {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
}

/* WhatsApp CTA */
.rt-wa-cta {
  display: flex; align-items: center; justify-content: center; gap: 9px;
  padding: 14px 20px; border: 1px solid var(--rt-ink); background: transparent;
  color: var(--rt-ink); text-decoration: none;
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 600;
  letter-spacing: 0.22em; text-transform: uppercase;
  transition: background 0.15s, color 0.15s; margin-bottom: 14px;
}
.rt-wa-cta:hover { background: var(--rt-ink); color: var(--rt-paper); }

/* Trust grid — auto-fit handles 3 or 4 cells */
.rt-trust-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(72px, 1fr));
  border: 1px solid var(--rt-ink);
}
.rt-trust-cell {
  padding: 14px 8px; display: flex; flex-direction: column; align-items: center; gap: 5px;
  border-right: 1px solid var(--rt-ink); text-align: center;
}
.rt-trust-cell:last-child { border-right: none; }
.rt-trust-icon { color: var(--rt-ink); opacity: 0.7; display: flex; flex-shrink: 0; }
.rt-trust-k { font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 700; color: var(--rt-ink); line-height: 1.25; }
.rt-trust-v { font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--rt-ink); opacity: 0.55; }

/* ══════════════════════════════════════════
   SPEC TABS (Index 02)
   ══════════════════════════════════════════ */
#rt-spec-section {
  border-bottom: 1px solid var(--rt-ink); background: var(--rt-paper);
}
.rt-spec-hd {
  padding: 20px 28px; border-bottom: 1px solid var(--rt-ink);
  display: flex; justify-content: space-between; align-items: baseline;
}
.rt-spec-hd-l {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 500;
  letter-spacing: 0.28em; text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
}
.rt-spec-hd-r {
  font-family: var(--rt-font-mono); font-size: 10px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
}
.rt-spec-body { display: grid; grid-template-columns: 280px 1fr; }
.rt-tab-sidebar {
  border-right: 1px solid var(--rt-ink); display: flex; flex-direction: column;
}
.rt-tab-btn {
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  padding: 20px 24px; background: transparent; color: var(--rt-ink);
  border: 0; border-bottom: 1px solid var(--rt-ink);
  text-align: left; cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.rt-tab-btn.is-active { background: var(--rt-ink); color: var(--rt-paper); }
.rt-tab-btn-inner { display: inline-flex; align-items: baseline; gap: 10px; }
.rt-tab-num {
  font-family: var(--rt-font-mono); font-size: 10px; letter-spacing: 0.1em;
  text-transform: uppercase; opacity: 0.55;
}
.rt-tab-name { font-family: var(--rt-font-grotesk); font-size: 14px; font-weight: 500; }
.rt-tab-btn.is-active .rt-tab-name { font-weight: 700; }
.rt-tab-arrow { font-size: 16px; opacity: 0; }
.rt-tab-btn.is-active .rt-tab-arrow { opacity: 1; }

.rt-tab-panels { flex: 1; }
.rt-tab-panel {
  padding: 36px; min-height: 420px; display: none;
}
.rt-tab-panel.is-active { display: block; }

/* Tab 0 — Description */
.rt-desc-panel { display: grid; grid-template-columns: 1.3fr 1fr; gap: 48px; align-items: start; }
.rt-desc-lead {
  font-family: var(--rt-font-grotesk); font-size: 22px; font-weight: 500;
  line-height: 1.45; letter-spacing: -0.005em; color: var(--rt-ink); max-width: 30ch; margin: 0 0 16px;
}
.rt-desc-body { font-size: 15px; line-height: 1.7; color: var(--rt-ink); opacity: 0.75; margin: 0 0 10px; }
.rt-worn-hd {
  font-family: var(--rt-font-grotesk); font-size: 10px; font-weight: 700;
  letter-spacing: 0.28em; text-transform: uppercase; color: var(--rt-ink); opacity: 0.65;
  margin-bottom: 12px; display: block;
}
.rt-tags-wrap { display: flex; flex-wrap: wrap; gap: 7px; }
.rt-tag {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 500;
  letter-spacing: 0.04em; color: var(--rt-ink); border: 1px solid var(--rt-ink);
  padding: 5px 9px; text-transform: capitalize;
}

/* Tab 1 — Specifications */
.rt-spec-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
.rt-spec-section-hd {
  font-family: var(--rt-font-grotesk); font-size: 10px; font-weight: 700;
  letter-spacing: 0.28em; text-transform: uppercase; color: var(--rt-ink); opacity: 0.65;
  margin-bottom: 14px; display: block;
}
.rt-spec-rows { list-style: none; margin: 0; padding: 0; }
.rt-spec-row {
  display: grid; grid-template-columns: 150px 1fr; gap: 20px;
  padding: 13px 0; border-bottom: 1px solid rgba(10,10,10,0.15); align-items: center;
}
.rt-spec-row:first-child { border-top: 1px solid rgba(10,10,10,0.15); }
.rt-spec-row-k {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
}
.rt-spec-row-v { font-family: var(--rt-font-grotesk); font-size: 14px; font-weight: 500; color: var(--rt-ink); }
.rt-receive-row {
  display: flex; justify-content: space-between; gap: 12px;
  padding-bottom: 12px; border-bottom: 1px solid rgba(10,10,10,0.15); margin-bottom: 12px;
}
.rt-receive-row:last-child { border-bottom: 0; padding-bottom: 0; margin-bottom: 0; }
.rt-receive-k { font-family: var(--rt-font-grotesk); font-size: 13px; font-weight: 700; color: var(--rt-ink); }
.rt-receive-v { font-family: var(--rt-font-grotesk); font-size: 12px; opacity: 0.65; text-align: right; color: var(--rt-ink); }

/* Tabs 2 & 3 — accordion content */
.rt-acc-tab-section { margin-bottom: 28px; }
.rt-acc-tab-section:last-child { margin-bottom: 0; }
.rt-acc-tab-section-hd {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase; color: var(--rt-ink);
  border-bottom: 1px solid var(--rt-ink); padding-bottom: 10px; margin-bottom: 14px;
}
.rt-acc-tab-body {
  font-family: var(--rt-font-grotesk); font-size: 14px; line-height: 1.75;
  color: var(--rt-ink); opacity: 0.8;
}
.rt-acc-tab-body p { margin: 0 0 10px; }
.rt-acc-tab-body p:last-child { margin: 0; }
.rt-acc-tab-body ul { padding-left: 20px; margin: 8px 0; }
.rt-acc-tab-body li { margin-bottom: 5px; }
.rt-acc-tab-body strong { font-weight: 600; color: var(--rt-ink); opacity: 1; }
.rt-acc-tab-body a { color: var(--rt-ink); text-underline-offset: 3px; }

/* ══════════════════════════════════════════
   ALL ANGLES (Index 03)
   ══════════════════════════════════════════ */
#rt-all-angles {
  background: var(--rt-paper-warm); padding: 60px 28px 64px;
  border-bottom: 1px solid var(--rt-ink);
}
.rt-all-angles-hd {
  display: flex; justify-content: space-between; align-items: flex-end;
  margin-bottom: 32px; flex-wrap: wrap; gap: 16px;
}
.rt-index-eyebrow {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 500;
  letter-spacing: 0.28em; text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
  display: block; margin-bottom: 10px;
}
.rt-display-hd {
  font-family: var(--rt-font-grotesk); font-size: clamp(36px, 5vw, 72px); font-weight: 900;
  line-height: 0.92; letter-spacing: -0.03em; text-transform: uppercase; color: var(--rt-ink); margin: 0;
}
.rt-angles-desc {
  font-family: var(--rt-font-grotesk); font-size: 14px; color: var(--rt-ink);
  opacity: 0.75; max-width: 44ch; line-height: 1.55;
}
.rt-angles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
.rt-angle-fig { margin: 0; }
.rt-angle-img {
  position: relative; aspect-ratio: 1 / 1.18;
  border: 1px solid var(--rt-ink); overflow: hidden;
  background:
    radial-gradient(110% 80% at 50% 30%, rgba(255,255,255,0.5) 0%, rgba(0,0,0,0) 55%),
    var(--rt-paper-warm);
}
.rt-angle-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rt-angle-badge {
  position: absolute; left: 12px; top: 12px;
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; background: var(--rt-paper); color: var(--rt-ink); padding: 3px 7px;
}
.rt-angle-cap {
  margin-top: 12px; display: flex; justify-content: space-between;
  align-items: baseline; gap: 10px;
}
.rt-angle-cap-name { font-family: var(--rt-font-grotesk); font-size: 13px; font-weight: 600; color: var(--rt-ink); }
.rt-angle-cap-meta {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.55; text-align: right;
}

/* ══════════════════════════════════════════
   FROM THE KARKHANA (Index 04)
   ══════════════════════════════════════════ */
#rt-karkhana {
  background: var(--rt-ink); color: var(--rt-paper); padding: 80px 28px;
}
.rt-karkhana-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
.rt-karkhana-eyebrow {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 500;
  letter-spacing: 0.28em; text-transform: uppercase; color: var(--rt-paper); opacity: 0.55;
  display: block; margin-bottom: 16px;
}
.rt-karkhana-headline {
  font-family: var(--rt-font-grotesk); font-size: clamp(52px, 7vw, 100px); font-weight: 900;
  line-height: 0.92; letter-spacing: -0.03em; text-transform: uppercase;
  color: var(--rt-paper); margin: 0 0 14px;
}
.rt-karkhana-headline .gold { color: var(--rt-gold); }
.rt-karkhana-deva {
  font-family: var(--rt-font-deva); font-size: 30px; font-weight: 500;
  color: var(--rt-gold); display: inline-block; margin-bottom: 22px;
}
.rt-karkhana-copy {
  font-size: 16px; line-height: 1.7; color: var(--rt-paper); opacity: 0.85;
  max-width: 54ch; margin: 0 0 32px;
}
.rt-karkhana-stats { display: flex; gap: 32px; flex-wrap: wrap; margin-bottom: 32px; }
.rt-stat-n {
  font-family: var(--rt-font-grotesk); font-size: 30px; font-weight: 800;
  letter-spacing: -0.02em; color: var(--rt-paper); line-height: 1; display: block;
}
.rt-stat-l {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--rt-paper); opacity: 0.6;
  display: block; margin-top: 5px;
}
.rt-karkhana-cta {
  display: inline-flex; align-items: center; gap: 10px; color: var(--rt-paper);
  text-decoration: none; border-bottom: 1px solid var(--rt-gold); padding-bottom: 5px;
}
.rt-karkhana-cta span {
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 700;
  letter-spacing: 0.28em; text-transform: uppercase;
}
.rt-karkhana-img {
  border: 1px solid var(--rt-paper); position: relative;
  aspect-ratio: 4 / 4.6; overflow: hidden;
  background: #1c1c1c;
  display: flex; align-items: center; justify-content: center;
}
.rt-karkhana-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rt-karkhana-img-lbl {
  position: absolute; left: 14px; bottom: 14px;
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; background: var(--rt-ink); color: var(--rt-paper);
  border: 1px solid rgba(239,236,228,0.4); padding: 3px 8px;
}
.rt-karkhana-ph {
  font-family: var(--rt-font-mono); font-size: 10px; letter-spacing: 0.1em;
  text-transform: uppercase; color: rgba(239,236,228,0.35); text-align: center; padding: 20px;
}

/* ══════════════════════════════════════════
   STICKY ATC BAR
   ══════════════════════════════════════════ */
.rt-sticky-atc {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 60;
  background: var(--rt-paper); border-top: 1px solid var(--rt-ink);
  padding: 12px 28px;
  display: grid; grid-template-columns: auto 1fr auto auto;
  align-items: center; gap: 20px;
  transform: translateY(110%);
  transition: transform 320ms cubic-bezier(0.2,0.7,0.2,1);
}
.rt-sticky-atc.is-visible { transform: translateY(0); }
.rt-sticky-thumb {
  width: 48px; height: 56px; border: 1px solid var(--rt-ink);
  overflow: hidden; flex-shrink: 0;
  background:
    radial-gradient(110% 80% at 50% 30%, rgba(255,255,255,0.5) 0%, rgba(0,0,0,0) 55%),
    var(--rt-paper-warm);
}
.rt-sticky-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.rt-sticky-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.rt-sticky-name {
  font-family: var(--rt-font-grotesk); font-size: 13px; font-weight: 700;
  color: var(--rt-ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.rt-sticky-sub {
  font-family: var(--rt-font-mono); font-size: 9px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--rt-ink); opacity: 0.55;
}
.rt-sticky-price {
  font-family: var(--rt-font-grotesk); font-size: 20px; font-weight: 800;
  letter-spacing: -0.01em; color: var(--rt-ink); white-space: nowrap;
}
.rt-sticky-price s { font-size: 13px; font-weight: 400; opacity: 0.45; margin-left: 6px; text-decoration: line-through; }
.rt-sticky-add {
  background: var(--rt-ink); color: var(--rt-paper); border: 0;
  padding: 14px 28px;
  font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 800;
  letter-spacing: 0.28em; text-transform: uppercase; cursor: pointer;
  display: inline-flex; align-items: center; gap: 12px; white-space: nowrap;
}


/* ── Mobile accordion toggle (hidden on desktop) ── */
.rt-mob-acc-btn { display: none; }

/* ── Image lightbox ── */
.rt-lightbox {
  display: none; position: fixed; inset: 0; z-index: 200;
  background: rgba(10,10,10,0.97); align-items: center; justify-content: center;
}
.rt-lightbox.is-open { display: flex; }
.rt-lightbox-img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }
.rt-lightbox-close {
  position: absolute; top: 16px; right: 16px;
  width: 44px; height: 44px; border: 1px solid rgba(239,236,228,0.3);
  background: transparent; color: var(--rt-paper);
  font-size: 24px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
}

/* ══════════════════════════════════════════
   RESPONSIVE
   ══════════════════════════════════════════ */
@media (max-width: 989px) {
  .rt-hero-pdp { grid-template-columns: 1fr; gap: 28px; padding: 20px 16px 40px; }
  .rt-gallery { grid-template-columns: 1fr; }
  .rt-thumb-rail {
    position: static; flex-direction: row; overflow-x: auto; scroll-snap-type: x mandatory;
    gap: 8px; padding-bottom: 4px; order: 2; scrollbar-width: none;
  }
  .rt-thumb-rail::-webkit-scrollbar { display: none; }
  .rt-thumb-btn { width: 58px; scroll-snap-align: start; flex-shrink: 0; }
  .rt-main-stage { cursor: default; order: 1; }
  .rt-title { font-size: clamp(40px, 10vw, 72px); }
  .rt-spec-body { grid-template-columns: 1fr; }
  .rt-tab-sidebar { display: none; }
  .rt-tab-panel { display: block !important; padding: 0 16px !important; border-bottom: none !important; min-height: unset; }
  .rt-mob-acc-btn {
    display: flex; justify-content: space-between; align-items: center;
    width: 100%; padding: 18px 0;
    border: none; border-top: 1px solid var(--rt-ink);
    background: transparent; cursor: pointer; color: var(--rt-ink);
    font-family: var(--rt-font-grotesk); font-size: 13px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .rt-mob-acc-left { display: flex; align-items: baseline; gap: 10px; }
  .rt-mob-acc-num { font-family: var(--rt-font-mono); font-size: 10px; opacity: 0.55; }
  .rt-mob-acc-icon { font-size: 22px; font-weight: 300; line-height: 1; transition: transform 0.2s; }
  .rt-tab-panel.is-open .rt-mob-acc-icon { transform: rotate(45deg); }
  .rt-acc-content { display: none; padding: 0 0 24px; }
  .rt-tab-panel.is-open .rt-acc-content { display: block; }
  .rt-spec-hd { padding: 16px; }
  .rt-spec-grid { grid-template-columns: 1fr; }
  .rt-spec-cell { flex-direction: row; align-items: baseline; gap: 12px; padding: 8px 12px; }
  .rt-spec-cell:nth-child(n) { border-right: none; }
  .rt-spec-cell:nth-child(n+2) { border-top: 1px solid var(--rt-ink); }
  .rt-spec-k { min-width: 82px; flex-shrink: 0; }
  .rt-angles-grid { grid-template-columns: 1fr 1fr; }
  .rt-karkhana-grid { grid-template-columns: 1fr; }
  .rt-karkhana-img { display: none; }
  .rt-sticky-atc { grid-template-columns: auto 1fr auto; padding: 10px 16px; }
  .rt-sticky-price { display: none; }
  .rt-bc { padding: 10px 16px; }
  .rt-bc__path-right { display: none; }
  .rt-trust-cell { padding: 10px 6px; }
  .rt-desc-panel { grid-template-columns: 1fr; gap: 24px; }
  .rt-spec-two-col { grid-template-columns: 1fr; gap: 28px; }
  .rt-var-btns { grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); }
  .rt-price-block, .rt-avail-badge, .rt-variants, .rt-spec-grid-wrap { margin-bottom: 14px; }
  .rt-atc-row { margin-bottom: 10px; }
  .rt-stock-row, .rt-wa-cta { margin-bottom: 12px; }
  #rt-all-angles { padding: 40px 16px 44px; }
  #rt-karkhana { padding: 56px 16px; }
}
@media (max-width: 479px) {
  .rt-angles-grid { grid-template-columns: 1fr; }
  .rt-atc-row { grid-template-columns: auto 1fr; }
}
{%- endstyle -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'rt-form-' | append: section.id
  assign wa_text = 'Hi, I am interested in ' | append: product.title | url_encode
  assign wa_url = 'https://wa.me/' | append: section.settings.whatsapp_number | append: '?text=' | append: wa_text

  assign jewelry_material = product.metafields.custom.jewelry_material | downcase
  assign show_hallmark = false
  assign show_service = false
  if jewelry_material contains 'silver' or jewelry_material contains '925' or jewelry_material contains 'gold-plated silver'
    assign show_hallmark = true
  elsif jewelry_material contains 'alloy'
    assign show_service = true
  endif

  assign availability = product.metafields.custom.availability
  assign is_mto = false
  if availability == 'Made to Order'
    assign is_mto = true
  endif

  assign care_content = ''
  assign shipping_content = ''
  assign returns_content = ''
  for block in section.blocks
    if block.type == 'accordion'
      assign bh = block.settings.heading | downcase
      if bh contains 'care'
        if block.settings.page != blank
          assign care_content = block.settings.page.content
        else
          assign care_content = block.settings.content
        endif
      elsif bh contains 'ship' or bh contains 'deliver'
        if block.settings.page != blank
          assign shipping_content = block.settings.page.content
        else
          assign shipping_content = block.settings.content
        endif
      elsif bh contains 'return' or bh contains 'exchange'
        if block.settings.page != blank
          assign returns_content = block.settings.page.content
        else
          assign returns_content = block.settings.content
        endif
      endif
    endif
  endfor
-%}

<div class="rt-pdp-page" data-rt-section="{{ section.id }}">

  <!-- ── [A] Breadcrumb ── -->
  <nav class="rt-bc" aria-label="Breadcrumb">
    <div class="rt-bc__path">
      <a href="/">Rangtarini</a>
      <span class="rt-bc__sep">/</span>
      <a href="/collections/all">Shop</a>
      {%- if collection -%}
        <span class="rt-bc__sep">/</span>
        <a href="{{ collection.url }}">{{ collection.title }}</a>
      {%- endif -%}
      <span class="rt-bc__sep">/</span>
      <span class="rt-bc__current">{{ product.title }}</span>
    </div>
    <div class="rt-bc__path rt-bc__path-right">
      <a href="/collections/all" style="opacity:0.45;">← Back to shop</a>
    </div>
  </nav>

  <!-- ── [B] Hero PDP ── -->
  <section class="rt-hero-pdp" aria-label="{{ product.title | escape }} product details">

    <!-- [B1] Gallery -->
    <div class="rt-gallery">
      <!-- Thumbnail rail -->
      <div class="rt-thumb-rail" role="list" aria-label="Product images">
        {%- for media in product.media limit: 10 -%}
          <button
            class="rt-thumb-btn{% if forloop.first %} is-active{% endif %}"
            role="listitem"
            aria-label="View image {{ forloop.index }}"
            data-src="{{ media | image_url: width: 1600 }}"
            data-srcset="{{ media | image_url: width: 800 }} 800w, {{ media | image_url: width: 1200 }} 1200w, {{ media | image_url: width: 1600 }} 1600w"
            data-alt="{{ media.alt | default: product.title | escape }}"
            data-idx="{{ forloop.index0 }}"
            data-total="{{ product.media.size }}"
            onclick="rtThumbClick(this,'{{ section.id }}')"
          >
            <img
              src="{{ media | image_url: width: 200 }}"
              alt="{{ media.alt | default: product.title | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="76" height="88"
            >
            <span class="rt-thumb-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          </button>
        {%- endfor -%}
      </div>

      <!-- Main image stage -->
      <div class="rt-main-stage"
           id="rt-stage-{{ section.id }}"
           aria-label="Product image"
           onmousemove="rtZoomMove(event,'{{ section.id }}')"
           onmouseenter="rtZoomEnter('{{ section.id }}')"
           onmouseleave="rtZoomLeave('{{ section.id }}')">
        {%- assign fm = product.featured_media -%}
        {%- if fm -%}
          <img
            id="rt-hero-img-{{ section.id }}"
            src="{{ fm | image_url: width: 1200 }}"
            srcset="{{ fm | image_url: width: 800 }} 800w, {{ fm | image_url: width: 1200 }} 1200w, {{ fm | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 989px) 100vw, 55vw"
            alt="{{ fm.alt | default: product.title | escape }}"
            width="{{ fm.width }}" height="{{ fm.height }}"
            loading="eager" fetchpriority="high"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}

        <span class="rt-stage-badge rt-stage-sku">{{ product.variants.first.sku | default: product.type }}</span>
        <span class="rt-stage-badge rt-stage-hint" id="rt-zoom-hint-{{ section.id }}">Hover to zoom</span>
        <div class="rt-stage-counter">
          <span id="rt-counter-{{ section.id }}">01 / {{ product.media.size | prepend: '0' | slice: -2, 2 }}</span>
          <span>Studio · Daylight</span>
        </div>
      </div>
    </div>

    <!-- [B2] Buy Box -->
    <div class="rt-buybox">

      <!-- Eyebrow -->
      <div class="rt-eyebrow">
        <div>
          <span class="rt-eyebrow-meta">{{ product.type | default: 'Jewellery' }} · {{ current_variant.sku | default: product.handle | upcase | truncate: 14, '' }}</span>
          <span class="rt-eyebrow-vendor">By {{ product.vendor }}</span>
        </div>
        {%- assign rt_rating = product.metafields.reviews.rating.value.rating | plus: 0 -%}
        {%- assign rt_count = product.metafields.reviews.rating_count | plus: 0 -%}
        {%- if rt_count > 0 -%}
          {%- assign rt_empty_pct = rt_rating | times: 20 | round | minus: 100 | abs -%}
          <a href="#rt-reviews-section" class="rt-stars-link"
            aria-label="{{ rt_rating }} out of 5, {{ rt_count }} reviews">
            <span class="rt-stars-wrap" aria-hidden="true">
              <span class="rt-stars-bg">★★★★★</span>
              <span class="rt-stars-fg" style="clip-path:inset(0 {{ rt_empty_pct }}% 0 0)">★★★★★</span>
            </span>
            <span class="rt-stars-count">({{ rt_count }})</span>
          </a>
        {%- endif -%}
      </div>

      <!-- Title -->
      <div class="rt-title-block">
        <h1 class="rt-title">{{ product.title }}.</h1>
        <div class="rt-title-sub">
          {%- if product.metafields.custom.title_devanagari != blank -%}
            <span class="rt-deva">{{ product.metafields.custom.title_devanagari }}</span>
            <span class="rt-title-rule"></span>
          {%- endif -%}
          {%- if section.settings.tagline != blank -%}
            <span class="rt-tagline">{{ section.settings.tagline }}</span>
          {%- endif -%}
        </div>
      </div>

      <!-- Price -->
      <product-form data-section-id="{{ section.id }}" data-product-url="{{ product.url }}">
      <span class="loading__spinner hidden"></span>
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <span class="product-form__error-message"></span>
      </div>
      {%- form 'product', product, id: product_form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="rt-vid-{{ section.id }}">

        <div class="rt-price-block">
          <div class="rt-price-left" id="rt-price-{{ section.id }}">
            <span class="rt-price-main">{{ current_variant.price | money }}</span>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="rt-price-was">{{ current_variant.compare_at_price | money }}</span>
              {%- assign saved_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
              <span class="rt-price-save">−{{ saved_pct }}% off</span>
            {%- endif -%}
          </div>
          <span class="rt-price-tax">Tax incl.</span>
        </div>

        <!-- Availability badge -->
        {%- if availability != blank -%}
          <div class="rt-avail-badge">
            <span class="rt-avail-dot {% if is_mto %}rt-avail-dot--mto{% else %}rt-avail-dot--rts{% endif %}" aria-hidden="true"></span>
            <div class="rt-avail-copy">
              <span class="rt-avail-lbl">{% if is_mto %}Made to Order{% else %}Ready to Ship{% endif %}</span>
              <span class="rt-avail-sub">{% if is_mto %}Ships in 2–3 weeks{% else %}Ships in 3–5 business days{% endif %}</span>
            </div>
          </div>
        {%- endif -%}

        <!-- Variant selector -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="rt-variants">
              <div class="rt-var-header">
                <span class="rt-var-label">{{ option.name }} · <span id="rt-opt-selected-{{ section.id }}-{{ forloop.index0 }}">{{ option.selected_value }}</span></span>
              </div>
              <div class="rt-var-btns" role="group" aria-label="{{ option.name }} options">
                {%- for value in option.values -%}
                  {%- assign swatch_color = value | downcase | replace: ' ', '' -%}
                  <button
                    type="button"
                    class="rt-var-btn{% if option.selected_value == value %} is-active{% endif %}"
                    data-option-index="{{ forloop.parentloop.index0 }}"
                    data-value="{{ value | escape }}"
                    aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                    onclick="rtVarClick(this,'{{ section.id }}')"
                  >
                    <span class="rt-var-swatch" style="background: {{ swatch_color }};"></span>
                    <span>
                      <span class="rt-var-name">{{ value }}</span>
                      <span class="rt-var-stock">
                        {%- assign matching = product.variants | where: 'title', value | first -%}
                        {%- if matching.available -%}
                          {%- if matching.inventory_management == blank -%}In stock{%- elsif matching.inventory_quantity <= 5 and matching.inventory_quantity > 0 -%}Low · {{ matching.inventory_quantity }} left{%- else -%}In stock{%- endif -%}
                        {%- else -%}Sold out{%- endif -%}
                      </span>
                    </span>
                  </button>
                {%- endfor -%}
              </div>
              <select class="rt-var-select-hidden" name="options[{{ option.name | escape }}]" id="rt-sel-{{ section.id }}-{{ forloop.index0 }}" aria-label="{{ option.name }}">
                {%- for value in option.values -%}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                {%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <!-- What's in the piece — populated by JS -->
        <div class="rt-spec-grid-wrap" id="rt-witp-{{ section.id }}" style="display:none;">
          <div class="rt-spec-grid-head">
            <span class="rt-spec-grid-head-l">What's in the piece</span>
            <span class="rt-spec-grid-head-r" id="rt-witp-ct-{{ section.id }}">—</span>
          </div>
          <div class="rt-spec-grid" id="rt-witp-grid-{{ section.id }}"></div>
        </div>

        <!-- Qty + ATC -->
        <div class="rt-atc-row">
          <div class="rt-qty" role="group" aria-label="Quantity">
            <button type="button" class="rt-qty-btn" aria-label="Decrease" onclick="rtQtyChange(-1,'{{ section.id }}')">−</button>
            <span class="rt-qty-sep"></span>
