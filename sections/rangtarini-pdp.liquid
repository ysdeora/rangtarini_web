<script type="application/ld+json">{{ product | structured_data }}</script>

<script>
(function () {
  'use strict';

  var SEC = '{{ section.id }}';
  var VARIANTS = {{ product.variants | json }};
  var DESC_HTML = {{ product.description | json }};
  var FIRST_IMG = {{ product.featured_image | image_url: width: 1600 | json }};
  var qty = 1;

  /* ─── parseDescription ───────────────────────────────── */
  function parseDescription(html) {
    var doc = new DOMParser().parseFromString(html || '', 'text/html');
    var paragraphs = Array.from(doc.querySelectorAll('p'))
      .map(function(p){ return p.textContent.trim(); }).filter(Boolean);
    var highlights = Array.from(doc.querySelectorAll('ul li'))
      .map(function(li){
        var strong = li.querySelector('strong');
        if (!strong) return null;
        var k = strong.textContent.trim();
        var clone = li.cloneNode(true);
        var s = clone.querySelector('strong');
        if (s) s.remove();
        var v = clone.textContent.replace(/^\s*[—–\-:·]\s*/, '').trim();
        return (k && v) ? {k: k, v: v} : null;
      }).filter(Boolean);
    return { paragraphs: paragraphs, highlights: highlights };
  }

  /* ─── Populate spec grid (buy box) ─────────────────────── */
  function populateWITP(parsed) {
    var wrap = document.getElementById('rt-witp-' + SEC);
    var grid = document.getElementById('rt-witp-grid-' + SEC);
    var ct   = document.getElementById('rt-witp-ct-' + SEC);
    if (!wrap || !grid || !parsed.highlights.length) return;
    ct.textContent = '0' + parsed.highlights.length + ' · From product spec';
    var html = '';
    parsed.highlights.forEach(function(h, i) {
      html += '<div class="rt-spec-cell"><span class="rt-spec-k">' + h.k + '</span><span class="rt-spec-v">' + h.v + '</span></div>';
    });
    grid.innerHTML = html;
    wrap.style.display = '';
  }

  /* ─── Populate description tab ──────────────────────────── */
  function populateDescTab(parsed) {
    var lead = document.getElementById('rt-desc-lead-' + SEC);
    var body = document.getElementById('rt-desc-body-' + SEC);
    if (!lead || !body) return;
    if (parsed.paragraphs.length) lead.textContent = parsed.paragraphs[0];
    var html = '';
    parsed.paragraphs.slice(1).forEach(function(p) {
      html += '<p class="rt-desc-body">' + p + '</p>';
    });
    body.innerHTML = html;
  }

  /* ─── Populate spec rows (tab 1) ────────────────────────── */
  function populateSpecRows(parsed) {
    var list = document.getElementById('rt-spec-rows-' + SEC);
    if (!list || !parsed.highlights.length) return;
    var html = '';
    parsed.highlights.forEach(function(h) {
      html += '<li class="rt-spec-row"><span class="rt-spec-row-k">' + h.k + '</span><span class="rt-spec-row-v">' + h.v + '</span></li>';
    });
    list.insertAdjacentHTML('afterbegin', html);
  }

  /* ─── Thumbnail switcher ─────────────────────────────────── */
  window.rtThumbClick = function(btn, sid) {
    document.querySelectorAll('[data-rt-section="' + sid + '"] .rt-thumb-btn').forEach(function(b){ b.classList.remove('is-active'); });
    btn.classList.add('is-active');
    var img = document.getElementById('rt-hero-img-' + sid);
    if (img) {
      img.src = btn.dataset.src;
      img.srcset = btn.dataset.srcset || '';
      img.alt = btn.dataset.alt;
    }
    var counter = document.getElementById('rt-counter-' + sid);
    if (counter) {
      var idx = parseInt(btn.dataset.idx, 10) + 1;
      var total = btn.dataset.total;
      counter.textContent = ('0' + idx).slice(-2) + ' / ' + ('0' + total).slice(-2);
    }
  };

  /* Keep existing alias for backward compat */
  window.rtMedia = window.rtThumbClick;

  /* ─── Hover zoom ─────────────────────────────────────────── */
  window.rtZoomEnter = function(sid) {
    var stage = document.getElementById('rt-stage-' + sid);
    var hint  = stage && stage.querySelector('.rt-stage-hint');
    if (stage) stage.classList.add('is-hovering');
    if (hint)  hint.textContent = 'Move to inspect';
  };
  window.rtZoomLeave = function(sid) {
    var stage = document.getElementById('rt-stage-' + sid);
    var img   = document.getElementById('rt-hero-img-' + sid);
    var hint  = stage && stage.querySelector('.rt-stage-hint');
    if (stage) stage.classList.remove('is-hovering');
    if (img)   { img.style.transform = 'scale(1)'; img.style.transformOrigin = '50% 50%'; }
    if (hint)  hint.textContent = 'Hover to zoom';
  };
  window.rtZoomMove = function(e, sid) {
    var stage = document.getElementById('rt-stage-' + sid);
    var img   = document.getElementById('rt-hero-img-' + sid);
    if (!stage || !img) return;
    var rect = stage.getBoundingClientRect();
    var x = Math.max(0, Math.min(100, ((e.clientX - rect.left) / rect.width)  * 100));
    var y = Math.max(0, Math.min(100, ((e.clientY - rect.top)  / rect.height) * 100));
    img.style.transformOrigin = x + '% ' + y + '%';
    img.style.transform = 'scale(2.2)';
  };

  /* ─── Variant picker ─────────────────────────────────────── */
  window.rtVarClick = function(btn, sid) {
    var idx = btn.dataset.optionIndex;
    /* update visual */
    var group = btn.closest('.rt-var-btns');
    if (group) group.querySelectorAll('.rt-var-btn').forEach(function(b){ b.classList.remove('is-active'); b.setAttribute('aria-pressed','false'); });
    btn.classList.add('is-active');
    btn.setAttribute('aria-pressed','true');
    /* sync hidden select */
    var sel = document.getElementById('rt-sel-' + sid + '-' + idx);
    if (sel) { sel.value = btn.dataset.value; sel.dispatchEvent(new Event('change', {bubbles:true})); }
    /* update selected label */
    var lbl = document.getElementById('rt-opt-selected-' + sid + '-' + idx);
    if (lbl) lbl.textContent = btn.dataset.value;
    rtUpdateVariant(sid);
  };

  /* ─── Variant data sync ──────────────────────────────────── */
  window.rtUpdateVariant = function(sid) {
    var selects = document.querySelectorAll('[data-rt-section="' + sid + '"] .rt-var-select-hidden');
    var chosen = Array.from(selects).map(function(s){ return s.value; });
    var match = VARIANTS.find(function(v){
      return v.options.every(function(o, i){ return o === chosen[i]; });
    });
    if (!match) return;

    /* variant id */
    ['rt-vid-' + sid].forEach(function(id){
      var el = document.getElementById(id);
      if (el) el.value = match.id;
    });

    /* price */
    var priceEl = document.getElementById('rt-price-' + sid);
    var stickyPrice = document.getElementById('rt-sticky-price-' + sid);
    var fmtMoney = function(cents){
      return '₹' + Number(cents / 100).toLocaleString('en-IN', {minimumFractionDigits: 0, maximumFractionDigits: 0});
    };
    if (priceEl) {
      var html = '<span class="rt-price-main">' + fmtMoney(match.price) + '</span>';
      if (match.compare_at_price && match.compare_at_price > match.price) {
        var pct = Math.round((1 - match.price / match.compare_at_price) * 100);
        html += '<span class="rt-price-was">' + fmtMoney(match.compare_at_price) + '</span>';
        html += '<span class="rt-price-save">−' + pct + '% off</span>';
      }
      priceEl.innerHTML = html;
    }
    if (stickyPrice) {
      var sh = fmtMoney(match.price * qty);
      if (match.compare_at_price && match.compare_at_price > match.price) sh += ' <s>' + fmtMoney(match.compare_at_price) + '</s>';
      stickyPrice.innerHTML = sh;
    }

    /* ATC button */
    var atcBtn = document.getElementById('rt-atc-' + sid);
    var atcLbl = document.getElementById('rt-atc-label-' + sid);
    if (atcBtn) atcBtn.disabled = !match.available;
    if (atcLbl) atcLbl.innerHTML = match.available ? 'Add to bag <span style="font-size:14px;">→</span>' : 'Sold out';

    /* stock dot */
    var stockEl = document.getElementById('rt-stock-' + sid);
    if (stockEl) {
      var isUntracked = !match.inventory_management;
      stockEl.className = 'rt-stock-dot ' + (!match.available ? 'rt-stock-dot--out' : (isUntracked || match.inventory_quantity > 5 ? 'rt-stock-dot--in' : 'rt-stock-dot--low'));
      stockEl.textContent = !match.available ? 'Sold out' : (isUntracked ? 'In stock' : match.inventory_quantity <= 5 && match.inventory_quantity > 0 ? 'Low stock · ' + match.inventory_quantity + ' left' : 'In stock · ready to ship');
    }

    /* sticky sub */
    var stickySub = document.getElementById('rt-sticky-sub-' + sid);
    if (stickySub) stickySub.textContent = match.title !== 'Default Title' ? match.title : '';

    /* gallery — variant image */
    if (match.featured_image && match.featured_image.src) {
      var heroImg = document.getElementById('rt-hero-img-' + sid);
      if (heroImg) heroImg.src = match.featured_image.src;
    }

    /* URL */
    if (history.replaceState) history.replaceState(null, '', '?variant=' + match.id);
  };

  /* ─── Qty stepper ────────────────────────────────────────── */
  window.rtQtyChange = function(delta, sid) {
    qty = Math.max(1, qty + delta);
    var numEl = document.getElementById('rt-qty-' + sid);
    var inputEl = document.getElementById('rt-qty-input-' + sid);
    if (numEl) numEl.textContent = qty;
    if (inputEl) inputEl.value = qty;
    /* update ATC label price */
    var match = VARIANTS.find(function(v){ return String(v.id) === document.getElementById('rt-vid-' + sid).value; });
    var atcLbl = document.getElementById('rt-atc-label-' + sid);
    if (atcLbl && match && match.available) {
      var fmtMoney = function(cents){ return '₹' + Number(cents / 100).toLocaleString('en-IN', {minimumFractionDigits:0, maximumFractionDigits:0}); };
      atcLbl.innerHTML = 'Add to bag · ' + fmtMoney(match.price * qty) + ' <span style="font-size:14px;">→</span>';
    }
  };

  /* ─── Spec tabs ──────────────────────────────────────────── */
  window.rtTabClick = function(btn, sid) {
    var tabIdx = btn.dataset.tab;
    var section = document.querySelector('[data-rt-section="' + sid + '"]');
    if (!section) return;
    section.querySelectorAll('.rt-tab-btn').forEach(function(b){ b.classList.remove('is-active'); b.setAttribute('aria-selected','false'); });
    section.querySelectorAll('.rt-tab-panel').forEach(function(p){ p.classList.remove('is-active'); });
    btn.classList.add('is-active');
    btn.setAttribute('aria-selected','true');
    var panel = document.getElementById('rt-tab-panel-' + sid + '-' + tabIdx);
    if (panel) panel.classList.add('is-active');
  };

  /* ─── Sticky bar ─────────────────────────────────────────── */
  var stickyEl = document.getElementById('rt-sticky-' + SEC);
  if (stickyEl) {
    var ticking = false;
    window.addEventListener('scroll', function() {
      if (ticking) return; ticking = true;
      requestAnimationFrame(function() {
        stickyEl.classList.toggle('is-visible', window.scrollY > Math.min(700, window.innerHeight - 150));
        ticking = false;
      });
    }, { passive: true });
  }

  /* ─── Mobile accordion ───────────────────────────────────── */
  window.rtAccToggle = function(btn) {
    var panel = btn.closest('.rt-tab-panel');
    var willOpen = !panel.classList.contains('is-open');
    panel.classList.toggle('is-open', willOpen);
    btn.setAttribute('aria-expanded', String(willOpen));
  };

  /* ─── Image lightbox (mobile tap-to-expand) ──────────────── */
  var lb = document.getElementById('rt-lightbox-' + SEC);
  if (lb) {
    var lbImg = lb.querySelector('.rt-lightbox-img');
    var lbStage = document.getElementById('rt-stage-' + SEC);
    if (lbStage) {
      lbStage.addEventListener('click', function() {
        if (window.innerWidth >= 990) return;
        var hi = document.getElementById('rt-hero-img-' + SEC);
        if (!hi) return;
        lbImg.src = hi.currentSrc || hi.src;
        lbImg.alt = hi.alt;
        lb.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      });
    }
    function closeLb() { lb.classList.remove('is-open'); document.body.style.overflow = ''; }
    lb.querySelector('.rt-lightbox-close').addEventListener('click', closeLb);
    lb.addEventListener('click', function(e) { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLb(); });
  }

  /* ─── Toast ──────────────────────────────────────────────── */
  window.rtToastHide = function(sid) {
    var t = document.getElementById('rt-toast-' + sid);
    if (t) t.classList.remove('is-visible');
  };
  var mainForm = document.getElementById('rt-form-' + SEC);
  if (mainForm) {
    mainForm.addEventListener('submit', function() {
      var toast = document.getElementById('rt-toast-' + SEC);
      if (!toast) return;
      toast.classList.add('is-visible');
      setTimeout(function(){ toast.classList.remove('is-visible'); }, 2800);
    });
  }


  /* ─── Init on DOMContentLoaded ──────────────────────────── */
  document.addEventListener('DOMContentLoaded', function() {
    var parsed = parseDescription(DESC_HTML);
    populateWITP(parsed);
    populateDescTab(parsed);
    populateSpecRows(parsed);
  });

})();
</script>

