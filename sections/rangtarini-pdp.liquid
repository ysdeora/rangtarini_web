      "type": "accordion",
      "name": "Accordion tab",
      "settings": [
        { "type": "text",     "id": "heading", "label": "Tab heading", "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Tab content (rich text)" },
        { "type": "page",     "id": "page",    "label": "Or link to a page" }
      ]
    }
  ],
  "settings": [
    { "type": "header",   "content": "Product copy" },
    { "type": "text",     "id": "tagline",    "label": "Product tagline (shown below title)" },
    { "type": "header",   "content": "WhatsApp & Enquiry" },
