    { "type": "text",     "id": "karkhana_stat2_num",  "label": "Stat 2 — number",  "default": "6 gen" },
    { "type": "text",     "id": "karkhana_stat2_lbl",  "label": "Stat 2 — label",   "default": "Of craft" },
    { "type": "text",     "id": "karkhana_stat3_num",  "label": "Stat 3 — number",  "default": "22kt" },
    { "type": "text",     "id": "karkhana_stat3_lbl",  "label": "Stat 3 — label",   "default": "Gold plating" },
    { "type": "text",     "id": "karkhana_stat4_num",  "label": "Stat 4 — number",  "default": "BIS 925" },
    { "type": "text",     "id": "karkhana_stat4_lbl",  "label": "Stat 4 — label",   "default": "Hallmarked" },
    { "type": "header",   "content": "Karkhana image & CTA" },
    { "type": "image_picker", "id": "karkhana_image",  "label": "Photo (4:5 portrait recommended)" },
    { "type": "text",     "id": "karkhana_img_lbl",    "label": "Image caption",    "default": "Karkhana · Jaipur" },
    { "type": "url",      "id": "karkhana_url",        "label": "CTA link URL (optional)" },
    { "type": "text",     "id": "karkhana_cta_label",  "label": "CTA link text",    "default": "Visit the karkhana" },
    { "type": "header",   "content": "Section padding" },
    { "type": "range",    "id": "padding_top",    "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Top padding",    "default": 0 },
    { "type": "range",    "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Bottom padding", "default": 0 }
  ],
  "presets": [{ "name": "Rangtarini PDP" }]
}
