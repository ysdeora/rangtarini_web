<style>
  .rt-hd-wrap {
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* 3-col grid */
  .rt-hd {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    height: 60px;
    padding: 0 28px;
  }

  /* ── Nav ── */
  .rt-hd__nav {
    display: flex;
    gap: 32px;
    align-self: stretch;
    align-items: center;
  }
  /* Full-height items so dropdown top:100% = header bottom */
  .rt-hd__nav-item {
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
  }
  .rt-hd__nav-link {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 180ms;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .rt-hd__nav-link:hover,
  .rt-hd__nav-item:hover > .rt-hd__nav-link,
  .rt-hd__nav-item:focus-within > .rt-hd__nav-link,
  .rt-hd__nav-link[aria-current] { opacity: 1; }

  .rt-hd__chevron {
    display: inline-block;
    width: 0; height: 0;
    border-left: 3.5px solid transparent;
    border-right: 3.5px solid transparent;
    border-top: 4px solid currentColor;
    opacity: 0.7;
    margin-top: 1px;
    flex-shrink: 0;
    transition: transform 200ms;
  }
  .rt-hd__nav-item:hover .rt-hd__chevron,
  .rt-hd__nav-item:focus-within .rt-hd__chevron {
    transform: rotate(180deg);
  }

  /* ── 2-level dropdown ── */
  .rt-hd__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--rt-paper);
    border: 1px solid var(--rt-ink);
    border-top: none;
    padding: 20px 24px;
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 10px 36px;
    min-width: 240px;
    z-index: 200;
  }
  .rt-hd__nav-item:hover .rt-hd__dropdown,
  .rt-hd__nav-item:focus-within .rt-hd__dropdown {
    display: grid;
  }
  .rt-hd__drop-link {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    font-weight: 500;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 180ms;
    white-space: nowrap;
    display: block;
    padding: 3px 0;
  }
  .rt-hd__drop-link:hover { opacity: 1; }

  /* ── 3-level mega menu ── */
  .rt-hd__dropdown--mega {
    grid-template-columns: unset;
    padding: 0;
    min-width: unset;
    flex-direction: column; /* body row on top, strip on bottom */
  }
  .rt-hd__nav-item:hover .rt-hd__dropdown--mega,
  .rt-hd__nav-item:focus-within .rt-hd__dropdown--mega {
    display: flex;
  }
  /* Category columns row */
  .rt-mega__body {
    display: flex;
    align-items: stretch; /* all columns same height */
  }
  .rt-mega__col {
    padding: 20px 24px;
    border-right: 1px solid rgba(10,10,10,0.1);
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 148px;
  }
  .rt-mega__col:last-child { border-right: none; }
  .rt-mega__col-heading {
    font-family: var(--rt-font-grotesk);
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.45;
    display: block;
    padding-bottom: 8px;
    margin-bottom: 2px;
    border-bottom: 1px solid rgba(10,10,10,0.1);
    white-space: nowrap;
  }
  /* Leaf items strip at the bottom */
  .rt-mega__strip {
    border-top: 1px solid rgba(10,10,10,0.08);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 0;
  }
  .rt-mega__strip-link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
    text-decoration: none;
    transition: opacity 180ms;
    white-space: nowrap;
    padding-right: 20px;
    margin-right: 20px;
    border-right: 1px solid rgba(10,10,10,0.12);
  }
  .rt-mega__strip-link:last-child {
    border-right: none;
    padding-right: 0;
    margin-right: 0;
  }
  .rt-mega__strip-link:hover { opacity: 1; }

  /* ── Logo (larger) ── */
  .rt-hd__logo {
    font-family: var(--rt-font-grotesk);
    font-size: 20px;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--rt-ink);
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: center;
    line-height: 1;
  }

  /* ── Right icons ── */
  .rt-hd__actions {
    display: flex;
    gap: 18px;
    align-items: center;
    justify-content: flex-end;
  }
  .rt-hd__icon {
    color: var(--rt-ink);
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .rt-hd__icon svg {
    width: 19px; height: 19px;
    fill: none;
    stroke: var(--rt-ink);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
  }
  .rt-hd__cart-count {
    font-family: var(--rt-font-grotesk);
    font-size: 8px;
    font-weight: 700;
    background: var(--rt-ink);
    color: var(--rt-paper);
    width: 15px; height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -6px; right: -8px;
    line-height: 1;
  }

  /* ── Inline search panel ── */
  .rt-hd__search-panel predictive-search { position: relative; display: block; }
  .rt-hd__search-panel {
    display: none;
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
    padding: 0 28px;
    position: absolute;
    top: 100%;
    left: 0; right: 0;
    z-index: 200;
  }
  .rt-hd__search-panel.is-open { display: block; }
  .rt-hd__search-form {
    display: flex;
    align-items: center;
    height: 52px;
    gap: 12px;
  }
  .rt-hd__search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--rt-font-grotesk);
    font-size: 14px;
    color: var(--rt-ink);
    font-weight: 400;
    letter-spacing: 0.02em;
    -webkit-appearance: none;
  }
  .rt-hd__search-input::placeholder {
    color: var(--rt-ink);
    opacity: 0.38;
  }
  .rt-hd__search-sep {
    width: 1px; height: 20px;
    background: var(--rt-ink);
    opacity: 0.15;
    flex-shrink: 0;
  }
  .rt-hd__search-btn {
    background: none; border: none;
    cursor: pointer;
    color: var(--rt-ink);
    display: flex; align-items: center;
    padding: 0;
    opacity: 0.6;
    transition: opacity 180ms;
  }
  .rt-hd__search-btn:hover { opacity: 1; }
  .rt-hd__search-btn svg {
    width: 18px; height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Mobile hamburger ── */
  .rt-hd__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none; border: none;
    cursor: pointer; padding: 4px;
    align-self: center;
  }
  .rt-hd__menu-btn span {
    display: block;
    width: 22px; height: 1.5px;
    background: var(--rt-ink);
    transition: transform 240ms ease, opacity 240ms ease;
  }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(4.5px, 4.5px);
  }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(4.5px, -4.5px);
  }

  /* ── Mobile drawer ── */
  .rt-hd__mobile-nav {
    display: none; flex-direction: column;
    background: var(--rt-paper);
    border-top: 1px solid rgba(10,10,10,0.1);
  }
  .rt-hd__mobile-nav.is-open {
    display: flex;
    max-height: calc(100vh - 60px);
    overflow-y: auto;
  }

  .rt-hd__mobile-item { border-bottom: 1px solid rgba(10,10,10,0.07); }
  .rt-hd__mobile-item:last-child { border-bottom: none; }

  .rt-hd__mobile-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rt-hd__mobile-link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rt-ink);
    text-decoration: none;
    display: block;
    padding: 14px 20px;
    flex: 1;
  }
  .rt-hd__mobile-acc-btn {
    background: none; border: none;
    cursor: pointer; padding: 14px 20px 14px 0;
    font-size: 18px; line-height: 1;
    color: var(--rt-ink); opacity: 0.5;
    transition: transform 220ms, opacity 220ms;
  }
  .rt-hd__mobile-acc-btn[aria-expanded="true"] {
    transform: rotate(45deg);
    opacity: 1;
  }
  /* Accordion section */
  .rt-hd__mobile-section {
    overflow: hidden;
    max-height: 0;
    transition: max-height 300ms ease;
  }
  .rt-hd__mobile-section.is-open { max-height: 1400px; }
  .rt-hd__mobile-children {
    padding: 4px 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  /* Flat child link */
  .rt-hd__mobile-child {
    font-family: var(--rt-font-grotesk);
    font-size: 12px; font-weight: 500;
    color: var(--rt-ink); opacity: 0.65;
    text-decoration: none;
    display: block;
    padding: 8px 0;
    border-bottom: 1px solid rgba(10,10,10,0.05);
  }
  .rt-hd__mobile-child:last-child { border-bottom: none; }
  /* Sub-accordion row (child WITH grandchildren) */
  .rt-mobile-sub { border-top: 1px solid rgba(10,10,10,0.05); }
  .rt-mobile-sub:first-child { border-top: none; }
  .rt-mobile-sub__row {
    display: flex;
    align-items: center;
  }
  .rt-mobile-sub__link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rt-ink); opacity: 0.5;
    text-decoration: none;
    display: block;
    padding: 10px 0;
    flex: 1;
  }
  .rt-mobile-sub__btn {
    background: none; border: none;
    cursor: pointer; padding: 10px 0 10px 14px;
    font-size: 16px; line-height: 1;
    color: var(--rt-ink); opacity: 0.4;
    transition: transform 220ms, opacity 220ms;
  }
  .rt-mobile-sub__btn[aria-expanded="true"] {
    transform: rotate(45deg);
    opacity: 1;
  }
  .rt-mobile-sub__section {
    overflow: hidden;
    max-height: 0;
    transition: max-height 280ms ease;
    padding-left: 12px;
  }
  .rt-mobile-sub__section.is-open { max-height: 600px; }
  .rt-hd__mobile-child--gc {
    font-size: 11px;
    opacity: 0.55;
    padding: 6px 0;
  }

  @media (max-width: 749px) {
    .rt-hd { grid-template-columns: 1fr auto 1fr; padding: 0 16px; }
    .rt-hd__nav { display: none; }
    .rt-hd__logo { justify-content: center; }
    .rt-hd__menu-btn { display: flex; justify-self: start; }
    .rt-hd__actions { justify-self: end; }
    .rt-hd__search-panel { padding: 0 16px; }
  }
</style>

<div class="rt-hd-wrap">

  <div class="rt-hd">

    {%- comment %} Left — desktop nav / mobile hamburger {%- endcomment %}
    <nav class="rt-hd__nav" aria-label="Main navigation">
      {%- for link in linklists[section.settings.menu].links -%}

        {%- if link.links.size > 0 -%}
          {%- comment %} Detect whether any child has grandchildren (3-level) {%- endcomment %}
          {%- assign is_mega = false -%}
          {%- for child in link.links -%}
            {%- if child.links.size > 0 -%}{%- assign is_mega = true -%}{%- endif -%}
          {%- endfor -%}

          <div class="rt-hd__nav-item">
            <a href="{{ link.url }}"
               class="rt-hd__nav-link"
               aria-haspopup="true"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
              <span class="rt-hd__chevron" aria-hidden="true"></span>
            </a>

            {%- if is_mega -%}
              <div class="rt-hd__dropdown rt-hd__dropdown--mega" role="menu">
                {%- comment %} Top: category columns (children WITH grandchildren) {%- endcomment %}
                <div class="rt-mega__body">
                  {%- for child in link.links -%}
                    {%- if child.links.size > 0 -%}
                      <div class="rt-mega__col">
                        <a href="{{ child.url }}" class="rt-mega__col-heading">{{ child.title | escape }}</a>
                        {%- for gc in child.links -%}
                          <a href="{{ gc.url }}" class="rt-hd__drop-link" role="menuitem">{{ gc.title | escape }}</a>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- comment %} Bottom strip: leaf children (no grandchildren) {%- endcomment %}
                {%- assign has_flat_children = false -%}
                {%- for child in link.links -%}
                  {%- if child.links.size == 0 -%}{%- assign has_flat_children = true -%}{%- endif -%}
                {%- endfor -%}
                {%- if has_flat_children -%}
                  <div class="rt-mega__strip">
                    {%- for child in link.links -%}
                      {%- if child.links.size == 0 -%}
                        <a href="{{ child.url }}" class="rt-mega__strip-link" role="menuitem">{{ child.title | escape }}</a>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- else -%}
              <div class="rt-hd__dropdown" role="menu">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="rt-hd__drop-link" role="menuitem">{{ child.title | escape }}</a>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

        {%- else -%}
          <div class="rt-hd__nav-item">
            <a href="{{ link.url }}"
               class="rt-hd__nav-link"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
          </div>
        {%- endif -%}

      {%- endfor -%}
    </nav>

    <button class="rt-hd__menu-btn"
            aria-expanded="false"
            aria-controls="rt-mobile-nav"
            aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    {%- comment %} Centre — wordmark {%- endcomment %}
    <a href="{{ routes.root_url }}" class="rt-hd__logo">
      {{ section.settings.logo_text | default: 'RANGTARINI' }}
    </a>

    {%- comment %} Right — search + cart {%- endcomment %}
    <div class="rt-hd__actions">
      <button class="rt-hd__icon rt-hd__icon--search"
              aria-label="Search"
              aria-expanded="false"
              aria-controls="rt-search-panel">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <a href="{{ routes.cart_url }}" class="rt-hd__icon" aria-label="Cart, {{ cart.item_count }} items">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="rt-hd__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>

  {%- comment %} Inline search panel — slides in below header {%- endcomment %}
  <div class="rt-hd__search-panel" id="rt-search-panel" role="search" aria-label="Site search">
    <form action="{{ routes.search_url }}" method="get" class="rt-hd__search-form">
      <input type="hidden" name="type" value="product">
      <input type="search"
             name="q"
             id="rt-search-input"
             class="rt-hd__search-input"
             placeholder="Search jewellery, collections…"
             autocomplete="off"
             aria-label="Search products">
      <div class="rt-hd__search-sep" aria-hidden="true"></div>
      <button type="submit" class="rt-hd__search-btn" aria-label="Submit search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <button type="button" class="rt-hd__search-btn" id="rt-search-close" aria-label="Close search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
    </form>
  </div>

  {%- comment %} Mobile nav drawer {%- endcomment %}
  <nav class="rt-hd__mobile-nav" id="rt-mobile-nav" hidden>
    {%- for link in linklists[section.settings.menu].links -%}
      {%- assign is_mega_mob = false -%}
      {%- for child in link.links -%}
        {%- if child.links.size > 0 -%}{%- assign is_mega_mob = true -%}{%- endif -%}
      {%- endfor -%}

      <div class="rt-hd__mobile-item">
        {%- if link.links.size > 0 -%}
          <div class="rt-hd__mobile-row">
            <a href="{{ link.url }}" class="rt-hd__mobile-link"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
            <button class="rt-hd__mobile-acc-btn"
                    aria-expanded="{%- if is_mega_mob -%}true{%- else -%}false{%- endif -%}"
                    aria-label="Expand {{ link.title | escape }}">+</button>
          </div>
          <div class="rt-hd__mobile-section{%- if is_mega_mob %} is-open{%- endif -%}">
            <div class="rt-hd__mobile-children">
              {%- if is_mega_mob -%}
                {%- for child in link.links -%}
                  {%- if child.links.size > 0 -%}
                    <div class="rt-mobile-sub">
                      <div class="rt-mobile-sub__row">
                        <a href="{{ child.url }}" class="rt-mobile-sub__link">{{ child.title | escape }}</a>
                        <button class="rt-mobile-sub__btn"
                                aria-expanded="false"
                                aria-label="Expand {{ child.title | escape }}">+</button>
                      </div>
                      <div class="rt-mobile-sub__section">
                        {%- for gc in child.links -%}
                          <a href="{{ gc.url }}" class="rt-hd__mobile-child rt-hd__mobile-child--gc">{{ gc.title | escape }}</a>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- else -%}
                    <a href="{{ child.url }}" class="rt-hd__mobile-child">{{ child.title | escape }}</a>
                  {%- endif -%}
                {%- endfor -%}
              {%- else -%}
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="rt-hd__mobile-child">{{ child.title | escape }}</a>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="rt-hd__mobile-link"
             {% if link.active %}aria-current="page"{% endif %}>
            {{ link.title | escape }}
          </a>
        {%- endif -%}
      </div>

    {%- endfor -%}
  </nav>

</div>

<script>
(function () {

  /* ── Mobile hamburger ── */
  var menuBtn = document.querySelector('.rt-hd__menu-btn');
  var mobileNav = document.getElementById('rt-mobile-nav');
  if (menuBtn && mobileNav) {
    menuBtn.addEventListener('click', function () {
      var open = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!open));
      menuBtn.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
      mobileNav.hidden = open;
      mobileNav.classList.toggle('is-open', !open);
    });
  }

  /* ── Mobile accordion (top level) ── */
  document.querySelectorAll('.rt-hd__mobile-acc-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item    = btn.closest('.rt-hd__mobile-item');
      var section = item && item.querySelector('.rt-hd__mobile-section');
      var open    = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      if (section) section.classList.toggle('is-open', !open);
    });
  });

  /* ── Mobile sub-accordion (sub-collections with grandchildren) ── */
  document.querySelectorAll('.rt-mobile-sub__btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var sub     = btn.closest('.rt-mobile-sub');
      var section = sub && sub.querySelector('.rt-mobile-sub__section');
      var open    = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      if (section) section.classList.toggle('is-open', !open);
    });
  });

  /* ── Inline search ── */
  var searchBtn   = document.querySelector('.rt-hd__icon--search');
  var searchPanel = document.getElementById('rt-search-panel');
  var searchInput = document.getElementById('rt-search-input');
  var searchClose = document.getElementById('rt-search-close');

  if (searchBtn && searchPanel && searchInput) {
    function openSearch() {
      searchPanel.classList.add('is-open');
      searchBtn.setAttribute('aria-expanded', 'true');
      setTimeout(function () { searchInput.focus(); }, 30);
    }
    function closeSearch() {
      searchPanel.classList.remove('is-open');
      searchBtn.setAttribute('aria-expanded', 'false');
    }

    searchBtn.addEventListener('click', function () {
      searchPanel.classList.contains('is-open') ? closeSearch() : openSearch();
    });

    if (searchClose) {
      searchClose.addEventListener('click', closeSearch);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && searchPanel.classList.contains('is-open')) {
        closeSearch();
        searchBtn.focus();
      }
    });

    /* Close when clicking outside the search panel and button */
    document.addEventListener('click', function (e) {
      if (!searchPanel.contains(e.target) && !searchBtn.contains(e.target)) {
        closeSearch();
      }
    });
  }

}());
</script>

