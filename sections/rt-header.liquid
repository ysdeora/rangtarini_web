<style>
  .rt-hd-wrap {
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* 3-column grid — nav | LOGO | actions */
  .rt-hd {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    height: 60px;
    padding: 0 28px;
  }

  /* ── Left: nav ── */
  /* Nav stretches to full header height so dropdowns anchor to the header bottom */
  .rt-hd__nav {
    display: flex;
    gap: 32px;
    align-self: stretch;
    align-items: center;
  }
  .rt-hd__nav-item {
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
  }
  .rt-hd__nav-link {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 180ms;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .rt-hd__nav-link:hover,
  .rt-hd__nav-item:hover > .rt-hd__nav-link,
  .rt-hd__nav-item:focus-within > .rt-hd__nav-link,
  .rt-hd__nav-link[aria-current] { opacity: 1; }

  .rt-hd__chevron {
    display: inline-block;
    width: 0;
    height: 0;
    border-left: 3.5px solid transparent;
    border-right: 3.5px solid transparent;
    border-top: 4px solid currentColor;
    opacity: 0.7;
    transition: transform 200ms ease;
    margin-top: 1px;
  }
  .rt-hd__nav-item:hover .rt-hd__chevron,
  .rt-hd__nav-item:focus-within .rt-hd__chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown ── */
  .rt-hd__dropdown {
    position: absolute;
    top: 100%;        /* aligns to bottom of full-height nav item = header bottom */
    left: 0;
    background: var(--rt-paper);
    border: 1px solid var(--rt-ink);
    border-top: none;
    padding: 20px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 40px;
    min-width: 260px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-4px);
    transition: opacity 180ms ease, visibility 180ms ease, transform 180ms ease;
    z-index: 200;
  }
  .rt-hd__nav-item:hover .rt-hd__dropdown,
  .rt-hd__nav-item:focus-within .rt-hd__dropdown {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }
  .rt-hd__drop-link {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    font-weight: 500;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 180ms;
    white-space: nowrap;
    display: block;
    padding: 3px 0;
  }
  .rt-hd__drop-link:hover { opacity: 1; }

  /* ── Centre: wordmark ── */
  .rt-hd__logo {
    font-family: var(--rt-font-grotesk);
    font-size: 17px;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--rt-ink);
    text-decoration: none;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    align-self: center;
  }

  /* ── Right: icons ── */
  .rt-hd__actions {
    display: flex;
    gap: 18px;
    align-items: center;
    justify-content: flex-end;
  }
  .rt-hd__icon {
    color: var(--rt-ink);
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
  }
  .rt-hd__icon svg {
    width: 19px;
    height: 19px;
    fill: none;
    stroke: var(--rt-ink);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
  }
  .rt-hd__cart-count {
    font-family: var(--rt-font-grotesk);
    font-size: 8px;
    font-weight: 700;
    background: var(--rt-ink);
    color: var(--rt-paper);
    width: 15px;
    height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -6px;
    right: -8px;
    line-height: 1;
  }

  /* ── Mobile hamburger ── */
  .rt-hd__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    align-self: center;
  }
  .rt-hd__menu-btn span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--rt-ink);
    transition: transform 240ms ease, opacity 240ms ease;
  }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(4.5px, 4.5px);
  }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(4.5px, -4.5px);
  }

  /* ── Mobile drawer ── */
  .rt-hd__mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--rt-paper);
    border-top: 1px solid rgba(10,10,10,0.1);
  }
  .rt-hd__mobile-nav.is-open { display: flex; }

  .rt-hd__mobile-item { border-bottom: 1px solid rgba(10,10,10,0.07); }
  .rt-hd__mobile-item:last-child { border-bottom: none; }

  .rt-hd__mobile-link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rt-ink);
    text-decoration: none;
    display: block;
    padding: 14px 20px;
  }
  .rt-hd__mobile-children {
    padding: 0 20px 14px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rt-hd__mobile-child {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.65;
    text-decoration: none;
    display: block;
  }

  @media (max-width: 749px) {
    .rt-hd {
      grid-template-columns: auto 1fr auto;
      padding: 0 16px;
      gap: 0;
    }
    .rt-hd__nav    { display: none; }
    .rt-hd__logo   { justify-content: center; padding: 0 12px; }
    .rt-hd__menu-btn { display: flex; }
  }
</style>

<div class="rt-hd-wrap">
  <div class="rt-hd">

    {%- comment %} Left – desktop nav / mobile hamburger {%- endcomment %}
    <nav class="rt-hd__nav" aria-label="Main navigation">
      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.links.size > 0 -%}
          <div class="rt-hd__nav-item">
            <a href="{{ link.url }}"
               class="rt-hd__nav-link"
               aria-haspopup="true"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
              <span class="rt-hd__chevron" aria-hidden="true"></span>
            </a>
            <div class="rt-hd__dropdown" role="menu">
              {%- for child in link.links -%}
                <a href="{{ child.url }}" class="rt-hd__drop-link" role="menuitem">
                  {{ child.title | escape }}
                </a>
              {%- endfor -%}
            </div>
          </div>
        {%- else -%}
          <div class="rt-hd__nav-item">
            <a href="{{ link.url }}"
               class="rt-hd__nav-link"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <button class="rt-hd__menu-btn"
            aria-expanded="false"
            aria-controls="rt-mobile-nav"
            aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    {%- comment %} Centre – wordmark {%- endcomment %}
    <a href="{{ routes.root_url }}" class="rt-hd__logo">
      {{ section.settings.logo_text | default: 'Rangtarini' }}
    </a>

    {%- comment %} Right – search + cart {%- endcomment %}
    <div class="rt-hd__actions">
      <a href="{{ routes.search_url }}" class="rt-hd__icon" aria-label="Search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </a>
      <a href="{{ routes.cart_url }}" class="rt-hd__icon" aria-label="Cart, {{ cart.item_count }} items">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="rt-hd__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>

  {%- comment %} Mobile nav – flat list with sub-links shown inline {%- endcomment %}
  <nav class="rt-hd__mobile-nav" id="rt-mobile-nav" hidden>
    {%- for link in linklists[section.settings.menu].links -%}
      <div class="rt-hd__mobile-item">
        <a href="{{ link.url }}"
           class="rt-hd__mobile-link"
           {% if link.active %}aria-current="page"{% endif %}>
          {{ link.title | escape }}
        </a>
        {%- if link.links.size > 0 -%}
          <div class="rt-hd__mobile-children">
            {%- for child in link.links -%}
              <a href="{{ child.url }}" class="rt-hd__mobile-child">
                {{ child.title | escape }}
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </nav>
</div>

<script>
(function () {
  var btn = document.querySelector('.rt-hd__menu-btn');
  var nav = document.getElementById('rt-mobile-nav');
  if (!btn || !nav) return;
  btn.addEventListener('click', function () {
    var open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    btn.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    nav.hidden = open;
    nav.classList.toggle('is-open', !open);
  });
}());
</script>

{% schema %}
{
  "name": "Header",
  "class": "rt-header-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "RANGTARINI"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "info": "Create a menu with 2–4 items. Add child links under 'Shop' to populate the dropdown.",
      "default": "main-menu"
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
