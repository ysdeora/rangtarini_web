<style>
  /* Sticky lives on the section wrapper (grid item), not .rt-hd-wrap.
     The <body> is a CSS grid, so each section's grid-item wrapper is the
     containing block for sticky — only it has room to stick across the page. */
  #shopify-section-{{ section.id }} {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  #shopify-section-{{ section.id }}.rt-hd--hidden {
    transform: translateY(-100%);
  }
  .rt-hd-wrap {
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
    position: relative;
    z-index: 100;
    transition: background-color 320ms ease, box-shadow 320ms ease, backdrop-filter 320ms ease;
  }
  /* Frosted translucency once scrolled past the hero threshold */
  #shopify-section-{{ section.id }}.rt-hd--scrolled .rt-hd-wrap {
    background: color-mix(in srgb, var(--rt-paper) 80%, transparent);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    backdrop-filter: blur(14px) saturate(1.1);
    box-shadow: 0 1px 0 rgba(10,10,10,0.06);
  }

  /* Transparent state while floating over the cinematic hero (light-on-dark) */
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd-wrap {
    background: transparent;
    border-bottom-color: transparent;
    -webkit-backdrop-filter: none;
    backdrop-filter: none;
    box-shadow: none;
  }
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__nav-link,
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__logo {
    color: var(--rt-paper);
    transition: color 320ms ease, opacity 180ms;
  }
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__nav-link { opacity: 0.82; }
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__nav-item:hover > .rt-hd__nav-link,
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__nav-link:hover { opacity: 1; }
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__icon svg { stroke: var(--rt-paper); transition: stroke 320ms ease; }
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__menu-btn span { background: var(--rt-paper); }
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__cart-count { background: var(--rt-paper); color: var(--rt-ink); }
  /* Keep the inline search panel readable on its own paper surface even while onhero */
  #shopify-section-{{ section.id }}.rt-hd--onhero .rt-hd__search-panel { background: var(--rt-paper); }

  /* 3-col grid */
  .rt-hd {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    height: 60px;
    padding: 0 28px;
  }

  /* ── Nav ── */
  .rt-hd__nav {
    display: flex;
    gap: 32px;
    align-self: stretch;
    align-items: center;
  }
  /* Full-height items so dropdown top:100% = header bottom */
  .rt-hd__nav-item {
    position: relative;
    display: flex;
    align-items: center;
    height: 100%;
  }
  .rt-hd__nav-link {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 180ms;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .rt-hd__nav-link:hover,
  .rt-hd__nav-item:hover > .rt-hd__nav-link,
  .rt-hd__nav-item:focus-within > .rt-hd__nav-link,
  .rt-hd__nav-link[aria-current] { opacity: 1; }

  .rt-hd__chevron {
    display: inline-block;
    width: 0; height: 0;
    border-left: 3.5px solid transparent;
    border-right: 3.5px solid transparent;
    border-top: 4px solid currentColor;
    opacity: 0.7;
    margin-top: 1px;
    flex-shrink: 0;
    transition: transform 200ms;
  }
  .rt-hd__nav-item:hover .rt-hd__chevron,
  .rt-hd__nav-item:focus-within .rt-hd__chevron {
    transform: rotate(180deg);
  }

  /* ── 2-level dropdown ── */
  .rt-hd__dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--rt-paper);
    border: 1px solid var(--rt-ink);
    border-top: none;
    padding: 20px 24px;
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 10px 36px;
    min-width: 240px;
    z-index: 200;
  }
  .rt-hd__nav-item:hover .rt-hd__dropdown,
  .rt-hd__nav-item:focus-within .rt-hd__dropdown {
    display: grid;
  }
  .rt-hd__drop-link {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    font-weight: 500;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.65;
    transition: opacity 180ms;
    white-space: nowrap;
    display: block;
    padding: 3px 0;
  }
  .rt-hd__drop-link:hover { opacity: 1; }

  /* ── 3-level mega menu ── */
  .rt-hd__dropdown--mega {
    grid-template-columns: unset;
    padding: 0;
    min-width: unset;
    flex-direction: column; /* body row on top, strip on bottom */
  }
  .rt-hd__nav-item:hover .rt-hd__dropdown--mega,
  .rt-hd__nav-item:focus-within .rt-hd__dropdown--mega {
    display: flex;
  }
  /* Category columns row */
  .rt-mega__body {
    display: flex;
    align-items: stretch; /* all columns same height */
  }
  .rt-mega__col {
    padding: 20px 24px;
    border-right: 1px solid rgba(10,10,10,0.1);
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 148px;
  }
  .rt-mega__col:last-child { border-right: none; }
  .rt-mega__col-heading {
    font-family: var(--rt-font-grotesk);
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--rt-ink);
    text-decoration: none;
    opacity: 0.45;
    display: block;
    padding-bottom: 8px;
    margin-bottom: 2px;
    border-bottom: 1px solid rgba(10,10,10,0.1);
    white-space: nowrap;
  }
  /* Leaf items strip at the bottom */
  .rt-mega__strip {
    border-top: 1px solid rgba(10,10,10,0.08);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 0;
  }
  .rt-mega__strip-link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
    text-decoration: none;
    transition: opacity 180ms;
    white-space: nowrap;
    padding-right: 20px;
    margin-right: 20px;
    border-right: 1px solid rgba(10,10,10,0.12);
  }
  .rt-mega__strip-link:last-child {
    border-right: none;
    padding-right: 0;
    margin-right: 0;
  }
  .rt-mega__strip-link:hover { opacity: 1; }

  /* ── Logo (larger) ── */
  .rt-hd__logo {
    font-family: var(--rt-font-grotesk);
    font-size: 23px;
    font-weight: 900;
    letter-spacing: 0.34em;
    text-indent: 0.34em; /* re-centre: offsets the trailing space from letter-spacing */
    white-space: nowrap;
    text-transform: uppercase;
    color: var(--rt-ink);
    text-decoration: none;
    display: inline-block;
    align-self: center;
    line-height: 1;
  }

  /* ── Right icons ── */
  .rt-hd__actions {
    display: flex;
    gap: 18px;
    align-items: center;
    justify-content: flex-end;
  }
  .rt-hd__icon {
    color: var(--rt-ink);
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .rt-hd__icon svg {
    width: 19px; height: 19px;
    fill: none;
    stroke: var(--rt-ink);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    display: block;
  }
  .rt-hd__cart-count {
    font-family: var(--rt-font-grotesk);
    font-size: 8px;
    font-weight: 700;
    background: var(--rt-ink);
    color: var(--rt-paper);
    width: 15px; height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -6px; right: -8px;
    line-height: 1;
  }
  .rt-hd__cart-count--pulse {
    animation: rt-cart-pulse 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes rt-cart-pulse {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.35); }
    100% { transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .rt-hd__cart-count--pulse { animation: none; }
  }

  /* ── Inline search panel ── */
  .rt-hd__search-panel predictive-search { position: relative; display: block; }
  .rt-hd__search-panel {
    display: none;
    background: var(--rt-paper);
    border-bottom: 1px solid var(--rt-ink);
    padding: 0 28px;
    position: absolute;
    top: 100%;
    left: 0; right: 0;
    z-index: 200;
  }
  .rt-hd__search-panel.is-open { display: block; }
  .rt-hd__search-form {
    display: flex;
    align-items: center;
    height: 52px;
    gap: 12px;
  }
  .rt-hd__search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--rt-font-grotesk);
    font-size: 14px;
    color: var(--rt-ink);
    font-weight: 400;
    letter-spacing: 0.02em;
    -webkit-appearance: none;
  }
  .rt-hd__search-input::placeholder {
    color: var(--rt-ink);
    opacity: 0.38;
  }
  .rt-hd__search-sep {
    width: 1px; height: 20px;
    background: var(--rt-ink);
    opacity: 0.15;
    flex-shrink: 0;
  }
  .rt-hd__search-btn {
    background: none; border: none;
    cursor: pointer;
    color: var(--rt-ink);
    display: flex; align-items: center;
    padding: 0;
    opacity: 0.6;
    transition: opacity 180ms;
  }
  .rt-hd__search-btn:hover { opacity: 1; }
  .rt-hd__search-btn svg {
    width: 18px; height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Mobile hamburger ── */
  .rt-hd__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none; border: none;
    cursor: pointer; padding: 4px;
    align-self: center;
  }
  .rt-hd__menu-btn span {
    display: block;
    width: 22px; height: 1.5px;
    background: var(--rt-ink);
    transition: transform 240ms ease, opacity 240ms ease;
  }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg) translate(4.5px, 4.5px);
  }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .rt-hd__menu-btn[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg) translate(4.5px, -4.5px);
  }

  /* ── Mobile drawer ── */
  .rt-hd__mobile-nav {
    display: none; flex-direction: column;
    background: var(--rt-paper);
    border-top: 1px solid rgba(10,10,10,0.1);
  }
  .rt-hd__mobile-nav.is-open {
    display: flex;
    max-height: calc(100vh - 60px);
    overflow-y: auto;
  }

  .rt-hd__mobile-item { border-bottom: 1px solid rgba(10,10,10,0.07); }
  .rt-hd__mobile-item:last-child { border-bottom: none; }

  .rt-hd__mobile-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rt-hd__mobile-link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rt-ink);
    text-decoration: none;
    display: block;
    padding: 14px 20px;
    flex: 1;
  }
  .rt-hd__mobile-acc-btn {
    background: none; border: none;
    cursor: pointer; padding: 14px 20px 14px 0;
    font-size: 18px; line-height: 1;
    color: var(--rt-ink); opacity: 0.5;
    transition: transform 220ms, opacity 220ms;
  }
  .rt-hd__mobile-acc-btn[aria-expanded="true"] {
    transform: rotate(45deg);
    opacity: 1;
  }
  /* Accordion section */
  .rt-hd__mobile-section {
    overflow: hidden;
    max-height: 0;
    transition: max-height 300ms ease;
  }
  .rt-hd__mobile-section.is-open { max-height: 1400px; }
  .rt-hd__mobile-children {
    padding: 4px 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  /* Flat child link */
  .rt-hd__mobile-child {
    font-family: var(--rt-font-grotesk);
    font-size: 12px; font-weight: 500;
    color: var(--rt-ink); opacity: 0.65;
    text-decoration: none;
    display: block;
    padding: 8px 0;
    border-bottom: 1px solid rgba(10,10,10,0.05);
  }
  .rt-hd__mobile-child:last-child { border-bottom: none; }
  /* Sub-accordion row (child WITH grandchildren) */
  .rt-mobile-sub { border-top: 1px solid rgba(10,10,10,0.05); }
  .rt-mobile-sub:first-child { border-top: none; }
  .rt-mobile-sub__row {
    display: flex;
    align-items: center;
  }
  .rt-mobile-sub__link {
    font-family: var(--rt-font-grotesk);
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rt-ink); opacity: 0.5;
    text-decoration: none;
    display: block;
    padding: 10px 0;
    flex: 1;
  }
  .rt-mobile-sub__btn {
    background: none; border: none;
    cursor: pointer; padding: 10px 0 10px 14px;
    font-size: 16px; line-height: 1;
    color: var(--rt-ink); opacity: 0.4;
    transition: transform 220ms, opacity 220ms;
  }
  .rt-mobile-sub__btn[aria-expanded="true"] {
    transform: rotate(45deg);
    opacity: 1;
  }
  .rt-mobile-sub__section {
    overflow: hidden;
    max-height: 0;
    transition: max-height 280ms ease;
    padding-left: 12px;
  }
  .rt-mobile-sub__section.is-open { max-height: 600px; }
  .rt-hd__mobile-child--gc {
    font-size: 11px;
    opacity: 0.55;
    padding: 6px 0;
  }

  @media (max-width: 749px) {
    .rt-hd { grid-template-columns: 1fr auto 1fr; padding: 0 16px; position: relative; }
    .rt-hd__nav { display: none; }
    /* Absolutely center logo so it's pixel-perfect regardless of icon count on either side */
    .rt-hd__logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      pointer-events: auto;
      font-size: 17px;
      letter-spacing: 0.26em;
      text-indent: 0.26em;
    }
    .rt-hd__menu-btn { display: flex; grid-column: 1; justify-self: start; }
    /* Logo is out of grid flow (absolute), so actions must be pinned to col 3 explicitly */
    .rt-hd__actions { grid-column: 3; justify-self: end; }
    /* Account icon hidden on mobile — login link is in the drawer */
    .rt-hd__icon--acct { display: none; }
    .rt-hd__search-panel { padding: 0 16px; }
  }

  /* ── Cart notification popup ── */
  .rt-hd__notif-anchor { position: relative; height: 0; overflow: visible; }
  cart-notification .cart-notification-wrapper { position: static; }

  /* Panel */
  #cart-notification.cart-notification {
    position: absolute;
    top: 0;
    right: 28px;
    width: 380px;
    max-width: calc(100vw - 32px);
    padding: 0;
    background: var(--rt-paper);
    border: 1px solid var(--rt-ink);
    z-index: 200;
    /* Hidden state */
    opacity: 0;
    transform: translateY(-12px);
    pointer-events: none;
    visibility: hidden;
  }
  #cart-notification.cart-notification.animate {
    transition: opacity 150ms ease, transform 180ms cubic-bezier(0.2,0.7,0.2,1), visibility 0s 180ms;
  }
  #cart-notification.cart-notification.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
    transition: opacity 150ms ease, transform 180ms cubic-bezier(0.2,0.7,0.2,1), visibility 0s;
  }

  /* Header row */
  .cart-notification__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 16px;
    border-bottom: 1px solid var(--rt-ink);
  }
  .cart-notification__heading {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--rt-ink);
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 11px;
  }
  /* Circle checkmark */
  .rt-cn__check-circle {
    width: 18px; height: 18px;
    border: 1px solid var(--rt-ink);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  /* (1,1,0) — beats component CSS .cart-notification__close { margin-top:-2rem; margin-right:-3rem } */
  #cart-notification .cart-notification__close {
    background: none; border: none;
    cursor: pointer; padding: 6px; margin: 0;
    display: inline-flex; align-items: center;
    opacity: 0.5; transition: opacity 180ms;
  }
  #cart-notification .cart-notification__close:hover { opacity: 1; }
  #cart-notification .cart-notification__close .svg-wrapper { display: flex; }
  #cart-notification .cart-notification__close .icon-close {
    width: 16px; height: 16px;
    stroke: var(--rt-ink); stroke-width: 1.6; fill: none;
  }

  /* Product row (populated by AJAX section rendering) */
  /* High specificity (1,1,0) required — component-cart-notification.css loads after this block and overrides equal-specificity rules */
  /* Grid + padding live on the persistent container (#cart-notification-product), not
     .rt-cn-product — cart-notification.js injects the wrapper's innerHTML, stripping .rt-cn-product. */
  #cart-notification .cart-notification-product {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 16px;
    padding: 20px;
  }

  /* Skeleton shown while AJAX is in-flight */
  #cart-notification[data-loading] #cart-notification-product {
    min-height: 110px;
    position: relative;
  }
  #cart-notification[data-loading] #cart-notification-product::after {
    content: '';
    position: absolute;
    inset: 10px 16px;
    background: var(--rt-ink);
    opacity: 0.06;
    animation: rt-cn-pulse 1s ease-in-out infinite;
  }
  @keyframes rt-cn-pulse {
    0%, 100% { opacity: 0.06; }
    50%       { opacity: 0.02; }
  }
  .rt-cn-product__img-link {
    display: block;
    width: 72px;
    aspect-ratio: 1 / 1.18;
    overflow: hidden;
    border: 1px solid var(--rt-ink);
    flex-shrink: 0;
  }
  .rt-cn-product__img-link img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .rt-cn-product__info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    min-width: 0;
  }
  .rt-cn-product__name-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rt-cn-product__name {
    font-family: var(--rt-font-grotesk);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--rt-ink);
    text-decoration: none;
    line-height: 1.25;
  }
  .rt-cn-product__name:hover { opacity: 0.7; }
  .rt-cn-product__deva {
    font-family: var(--rt-font-deva);
    font-size: 14px;
    font-weight: 500;
    color: var(--rt-gold);
    line-height: 1.1;
  }
  .rt-cn-product__variant,
  .rt-cn-product__qty {
    font-family: var(--rt-font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rt-ink);
    opacity: 0.55;
    margin: 0;
  }
  .rt-cn-product__price {
    font-family: var(--rt-font-grotesk);
    font-size: 15px;
    font-weight: 700;
    color: var(--rt-ink);
    margin: 2px 0 0;
  }

  /* Subtotal row */
  .rt-cn-subtotal {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 12px 16px;
    border-top: 1px solid var(--rt-ink);
    border-bottom: 1px solid var(--rt-ink);
  }
  .rt-cn-subtotal__label {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    opacity: 0.7;
  }
  .rt-cn-subtotal__price {
    font-family: var(--rt-font-grotesk);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--rt-ink);
  }

  /* Action buttons */
  .cart-notification__links {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rt-cn-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 15px 18px;
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    box-sizing: border-box;
    border-radius: 0;
    transition: background 180ms, color 180ms, opacity 180ms;
  }
  .rt-cn-btn--outline {
    background: transparent;
    border: 1px solid var(--rt-ink);
    color: var(--rt-ink);
  }
  .rt-cn-btn--outline:hover { background: var(--rt-ink); color: var(--rt-paper); }
  .rt-cn-btn--solid {
    background: var(--rt-ink);
    border: 1px solid var(--rt-ink);
    color: var(--rt-paper);
  }
  .rt-cn-btn--solid:hover { opacity: 0.8; }
  .rt-cn-btn--ghost {
    background: transparent;
    border: none;
    color: var(--rt-ink);
    font-size: 11px;
    letter-spacing: 0;
    text-transform: none;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    padding: 6px 0 2px;
    opacity: 0.7;
  }
  .rt-cn-btn--ghost:hover { opacity: 1; }
  #cart-notification-form { width: 100%; margin: 0; }

  @media (max-width: 749px) {
    #cart-notification.cart-notification {
      right: 0;
      width: 100%;
      max-width: 100%;
    }
  }
</style>

<div class="rt-hd-wrap">

  <div class="rt-hd">

    {%- comment %} Left — desktop nav / mobile hamburger {%- endcomment %}
    <nav class="rt-hd__nav" aria-label="Main navigation">
      {%- for link in linklists[section.settings.menu].links -%}

        {%- if link.links.size > 0 -%}
          {%- comment %} Detect whether any child has grandchildren (3-level) {%- endcomment %}
          {%- assign is_mega = false -%}
          {%- for child in link.links -%}
            {%- if child.links.size > 0 -%}{%- assign is_mega = true -%}{%- endif -%}
          {%- endfor -%}

          <div class="rt-hd__nav-item">
            <a href="{{ link.url }}"
               class="rt-hd__nav-link"
               aria-haspopup="true"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
              <span class="rt-hd__chevron" aria-hidden="true"></span>
            </a>

            {%- if is_mega -%}
              <div class="rt-hd__dropdown rt-hd__dropdown--mega" role="menu">
                {%- comment %} Top: category columns (children WITH grandchildren) {%- endcomment %}
                <div class="rt-mega__body">
                  {%- for child in link.links -%}
                    {%- if child.links.size > 0 -%}
                      <div class="rt-mega__col">
                        <a href="{{ child.url }}" class="rt-mega__col-heading">{{ child.title | escape }}</a>
                        {%- for gc in child.links -%}
                          <a href="{{ gc.url }}" class="rt-hd__drop-link" role="menuitem">{{ gc.title | escape }}</a>
                        {%- endfor -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- comment %} Bottom strip: leaf children (no grandchildren) {%- endcomment %}
                {%- assign has_flat_children = false -%}
                {%- for child in link.links -%}
                  {%- if child.links.size == 0 -%}{%- assign has_flat_children = true -%}{%- endif -%}
                {%- endfor -%}
                {%- if has_flat_children -%}
                  <div class="rt-mega__strip">
                    {%- for child in link.links -%}
                      {%- if child.links.size == 0 -%}
                        <a href="{{ child.url }}" class="rt-mega__strip-link" role="menuitem">{{ child.title | escape }}</a>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- else -%}
              <div class="rt-hd__dropdown" role="menu">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="rt-hd__drop-link" role="menuitem">{{ child.title | escape }}</a>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

        {%- else -%}
          <div class="rt-hd__nav-item">
            <a href="{{ link.url }}"
               class="rt-hd__nav-link"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
          </div>
        {%- endif -%}

      {%- endfor -%}
    </nav>

    <button class="rt-hd__menu-btn"
            aria-expanded="false"
            aria-controls="rt-mobile-nav"
            aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

    {%- comment %} Centre — wordmark {%- endcomment %}
    <a href="{{ routes.root_url }}" class="rt-hd__logo">
      {{ section.settings.logo_text | default: 'RANGTARINI' }}
    </a>

    {%- comment %} Right — search + account + cart {%- endcomment %}
    <div class="rt-hd__actions">
      <button class="rt-hd__icon rt-hd__icon--search"
              aria-label="Search"
              aria-expanded="false"
              aria-controls="rt-search-panel">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
           class="rt-hd__icon rt-hd__icon--acct"
           aria-label="{%- if customer -%}{{ 'customer.account.title' | t }}{%- else -%}{{ 'customer.log_in' | t }}{%- endif -%}">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="rt-hd__icon rt-hd__icon--cart" aria-label="Cart, {{ cart.item_count }} items">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="rt-hd__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

  </div>

  {%- comment %} Inline search panel — slides in below header {%- endcomment %}
  <div class="rt-hd__search-panel" id="rt-search-panel" role="search" aria-label="Site search">
    {%- if settings.predictive_search_enabled -%}
      <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
    {%- endif -%}
    <form action="{{ routes.search_url }}" method="get" class="rt-hd__search-form">
      <input type="hidden" name="type" value="product">
      <input type="search"
             name="q"
             id="rt-search-input"
             class="rt-hd__search-input"
             placeholder="Search jewellery, collections…"
             autocomplete="off"
             autocorrect="off"
             autocapitalize="off"
             spellcheck="false"
             aria-label="Search products"
             {%- if settings.predictive_search_enabled -%}
               role="combobox"
               aria-expanded="false"
               aria-owns="predictive-search-results"
               aria-controls="predictive-search-results"
               aria-haspopup="listbox"
               aria-autocomplete="list"
             {%- endif -%}>
      <button type="reset" class="hidden" aria-label="{{ 'general.search.reset' | t }}"></button>
      <div class="rt-hd__search-sep" aria-hidden="true"></div>
      <button type="submit" class="rt-hd__search-btn" aria-label="Submit search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      <button type="button" class="rt-hd__search-btn" id="rt-search-close" aria-label="Close search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
      </button>
      {%- if settings.predictive_search_enabled -%}
        <div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
          {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
        </div>
        <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
      {%- endif -%}
    </form>
    {%- if settings.predictive_search_enabled -%}
      </predictive-search>
    {%- endif -%}
  </div>

  {%- comment %} Mobile nav drawer {%- endcomment %}
  <nav class="rt-hd__mobile-nav" id="rt-mobile-nav" hidden>
    {%- for link in linklists[section.settings.menu].links -%}
      {%- assign is_mega_mob = false -%}
      {%- for child in link.links -%}
        {%- if child.links.size > 0 -%}{%- assign is_mega_mob = true -%}{%- endif -%}
      {%- endfor -%}

      <div class="rt-hd__mobile-item">
        {%- if link.links.size > 0 -%}
          <div class="rt-hd__mobile-row">
            <a href="{{ link.url }}" class="rt-hd__mobile-link"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title | escape }}
            </a>
            <button class="rt-hd__mobile-acc-btn"
                    aria-expanded="{%- if is_mega_mob -%}true{%- else -%}false{%- endif -%}"
                    aria-label="Expand {{ link.title | escape }}">+</button>
          </div>
          <div class="rt-hd__mobile-section{%- if is_mega_mob %} is-open{%- endif -%}">
            <div class="rt-hd__mobile-children">
              {%- if is_mega_mob -%}
                {%- for child in link.links -%}
                  {%- if child.links.size > 0 -%}
                    <div class="rt-mobile-sub">
                      <div class="rt-mobile-sub__row">
                        <a href="{{ child.url }}" class="rt-mobile-sub__link">{{ child.title | escape }}</a>
                        <button class="rt-mobile-sub__btn"
                                aria-expanded="false"
                                aria-label="Expand {{ child.title | escape }}">+</button>
                      </div>
                      <div class="rt-mobile-sub__section">
                        {%- for gc in child.links -%}
                          <a href="{{ gc.url }}" class="rt-hd__mobile-child rt-hd__mobile-child--gc">{{ gc.title | escape }}</a>
                        {%- endfor -%}
                      </div>
                    </div>
                  {%- else -%}
                    <a href="{{ child.url }}" class="rt-hd__mobile-child">{{ child.title | escape }}</a>
                  {%- endif -%}
                {%- endfor -%}
              {%- else -%}
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="rt-hd__mobile-child">{{ child.title | escape }}</a>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="rt-hd__mobile-link"
             {% if link.active %}aria-current="page"{% endif %}>
            {{ link.title | escape }}
          </a>
        {%- endif -%}
      </div>

    {%- endfor -%}
    <div class="rt-hd__mobile-item">
      <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
         class="rt-hd__mobile-link">
        {%- if customer -%}{{ 'customer.account.title' | t }}{%- else -%}{{ 'customer.log_in' | t }}{%- endif -%}
      </a>
    </div>
  </nav>

  {%- if settings.cart_type == 'notification' -%}
    <div class="rt-hd__notif-anchor">
      {%- render 'cart-notification' -%}
    </div>
  {%- endif -%}

  {%- comment -%} Required by cart-notification.js — absorbs section render without affecting UI {%- endcomment -%}
  <span id="cart-icon-bubble" aria-hidden="true" style="display:none"></span>

</div>

{%- if settings.cart_type == 'notification' -%}
  <script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script>
(function () {

  /* ── Mobile hamburger (with Escape + focus trap) ── */
  var menuBtn = document.querySelector('.rt-hd__menu-btn');
  var mobileNav = document.getElementById('rt-mobile-nav');
  if (menuBtn && mobileNav) {
    function drawerFocusables() {
      return mobileNav.querySelectorAll('a[href], button:not([disabled]), input, [tabindex]:not([tabindex="-1"])');
    }
    function openDrawer() {
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.setAttribute('aria-label', 'Close menu');
      mobileNav.hidden = false;
      mobileNav.classList.add('is-open');
      var f = drawerFocusables();
      if (f.length) setTimeout(function () { f[0].focus(); }, 30);
    }
    function closeDrawer() {
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.setAttribute('aria-label', 'Open menu');
      mobileNav.classList.remove('is-open');
      mobileNav.hidden = true;
      menuBtn.focus();
    }
    menuBtn.addEventListener('click', function () {
      (menuBtn.getAttribute('aria-expanded') === 'true') ? closeDrawer() : openDrawer();
    });
    document.addEventListener('keydown', function (e) {
      if (mobileNav.hidden) return;
      if (e.key === 'Escape') {
        closeDrawer();
        return;
      }
      if (e.key === 'Tab') {
        var f = drawerFocusables();
        if (!f.length) return;
        var first = f[0];
        var last = f[f.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  }

  /* ── Mobile accordion (top level) ── */
  document.querySelectorAll('.rt-hd__mobile-acc-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item    = btn.closest('.rt-hd__mobile-item');
      var section = item && item.querySelector('.rt-hd__mobile-section');
      var open    = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      if (section) section.classList.toggle('is-open', !open);
    });
  });

  /* ── Mobile sub-accordion (sub-collections with grandchildren) ── */
  document.querySelectorAll('.rt-mobile-sub__btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var sub     = btn.closest('.rt-mobile-sub');
      var section = sub && sub.querySelector('.rt-mobile-sub__section');
      var open    = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      if (section) section.classList.toggle('is-open', !open);
    });
  });

  /* ── Inline search ── */
  var searchBtn   = document.querySelector('.rt-hd__icon--search');
  var searchPanel = document.getElementById('rt-search-panel');
  var searchInput = document.getElementById('rt-search-input');
  var searchClose = document.getElementById('rt-search-close');

  if (searchBtn && searchPanel && searchInput) {
    function openSearch() {
      searchPanel.classList.add('is-open');
      searchBtn.setAttribute('aria-expanded', 'true');
      setTimeout(function () { searchInput.focus(); }, 30);
    }
    function closeSearch() {
      searchPanel.classList.remove('is-open');
      searchBtn.setAttribute('aria-expanded', 'false');
    }

    searchBtn.addEventListener('click', function () {
      searchPanel.classList.contains('is-open') ? closeSearch() : openSearch();
    });

    if (searchClose) {
      searchClose.addEventListener('click', closeSearch);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && searchPanel.classList.contains('is-open')) {
        closeSearch();
        searchBtn.focus();
      }
    });

    /* Close when clicking outside the search panel and button */
    document.addEventListener('click', function (e) {
      if (!searchPanel.contains(e.target) && !searchBtn.contains(e.target)) {
        closeSearch();
      }
    });
  }

  /* ── Hide on scroll down, reveal on scroll up ──
     The sticky element is the section wrapper (grid item), so toggle the
     class there — not on .rt-hd-wrap, which can't stick on its own. */
  var hdWrap = document.querySelector('.rt-hd-wrap');
  var hdSection = hdWrap ? hdWrap.closest('.shopify-section') : null;
  /* Cinematic hero (homepage only) — header floats transparent over it.
     The header markup is parsed before the template body, so resolve the hero
     lazily (now if present, again on DOMContentLoaded / section load). */
  var heroEl = document.querySelector('.rt-hero-cinema');
  function refreshHero() { heroEl = document.querySelector('.rt-hero-cinema'); }
  var HEADER_H = hdWrap ? hdWrap.offsetHeight : 60;
  var lastScrollY = window.scrollY;
  var scrollTicking = false;
  var HD_THRESHOLD = 80;

  function syncHeaderState() {
    var y = window.scrollY;
    var isSearchOpen = searchPanel && searchPanel.classList.contains('is-open');
    var isMobileOpen = mobileNav && !mobileNav.hidden;

    /* Over the hero while its bottom edge is still beneath the header band */
    var overHero = false;
    if (heroEl && !isSearchOpen && !isMobileOpen) {
      overHero = heroEl.getBoundingClientRect().bottom > HEADER_H + 2;
    }

    if (hdSection) {
      hdSection.classList.toggle('rt-hd--onhero', overHero);
      /* Frosted only once we've left the hero (the two states are exclusive) */
      hdSection.classList.toggle('rt-hd--scrolled', y > HD_THRESHOLD && !overHero);
    }

    if (hdSection && !isSearchOpen && !isMobileOpen) {
      if (y > lastScrollY && y > HD_THRESHOLD) {
        hdSection.classList.add('rt-hd--hidden');
      } else {
        hdSection.classList.remove('rt-hd--hidden');
      }
    }

    lastScrollY = y;
    scrollTicking = false;
  }

  window.addEventListener('scroll', function () {
    if (scrollTicking) return;
    scrollTicking = true;
    requestAnimationFrame(syncHeaderState);
  }, { passive: true });

  /* Initial paint — establish the over-hero state before any scroll.
     Re-resolve the hero once the template body has parsed. */
  syncHeaderState();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      refreshHero();
      HEADER_H = hdWrap ? hdWrap.offsetHeight : 60;
      syncHeaderState();
    });
  } else {
    refreshHero();
    syncHeaderState();
  }
  /* Theme editor — hero can load after the header */
  document.addEventListener('shopify:section:load', function () { refreshHero(); syncHeaderState(); });

}());
</script>

<script>
/* Update cart notification subtotal and header cart count badge on cart change */
document.addEventListener('DOMContentLoaded', function() {

  /* The /cart/add response has no item_count — read the true count from the
     freshly-rendered cart-icon-bubble section that ships in the same payload. */
  function countFromBubbleSection(sections) {
    if (!sections || !sections['cart-icon-bubble']) return null;
    var doc = new DOMParser().parseFromString(sections['cart-icon-bubble'], 'text/html');
    var countEl = doc.querySelector('.cart-count-bubble [aria-hidden="true"]');
    if (countEl) {
      var n = parseInt((countEl.textContent || '').replace(/\D+/g, ''), 10);
      return isNaN(n) ? null : n;
    }
    /* Bubble present but count hidden (>= 100) → leave the badge unchanged */
    if (doc.querySelector('.cart-count-bubble')) return null;
    return 0; /* no bubble => empty cart */
  }

  subscribe(PUB_SUB_EVENTS.cartUpdate, function(event) {
    if (!event || !event.cartData) return;
    var data = event.cartData;
    var count = (typeof data.item_count === 'number') ? data.item_count : countFromBubbleSection(data.sections);
    var paise = data.total_price;

    /* Subtotal row inside notification */
    var subtotalEl = document.querySelector('.rt-cn-subtotal');
    if (subtotalEl && typeof paise === 'number' && count !== null) {
      var label = subtotalEl.querySelector('.rt-cn-subtotal__label');
      var price = subtotalEl.querySelector('.rt-cn-subtotal__price');
      if (label) label.textContent = 'Bag subtotal — ' + count + ' ' + (count === 1 ? 'item' : 'items');
      if (price) price.textContent = Shopify && Shopify.formatMoney
        ? Shopify.formatMoney(paise, window.Shopify.money_format || 'Rs. {{amount}}')
        : 'Rs. ' + (paise / 100).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    /* Header cart count badge — never blow it away when the count is unknown */
    if (count === null) return;
    var cartIcon = document.querySelector('.rt-hd__icon--cart');
    if (cartIcon) {
      var badge = cartIcon.querySelector('.rt-hd__cart-count');
      if (count > 0) {
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'rt-hd__cart-count';
          badge.setAttribute('aria-hidden', 'true');
          cartIcon.appendChild(badge);
        }
        badge.textContent = count;
        /* Pulse the badge on cart change */
        badge.classList.remove('rt-hd__cart-count--pulse');
        void badge.offsetWidth;
        badge.classList.add('rt-hd__cart-count--pulse');
      } else if (badge) {
        badge.remove();
      }
    }
  });
});
</script>

{% schema %}
{
  "name": "Header",
  "class": "rt-header-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "RANGTARINI"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "info": "Items with child links get a dropdown. Children with grandchildren become a mega menu with column headings.",
      "default": "main-menu"
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
