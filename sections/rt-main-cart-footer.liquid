<style>
  /* ── Footer shell ── */
  .rt-cart-ft {
    background: var(--rt-paper);
    padding: 0 28px 80px;
  }

  /* Hide footer when cart is empty — initial SSR state */
  #main-cart-footer.rt-cart-ft-empty { display: none; }
  /* Hide footer when cart is dynamically emptied via AJAX */
  body:has(cart-items.is-empty) #main-cart-footer { display: none; }

  /* ── Inner layout: two-col on desktop ── */
  .rt-cart-ft__inner {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 0;
    border-top: 1px solid var(--rt-ink);
  }

  /* ── Note / left col ── */
  .rt-cart-ft__left {
    padding: 48px 56px 0 0;
    border-right: 1px solid var(--rt-ink);
  }

  /* Cart note */
  cart-note.rt-cart-note {
    display: block;
  }
  .rt-cart-note label {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    opacity: 0.5;
    display: block;
    margin: 0 0 10px;
  }
  .rt-cart-note textarea {
    width: 100%;
    border: 1px solid var(--rt-ink);
    background: none;
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    color: var(--rt-ink);
    padding: 14px 16px;
    resize: vertical;
    min-height: 100px;
    outline: none;
    transition: border-color 160ms;
  }
  .rt-cart-note textarea::placeholder { opacity: 0.35; }
  .rt-cart-note textarea:focus { border-color: var(--rt-ink); }

  /* Discounts in left col */
  .rt-cart-ft__discounts {
    margin-top: 32px;
  }
  .rt-cart-ft__discounts-label {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    opacity: 0.45;
    display: block;
    margin: 0 0 10px;
  }
  .rt-cart-ft__discount-item {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--rt-ink);
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }
  .rt-cart-ft__discount-item svg { width: 14px; height: 14px; opacity: 0.5; }

  /* ── Summary / right col ── */
  .rt-cart-ft__right {
    padding: 48px 0 0 48px;
  }

  /* Total row */
  .rt-cart-ft__total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--rt-ink);
    margin-bottom: 16px;
  }
  .rt-cart-ft__total-label {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-ink);
    opacity: 0.55;
  }
  .rt-cart-ft__total-amount {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(22px, 2.5vw, 32px);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--rt-ink);
    text-align: right;
  }

  /* Tax note */
  .rt-cart-ft__tax-note {
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--rt-ink);
    opacity: 0.45;
    line-height: 1.55;
    margin: 0 0 32px;
  }
  .rt-cart-ft__tax-note a {
    color: inherit;
    text-decoration: underline;
    opacity: 0.7;
    transition: opacity 150ms;
  }
  .rt-cart-ft__tax-note a:hover { opacity: 1; }

  /* Checkout button */
  .rt-cart-ft__checkout {
    display: block;
    width: 100%;
    background: var(--rt-ink);
    color: var(--rt-paper);
    border: 1px solid var(--rt-ink);
    padding: 18px 24px;
    font-family: var(--rt-font-grotesk);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 180ms;
    text-align: center;
  }
  .rt-cart-ft__checkout:hover { opacity: 0.75; }
  .rt-cart-ft__checkout[disabled] { opacity: 0.35; cursor: default; }

  /* Dynamic checkout buttons */
  .rt-cart-ft__dynamic {
    margin-top: 12px;
  }

  /* Continue shopping */
  .rt-cart-ft__continue {
    display: block;
    text-align: center;
    margin-top: 20px;
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-ink);
    opacity: 0.38;
    text-decoration: none;
    transition: opacity 160ms;
  }
  .rt-cart-ft__continue:hover { opacity: 0.85; }

  /* Errors */
  #cart-errors {
    font-family: var(--rt-font-grotesk);
    font-size: 12px;
    color: #b91c1c;
    margin-top: 14px;
    letter-spacing: 0.04em;
  }
  #cart-errors:empty { display: none; }

  /* ── Responsive ── */
  @media (max-width: 990px) {
    .rt-cart-ft { padding: 0 20px 64px; }
    .rt-cart-ft__inner { grid-template-columns: 1fr 320px; }
    .rt-cart-ft__left  { padding: 40px 40px 0 0; }
    .rt-cart-ft__right { padding: 40px 0 0 36px; }
  }
  @media (max-width: 749px) {
    .rt-cart-ft { padding: 0 16px 56px; }
    .rt-cart-ft__inner { grid-template-columns: 1fr; }
    .rt-cart-ft__left  {
      padding: 32px 0 32px 0;
      border-right: none;
      border-bottom: 1px solid var(--rt-ink);
    }
    .rt-cart-ft__right { padding: 32px 0 0; }
    .rt-cart-ft__total-amount { font-size: 24px; }
  }
</style>

<div class="rt-cart-ft-wrap{% if cart == empty %} rt-cart-ft-empty{% endif %}" id="main-cart-footer" data-id="{{ section.id }}">
  <div class="rt-cart-ft{% if cart == empty %} is-empty{% endif %}">
    <div class="rt-cart-ft__inner js-contents">

      {%- comment -%} LEFT COLUMN: note + cart-level discounts {%- endcomment -%}
      <div class="rt-cart-ft__left">

        {%- if settings.show_cart_note -%}
          <cart-note class="rt-cart-note">
            <label for="Cart-note">{{ 'sections.cart.note' | t }}</label>
            <textarea
              name="note"
              form="cart"
              id="Cart-note"
              placeholder="{{ 'sections.cart.note' | t }}">{{ cart.note }}</textarea>
          </cart-note>
        {%- endif -%}

        {%- if cart.cart_level_discount_applications.size > 0 -%}
          <div class="rt-cart-ft__discounts">
            <span class="rt-cart-ft__discounts-label">Discounts applied</span>
            {%- for discount in cart.cart_level_discount_applications -%}
              <p class="rt-cart-ft__discount-item">
                {{- 'icon-discount.svg' | inline_asset_content -}}
                {{ discount.title | escape }}
                <span>(−{{ discount.total_allocated_amount | money }})</span>
              </p>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} RIGHT COLUMN: total + checkout {%- endcomment -%}
      <div class="rt-cart-ft__right">

        <div class="rt-cart-ft__total-row">
          <span class="rt-cart-ft__total-label">{{ 'sections.cart.estimated_total' | t }}</span>
          <span class="rt-cart-ft__total-amount">{{ cart.total_price | money_with_currency }}</span>
        </div>

        <p class="rt-cart-ft__tax-note">
          {%- if cart.duties_included and cart.taxes_included -%}
            {%- if shop.shipping_policy.body == blank -%}
              {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
            {%- else -%}
              {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}
            {%- endif -%}
          {%- elsif cart.taxes_included -%}
            {%- if shop.shipping_policy.body == blank -%}
              {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
            {%- else -%}
              {{ 'sections.cart.taxes_included_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}
            {%- endif -%}
          {%- else -%}
            {%- if shop.shipping_policy.body == blank -%}
              {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
            {%- else -%}
              {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html' | t: link: shop.shipping_policy.url }}
            {%- endif -%}
          {%- endif -%}
        </p>

        <button
          type="submit"
          id="checkout"
          class="rt-cart-ft__checkout"
          name="checkout"
          {% if cart == empty %}disabled{% endif %}
          form="cart">
          {{ 'sections.cart.checkout' | t }} →
        </button>

        {%- if additional_checkout_buttons -%}
          <div class="rt-cart-ft__dynamic additional-checkout-buttons">
            {{ content_for_additional_checkout_buttons }}
          </div>
        {%- endif -%}

        <a href="{{ routes.all_products_collection_url }}" class="rt-cart-ft__continue">
          {{ 'general.continue_shopping' | t }} →
        </a>

        <div id="cart-errors"></div>

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "RT Cart Footer",
  "class": "rt-cart-footer-section",
  "settings": []
}
{% endschema %}
