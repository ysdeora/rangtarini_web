{%- comment -%}
  rt-about.liquid
  About Us editorial section — dark-background design matching v3 aesthetic.
  All copy and images are editable from the Theme Editor.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">

<style>
  .rt-about {
    --rt-serif:  "Cormorant Garamond", Georgia, serif;
    --rt-sans:   "Archivo", sans-serif;
    --rt-mono:   "DM Mono", "Courier New", monospace;
    --rt-dark:   #0a0a0a;
    --rt-dark2:  #111111;
    --rt-dark3:  #0d0d0d;
    --rt-cream:  #f5f0e8;
    --rt-muted:  #aaaaaa;
    --rt-dim:    #888888;
    --rt-gold:   #c9a84c;
    --rt-gold2:  #e8d5a3;
    --rt-rule:   rgba(201, 168, 76, 0.12);
    box-sizing: border-box;
    font-family: var(--rt-sans);
    font-weight: 300;
    color: var(--rt-cream);
    background: var(--rt-dark);
    -webkit-font-smoothing: antialiased;
  }
  .rt-about *, .rt-about *::before, .rt-about *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .rt-about a { text-decoration: none; }

  /* Shared tokens */
  .rt-about__eyebrow {
    font-family: var(--rt-sans);
    font-size: 11px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--rt-gold);
    display: block;
    margin-bottom: 16px;
  }
  .rt-about__rule {
    width: 40px;
    height: 1px;
    background: var(--rt-gold);
    margin-bottom: 28px;
  }

  /* Scroll reveal */
  .rt-ab-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .rt-ab-reveal.rt-ab-visible { opacity: 1; transform: none; }
  .rt-ab-d1 { transition-delay: 0.10s; }
  .rt-ab-d2 { transition-delay: 0.20s; }
  .rt-ab-d3 { transition-delay: 0.30s; }

  /* ── 1. HERO ── */
  .rt-ab-hero {
    background: var(--rt-dark);
    padding: 72px 64px 64px;
    border-bottom: 1px solid var(--rt-rule);
  }
  .rt-ab-hero__headline {
    font-family: var(--rt-serif);
    font-size: clamp(3.8rem, 7vw, 7rem);
    font-weight: 300;
    line-height: 1.08;
    color: var(--rt-cream);
    margin-bottom: 28px;
  }
  .rt-ab-hero__headline em { font-style: italic; color: var(--rt-gold2); }
  .rt-ab-hero__sub {
    font-size: 14px;
    line-height: 1.9;
    color: var(--rt-muted);
    max-width: 52ch;
  }

  /* ── 2. FOUNDER ── */
  .rt-ab-founder {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--rt-rule);
  }
  .rt-ab-founder__img {
    background: #141414;
    position: relative;
    min-height: 480px;
    overflow: hidden;
  }
  .rt-ab-founder__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }
  .rt-ab-founder__copy {
    background: var(--rt-dark2);
    padding: 64px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .rt-ab-founder__headline {
    font-family: var(--rt-serif);
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--rt-cream);
    margin-bottom: 28px;
  }
  .rt-ab-founder__headline em { font-style: italic; color: var(--rt-gold2); }
  .rt-ab-founder__body { font-size: 13px; line-height: 1.9; color: var(--rt-muted); }
  .rt-ab-founder__body p { margin-bottom: 18px; }
  .rt-ab-founder__body p:last-child { margin-bottom: 0; }
  .rt-ab-founder__body strong { color: var(--rt-cream); font-weight: 500; }

  /* ── 3. MISSION ── */
  .rt-ab-mission {
    padding: 72px 64px;
    background: var(--rt-dark3);
    border-bottom: 1px solid var(--rt-rule);
  }
  .rt-ab-mission__quote {
    font-family: var(--rt-serif);
    font-size: clamp(2.2rem, 3.5vw, 3.6rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.4;
    color: var(--rt-cream);
    max-width: 28ch;
    margin-bottom: 36px;
    padding-left: 28px;
    border-left: 2px solid var(--rt-gold);
  }
  .rt-ab-mission__body { font-size: 13px; line-height: 1.9; color: var(--rt-muted); max-width: 62ch; }
  .rt-ab-mission__body p { margin-bottom: 16px; }
  .rt-ab-mission__body p:last-child { margin-bottom: 0; }
  .rt-ab-mission__body em { color: var(--rt-cream); font-style: normal; }

  /* ── 4. ORIGIN ── */
  .rt-ab-origin {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--rt-rule);
  }
  .rt-ab-origin__copy {
    padding: 64px 56px;
    background: var(--rt-dark2);
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid rgba(201,168,76,0.10);
  }
  .rt-ab-origin__headline {
    font-family: var(--rt-serif);
    font-size: clamp(2.6rem, 3.5vw, 3.8rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--rt-cream);
    margin-bottom: 28px;
  }
  .rt-ab-origin__headline em { font-style: italic; color: var(--rt-gold2); }
  .rt-ab-origin__body { font-size: 13px; line-height: 1.9; color: var(--rt-muted); }
  .rt-ab-origin__body p { margin-bottom: 16px; }
  .rt-ab-origin__body p:last-child { margin-bottom: 0; }
  .rt-ab-origin__img {
    background: #141414;
    position: relative;
    overflow: hidden;
    min-height: 420px;
  }
  .rt-ab-origin__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }
  .rt-ab-origin__img:hover img { transform: scale(1.04); }

  /* ── 5. MATERIALS ── */
  .rt-ab-materials {
    background: var(--rt-dark);
    padding: 72px 64px;
    border-bottom: 1px solid var(--rt-rule);
  }
  .rt-ab-materials__hd { margin-bottom: 44px; }
  .rt-ab-materials__headline {
    font-family: var(--rt-serif);
    font-size: clamp(2.6rem, 3.5vw, 3.6rem);
    font-weight: 300;
    color: var(--rt-cream);
    margin-bottom: 14px;
  }
  .rt-ab-materials__sub { font-size: 13px; color: var(--rt-dim); line-height: 1.75; max-width: 55ch; }
  .rt-ab-mat-grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks | size | at_most: 3 }}, 1fr);
    border: 1px solid var(--rt-rule);
  }
  .rt-ab-mat-item {
    padding: 48px 40px;
    border-right: 1px solid var(--rt-rule);
    transition: background 0.3s ease;
  }
  .rt-ab-mat-item:last-child { border-right: none; }
  .rt-ab-mat-item:hover { background: rgba(201,168,76,0.03); }
  .rt-ab-mat-num {
    font-family: var(--rt-serif);
    font-size: 2.8rem;
    font-weight: 300;
    color: #d3d3d3;
    line-height: 1;
    margin-bottom: 16px;
  }
  .rt-ab-mat-tag {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rt-gold);
    border: 1px solid rgba(201,168,76,0.30);
    padding: 4px 12px;
    margin-bottom: 14px;
  }
  .rt-ab-mat-name {
    font-family: var(--rt-serif);
    font-size: 2.1rem;
    font-weight: 400;
    color: var(--rt-cream);
    margin-bottom: 14px;
  }
  .rt-ab-mat-desc { font-size: 12px; line-height: 1.8; color: var(--rt-dim); }

  /* ── 6. CLOSING ── */
  .rt-ab-closing {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--rt-rule);
  }
  .rt-ab-bespoke {
    padding: 64px 56px;
    background: var(--rt-dark2);
    border-right: 1px solid rgba(201,168,76,0.10);
  }
  .rt-ab-bespoke__headline {
    font-family: var(--rt-serif);
    font-size: clamp(2.6rem, 3.2vw, 3.4rem);
    font-weight: 300;
    color: var(--rt-cream);
    line-height: 1.15;
    margin-bottom: 24px;
  }
  .rt-ab-bespoke__headline em { font-style: italic; color: var(--rt-gold2); }
  .rt-ab-bespoke__body {
    font-size: 13px;
    color: var(--rt-muted);
    line-height: 1.9;
    margin-bottom: 36px;
  }
  .rt-ab-bespoke__cta {
    display: inline-block;
    font-family: var(--rt-sans);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rt-dark);
    background: var(--rt-gold);
    padding: 16px 36px;
    transition: background 0.2s ease;
  }
  .rt-ab-bespoke__cta:hover { background: var(--rt-gold2); }
  .rt-ab-signoff {
    padding: 64px 56px;
    background: var(--rt-dark3);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .rt-ab-signoff__statement {
    font-family: var(--rt-serif);
    font-size: clamp(1.9rem, 2.5vw, 2.6rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.55;
    color: var(--rt-cream);
    margin-bottom: 36px;
  }
  .rt-ab-signoff__name {
    font-family: var(--rt-serif);
    font-size: 1.5rem;
    color: var(--rt-gold);
    margin-bottom: 6px;
  }
  .rt-ab-signoff__title {
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #555;
  }
  .rt-ab-signoff__shop {
    display: inline-block;
    margin-top: 36px;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--rt-cream);
    border-bottom: 1px solid var(--rt-gold);
    padding-bottom: 4px;
    transition: color 0.2s ease;
  }
  .rt-ab-signoff__shop:hover { color: var(--rt-gold); }

  /* Mobile */
  @media (max-width: 749px) {
    .rt-ab-hero { padding: 56px 24px 48px; }

    .rt-ab-founder { grid-template-columns: 1fr; }
    .rt-ab-founder__img { min-height: 300px; aspect-ratio: 4/3; }
    .rt-ab-founder__copy { padding: 48px 24px; }

    .rt-ab-mission { padding: 56px 24px; }

    .rt-ab-origin { grid-template-columns: 1fr; }
    .rt-ab-origin__img { min-height: 260px; order: -1; }
    .rt-ab-origin__copy { padding: 48px 24px; border-right: none; border-top: 1px solid var(--rt-rule); }

    .rt-ab-materials { padding: 56px 24px; }
    .rt-ab-mat-grid { grid-template-columns: 1fr; }
    .rt-ab-mat-item { border-right: none; border-bottom: 1px solid var(--rt-rule); padding: 40px 28px; }
    .rt-ab-mat-item:last-child { border-bottom: none; }

    .rt-ab-closing { grid-template-columns: 1fr; }
    .rt-ab-bespoke { padding: 48px 24px; border-right: none; border-bottom: 1px solid var(--rt-rule); }
    .rt-ab-signoff { padding: 48px 24px; }
  }
</style>

<div class="rt-about">

  {%- comment -%}── 1. HERO ──{%- endcomment -%}
  <div class="rt-ab-hero">
    {%- if section.settings.hero_eyebrow != blank -%}
      <span class="rt-about__eyebrow rt-ab-reveal">{{ section.settings.hero_eyebrow | escape }}</span>
    {%- endif -%}
    <div class="rt-about__rule rt-ab-reveal rt-ab-d1"></div>
    <h1 class="rt-ab-hero__headline rt-ab-reveal rt-ab-d2">
      {{ section.settings.hero_headline }}
    </h1>
    {%- if section.settings.hero_sub != blank -%}
      <p class="rt-ab-hero__sub rt-ab-reveal rt-ab-d3">{{ section.settings.hero_sub | escape }}</p>
    {%- endif -%}
  </div>

  {%- comment -%}── 2. FOUNDER ──{%- endcomment -%}
  <div class="rt-ab-founder">
    <div class="rt-ab-founder__img">
      {%- if section.settings.founder_image != blank -%}
        {%- assign fimg = section.settings.founder_image -%}
        <img src="{{ fimg | image_url: width: 900 }}"
             srcset="{{ fimg | image_url: width: 600 }} 600w, {{ fimg | image_url: width: 900 }} 900w"
             sizes="50vw"
             alt="{{ fimg.alt | default: section.settings.founder_name | escape }}"
             width="{{ fimg.width }}"
             height="{{ fimg.height }}"
             loading="lazy">
      {%- endif -%}
    </div>
    <div class="rt-ab-founder__copy">
      {%- if section.settings.founder_eyebrow != blank -%}
        <span class="rt-about__eyebrow rt-ab-reveal">{{ section.settings.founder_eyebrow | escape }}</span>
      {%- endif -%}
      <div class="rt-about__rule rt-ab-reveal rt-ab-d1"></div>
      <h2 class="rt-ab-founder__headline rt-ab-reveal rt-ab-d2">
        {{ section.settings.founder_headline }}
      </h2>
      {%- if section.settings.founder_body != blank -%}
        <div class="rt-ab-founder__body rt-ab-reveal rt-ab-d3">
          {{ section.settings.founder_body }}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}── 3. MISSION ──{%- endcomment -%}
  <div class="rt-ab-mission">
    {%- if section.settings.mission_eyebrow != blank -%}
      <span class="rt-about__eyebrow rt-ab-reveal">{{ section.settings.mission_eyebrow | escape }}</span>
    {%- endif -%}
    {%- if section.settings.mission_quote != blank -%}
      <blockquote class="rt-ab-mission__quote rt-ab-reveal rt-ab-d1">
        {{ section.settings.mission_quote | escape }}
      </blockquote>
    {%- endif -%}
    {%- if section.settings.mission_body != blank -%}
      <div class="rt-ab-mission__body rt-ab-reveal rt-ab-d2">
        {{ section.settings.mission_body }}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%}── 4. ORIGIN ──{%- endcomment -%}
  <div class="rt-ab-origin">
    <div class="rt-ab-origin__copy">
      {%- if section.settings.origin_eyebrow != blank -%}
        <span class="rt-about__eyebrow rt-ab-reveal">{{ section.settings.origin_eyebrow | escape }}</span>
      {%- endif -%}
      <div class="rt-about__rule rt-ab-reveal rt-ab-d1"></div>
      <h2 class="rt-ab-origin__headline rt-ab-reveal rt-ab-d2">
        {{ section.settings.origin_headline }}
      </h2>
      {%- if section.settings.origin_body != blank -%}
        <div class="rt-ab-origin__body rt-ab-reveal rt-ab-d3">
          {{ section.settings.origin_body }}
        </div>
      {%- endif -%}
    </div>
    <div class="rt-ab-origin__img">
      {%- if section.settings.origin_image != blank -%}
        {%- assign oimg = section.settings.origin_image -%}
        <img src="{{ oimg | image_url: width: 900 }}"
             srcset="{{ oimg | image_url: width: 600 }} 600w, {{ oimg | image_url: width: 900 }} 900w"
             sizes="50vw"
             alt="{{ oimg.alt | default: section.settings.origin_eyebrow | escape }}"
             width="{{ oimg.width }}"
             height="{{ oimg.height }}"
             loading="lazy">
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}── 5. MATERIALS ──{%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="rt-ab-materials">
      <div class="rt-ab-materials__hd">
        {%- if section.settings.mat_eyebrow != blank -%}
          <span class="rt-about__eyebrow rt-ab-reveal">{{ section.settings.mat_eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section.settings.mat_headline != blank -%}
          <h2 class="rt-ab-materials__headline rt-ab-reveal rt-ab-d1">{{ section.settings.mat_headline | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.mat_sub != blank -%}
          <p class="rt-ab-materials__sub rt-ab-reveal rt-ab-d2">{{ section.settings.mat_sub | escape }}</p>
        {%- endif -%}
      </div>
      <div class="rt-ab-mat-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'material' -%}
            <div class="rt-ab-mat-item rt-ab-reveal{% if forloop.index0 > 0 %} rt-ab-d{{ forloop.index0 }}{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.number != blank -%}
                <div class="rt-ab-mat-num">{{ block.settings.number | escape }}</div>
              {%- endif -%}
              {%- if block.settings.tag != blank -%}
                <span class="rt-ab-mat-tag">{{ block.settings.tag | escape }}</span>
              {%- endif -%}
              {%- if block.settings.name != blank -%}
                <h3 class="rt-ab-mat-name">{{ block.settings.name | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="rt-ab-mat-desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- comment -%}── 6. CLOSING ──{%- endcomment -%}
  <div class="rt-ab-closing">
    <div class="rt-ab-bespoke">
      {%- if section.settings.bespoke_eyebrow != blank -%}
        <span class="rt-about__eyebrow rt-ab-reveal">{{ section.settings.bespoke_eyebrow | escape }}</span>
      {%- endif -%}
      <div class="rt-about__rule rt-ab-reveal rt-ab-d1"></div>
      <h2 class="rt-ab-bespoke__headline rt-ab-reveal rt-ab-d2">
        {{ section.settings.bespoke_headline }}
      </h2>
      {%- if section.settings.bespoke_body != blank -%}
        <p class="rt-ab-bespoke__body rt-ab-reveal rt-ab-d3">{{ section.settings.bespoke_body | escape }}</p>
      {%- endif -%}
      {%- if section.settings.bespoke_cta_label != blank and section.settings.bespoke_cta_url != blank -%}
        <a href="{{ section.settings.bespoke_cta_url }}" class="rt-ab-bespoke__cta rt-ab-reveal">
          {{ section.settings.bespoke_cta_label | escape }}
        </a>
      {%- endif -%}
    </div>
    <div class="rt-ab-signoff">
      {%- if section.settings.signoff_quote != blank -%}
        <p class="rt-ab-signoff__statement rt-ab-reveal">"{{ section.settings.signoff_quote | escape }}"</p>
      {%- endif -%}
      {%- if section.settings.signoff_name != blank -%}
        <p class="rt-ab-signoff__name rt-ab-reveal rt-ab-d1">{{ section.settings.signoff_name | escape }}</p>
      {%- endif -%}
      {%- if section.settings.signoff_title != blank -%}
        <p class="rt-ab-signoff__title rt-ab-reveal rt-ab-d2">{{ section.settings.signoff_title | escape }}</p>
      {%- endif -%}
      {%- if section.settings.signoff_shop_label != blank and section.settings.signoff_shop_url != blank -%}
        <a href="{{ section.settings.signoff_shop_url }}" class="rt-ab-signoff__shop rt-ab-reveal rt-ab-d3">
          {{ section.settings.signoff_shop_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>

</div>

<script>
(function () {
  var els = document.querySelectorAll('.rt-ab-reveal');
  if (!els.length) return;
  if (!('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('rt-ab-visible'); });
    return;
  }
  var obs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('rt-ab-visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.1 });
  els.forEach(function (el) { obs.observe(el); });
})();
</script>

{% schema %}
{
  "name": "About Page",
  "class": "rt-about-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow",
      "default": "About Us"
    },
    {
      "type": "richtext",
      "id": "hero_headline",
      "label": "Headline",
      "default": "<p>Born in Jodhpur.<br>Made in Rajasthan.<br><em>Worn Everywhere.</em></p>"
    },
    {
      "type": "textarea",
      "id": "hero_sub",
      "label": "Subheadline",
      "default": "Handcrafted Indian jewelry, rooted in Rajasthan. Regal by design. Yours to wear."
    },
    {
      "type": "header",
      "content": "Founder"
    },
    {
      "type": "image_picker",
      "id": "founder_image",
      "label": "Founder photo"
    },
    {
      "type": "text",
      "id": "founder_eyebrow",
      "label": "Eyebrow",
      "default": "The Woman Behind It"
    },
    {
      "type": "richtext",
      "id": "founder_headline",
      "label": "Headline",
      "default": "<p><em>I don’t trend-chase.</em><br>I curate.</p>"
    },
    {
      "type": "text",
      "id": "founder_name",
      "label": "Founder name (for image alt text)",
      "default": "Bhoomika Ranawat"
    },
    {
      "type": "richtext",
      "id": "founder_body",
      "label": "Body copy",
      "default": "<p>My name is <strong>Bhoomika Ranawat</strong>. I grew up in Jodhpur — surrounded by jewelry the way most children are surrounded by toys. At weddings, at temples, at Sunday markets.</p><p>Silver anklets. Gold chokers. Jhumkas passed from mother to daughter like quiet heirlooms. I didn’t study jewelry. I absorbed it. I learned to read a piece — whether it carries something real, or whether it’s just surface.</p><p>Every piece at Rangtarini passes one test: <strong>does it feel worthy?</strong> Worthy of the craft. Worthy of the woman who will wear it. If it doesn’t — it doesn’t make the cut.</p>"
    },
    {
      "type": "header",
      "content": "Mission"
