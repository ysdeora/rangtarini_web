{%- comment -%}
  rt-about.liquid — About Us (Heirloom · Cinema)
  Implements the Claude Design "Rangtarini About Heirloom" layout on the
  theme's --rt-* tokens. All copy/images editable from the Theme Editor.
  Motion: global rt-reveal.js ([data-rt-reveal] → .rt-in).
{%- endcomment -%}

{{ 'rt-about.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign deva_house = 'रंगतारिणी'
  assign s = section.settings
-%}

<div class="rt-about" id="rt-about-{{ section.id }}">

  {%- comment -%}════════ HERO ════════{%- endcomment -%}
  <section class="rt-ab-hero" data-screen-label="Hero">
    <div class="rt-ab-hero__media">
      {%- if s.hero_image != blank -%}
        <img class="rt-ab-img"
             src="{{ s.hero_image | image_url: width: 2000 }}"
             srcset="{{ s.hero_image | image_url: width: 1200 }} 1200w, {{ s.hero_image | image_url: width: 2000 }} 2000w"
             sizes="100vw"
             alt="{{ s.hero_image.alt | default: 'Rangtarini' | escape }}"
             loading="eager" fetchpriority="high"
             width="{{ s.hero_image.width }}" height="{{ s.hero_image.height }}">
      {%- else -%}
        <span class="rt-ab-ph" aria-hidden="true"></span>
      {%- endif -%}
    </div>
    <div class="rt-ab-hero__scrim" aria-hidden="true"></div>
    <div class="rt-ab-hero__frame" aria-hidden="true">
      <span>Est. Rajasthan</span>
      <span>Udaipur — 24.5854° N</span>
    </div>
    <div class="rt-ab-hero__content">
      <div>
        {%- if s.hero_eyebrow != blank -%}
          <span class="rt-ab-hero__eyebrow" data-rt-reveal>{{ s.hero_eyebrow | escape }}</span>
        {%- endif -%}
        <h1 class="rt-ab-hero__headline" data-rt-reveal style="--d:120ms;">{{ s.hero_headline }}</h1>
        {%- if s.hero_sub != blank -%}
          <p class="rt-ab-hero__sub" data-rt-reveal style="--d:280ms;">{{ s.hero_sub | escape }}</p>
        {%- endif -%}
        <div class="rt-ab-hero__ctas" data-rt-reveal style="--d:400ms;">
          {%- if s.hero_cta1_label != blank -%}
            <a class="rt-ab-btn rt-ab-btn--paper" href="{{ s.hero_cta1_url | default: '#ra-founder' }}">{{ s.hero_cta1_label | escape }} <span class="arr" aria-hidden="true">→</span></a>
          {%- endif -%}
          {%- if s.hero_cta2_label != blank -%}
            <a class="rt-ab-btn rt-ab-btn--onink" href="{{ s.hero_cta2_url | default: '/collections/all' }}">{{ s.hero_cta2_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
      <div class="rt-ab-hero__side" data-rt-reveal style="--d:520ms;">
        <span class="deva" aria-hidden="true">{{ deva_house }}</span>
        <span class="rt-ab-hero__cue" aria-hidden="true"></span>
      </div>
    </div>
  </section>

  {%- comment -%}════════ INTRO STATEMENT ════════{%- endcomment -%}
  <section class="ra-intro" data-screen-label="Intro">
    <div>
      {%- if s.intro_idx != blank -%}<span class="idx" data-rt-reveal>{{ s.intro_idx | escape }}</span>{%- endif -%}
      {%- if s.intro_lead != blank -%}<p class="ra-intro-lead" data-rt-reveal style="--d:90ms;">{{ s.intro_lead }}</p>{%- endif -%}
    </div>
    <div class="ra-intro-foot">
      {%- if s.intro_body != blank -%}<p data-rt-reveal>{{ s.intro_body | escape }}</p>{%- endif -%}
      {%- if s.intro_deva != blank -%}<span class="ra-intro-deva" data-rt-reveal style="--d:120ms;" aria-hidden="true">{{ s.intro_deva | escape }}</span>{%- endif -%}
    </div>
  </section>

  {%- comment -%}════════ 01 · FOUNDER ════════{%- endcomment -%}
  <section class="ra-founder" id="ra-founder" data-screen-label="Founder">
    <div class="ra-founder-media">
      <div class="ra-founder-frame" data-rt-reveal>
        {%- if s.founder_image != blank -%}
          <img class="rt-ab-img" src="{{ s.founder_image | image_url: width: 1000 }}"
               alt="{{ s.founder_image.alt | default: s.founder_name | escape }}" loading="lazy"
               width="{{ s.founder_image.width }}" height="{{ s.founder_image.height }}">
        {%- else -%}
          <span class="rt-ab-ph" aria-hidden="true"></span>
        {%- endif -%}
      </div>
      {%- if s.founder_name != blank -%}
        <figcaption class="ra-founder-cap">
          <span class="nm">{{ s.founder_name | escape }}</span>
          {%- if s.founder_role != blank -%}<span class="ttl">{{ s.founder_role | escape }}</span>{%- endif -%}
        </figcaption>
      {%- endif -%}
    </div>
    <div class="ra-founder-body">
      {%- if s.founder_eyebrow != blank -%}<span class="idx" data-rt-reveal>{{ s.founder_eyebrow | escape }}</span>{%- endif -%}
      <h2 class="ra-founder-headline" data-rt-reveal style="--d:80ms;">{{ s.founder_headline }}</h2>
      {%- if s.founder_deva != blank -%}<span class="ra-founder-deva" data-rt-reveal style="--d:140ms;">{{ s.founder_deva | escape }}</span>{%- endif -%}
      {%- if s.founder_body != blank -%}<div class="ra-founder-copy" data-rt-reveal style="--d:180ms;">{{ s.founder_body }}</div>{%- endif -%}
      {%- if s.founder_test != blank -%}
        <div class="ra-test" data-rt-reveal style="--d:300ms;">
          <span class="q">{{ s.founder_test }}</span>
          {%- if s.founder_test_note != blank -%}<span class="note">{{ s.founder_test_note | escape }}</span>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  {%- comment -%}════════ 02 · MANIFESTO ════════{%- endcomment -%}
  <section class="ra-mani" data-screen-label="Manifesto">
    <div class="ra-mani-inner">
      {%- if s.mission_eyebrow != blank -%}<span class="idx" data-rt-reveal>{{ s.mission_eyebrow | escape }}</span>{%- endif -%}
      {%- if s.mission_quote != blank -%}<blockquote class="ra-mani-quote" data-rt-reveal style="--d:90ms;">{{ s.mission_quote }}</blockquote>{%- endif -%}
      {%- if s.mission_body != blank -%}<div class="ra-mani-foot" data-rt-reveal style="--d:160ms;">{{ s.mission_body }}</div>{%- endif -%}
    </div>
    <span class="ra-mani-wm" aria-hidden="true">{{ deva_house }}</span>
  </section>

  {%- comment -%}════════ 04 · MATERIALS ════════{%- endcomment -%}
  <div class="rt-shead" data-screen-label="Materials head">
    <div>
      {%- if s.mat_eyebrow != blank -%}<span class="rt-shead__idx">{{ s.mat_eyebrow | escape }}</span>{%- endif -%}
      {%- comment -%} Break after the first sentence so it reads as two lines (e.g. "Three materials." / "One standard.") {%- endcomment -%}
      {%- if s.mat_headline != blank -%}<h2 class="rt-shead__title" data-rt-reveal>{{ s.mat_headline | escape | replace_first: '. ', '.<br>' }}</h2>{%- endif -%}
    </div>
    {%- if s.mat_sub != blank -%}<div class="rt-shead__meta">{{ s.mat_sub | escape }}</div>{%- endif -%}
  </div>
  <section class="ra-mat" data-screen-label="Materials">
    {%- for block in section.blocks -%}
      {%- if block.type == 'material' -%}
        <article class="ra-mat-card" data-rt-reveal style="--d:{{ forloop.index0 | times: 110 }}ms;" {{ block.shopify_attributes }}>
          <div class="ra-mat-frame">
            {%- if block.settings.image != blank -%}
              <img class="rt-ab-img" src="{{ block.settings.image | image_url: width: 800 }}"
                   alt="{{ block.settings.image.alt | default: block.settings.name | escape }}" loading="lazy"
                   width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}">
            {%- else -%}
              <span class="rt-ab-ph" aria-hidden="true"></span>
            {%- endif -%}
            {%- if block.settings.number != blank -%}<span class="ra-mat-no">{{ block.settings.number | escape }}</span>{%- endif -%}
          </div>
          {%- if block.settings.tag != blank -%}<span class="ra-mat-kicker">{{ block.settings.tag | escape }}</span>{%- endif -%}
          {%- if block.settings.name != blank -%}<h3>{{ block.settings.name | escape }}</h3>{%- endif -%}
          {%- if block.settings.description != blank -%}<p>{{ block.settings.description | escape }}</p>{%- endif -%}
        </article>
      {%- endif -%}
    {%- endfor -%}
  </section>

  {%- comment -%}════════ 05 · BESPOKE ════════{%- endcomment -%}
  <section class="rt-ab-wa" id="ra-bespoke" data-screen-label="Bespoke">
    <div class="rt-ab-wa-grid">
      <div>
        {%- if s.bespoke_eyebrow != blank -%}<span class="idx">{{ s.bespoke_eyebrow | escape }}</span>{%- endif -%}
        <h2 class="rt-ab-wa-head" data-rt-reveal style="--d:60ms;">{{ s.bespoke_headline }}</h2>
        {%- if s.bespoke_chips != blank -%}
          <div class="rt-ab-wa-chips" data-rt-reveal style="--d:150ms;">
            {%- assign chips = s.bespoke_chips | newline_to_br | split: '<br />' -%}
            {%- for chip in chips -%}
              {%- assign chip_t = chip | strip -%}
              {%- if chip_t != blank -%}<span class="rt-ab-wa-chip">{{ chip_t | escape }}</span>{%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <div class="rt-ab-wa-right" data-rt-reveal style="--d:250ms;">
        {%- if s.bespoke_body != blank -%}<p>{{ s.bespoke_body | escape }}</p>{%- endif -%}
        {%- if s.bespoke_cta_label != blank -%}
          <a class="rt-ab-btn rt-ab-btn--wa" href="{{ s.bespoke_cta_url }}">{{ s.bespoke_cta_label | escape }} <span class="arr" aria-hidden="true">→</span></a>
        {%- endif -%}
        {%- if s.bespoke_note != blank -%}<span class="rt-ab-wa-note">{{ s.bespoke_note | escape }}</span>{%- endif -%}
        {%- if s.bespoke_email != blank -%}
          <a class="rt-ab-wa-email" href="mailto:{{ s.bespoke_email }}">Or email {{ s.bespoke_email | escape }} <span class="arr" aria-hidden="true">→</span></a>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%}════════ CLOSING ════════{%- endcomment -%}
  <section class="ra-close" data-screen-label="Closing">
    <div class="ra-close-inner">
      <span class="mark" data-rt-reveal aria-hidden="true">{{ deva_house }}</span>
      {%- if s.signoff_quote != blank -%}<blockquote class="ra-close-quote" data-rt-reveal style="--d:100ms;">{{ s.signoff_quote }}</blockquote>{%- endif -%}
      <div class="by" data-rt-reveal style="--d:220ms;">
        {%- if s.signoff_name != blank -%}<span class="nm">{{ s.signoff_name | escape }}</span>{%- endif -%}
        {%- if s.signoff_title != blank -%}<span class="role">{{ s.signoff_title | escape }}</span>{%- endif -%}
      </div>
      {%- if s.signoff_shop_label != blank -%}
        <a class="rt-ab-btn rt-ab-btn--onink" data-rt-reveal style="--d:300ms;" href="{{ s.signoff_shop_url | default: '/collections/all' }}">{{ s.signoff_shop_label | escape }} <span class="arr" aria-hidden="true">→</span></a>
      {%- endif -%}
    </div>
    <span class="ra-close-wm" aria-hidden="true">RT</span>
  </section>

</div>

{% schema %}
{
  "name": "About Page",
  "tag": "section",
  "class": "section-rt-about",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero background image" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Our story · Handcrafted in Rajasthan" },
    { "type": "richtext", "id": "hero_headline", "label": "Headline", "info": "Italicise words to accent them in gold.", "default": "<p>Born in Jodhpur.<br>Based in Udaipur.<br>Worn <em>everywhere.</em></p>" },
    { "type": "textarea", "id": "hero_sub", "label": "Sub-text", "default": "Handcrafted Indian jewellery, rooted in Rajasthan — regal by design, and yours to wear." },
    { "type": "text", "id": "hero_cta1_label", "label": "Primary CTA label", "default": "Meet the founder" },
    { "type": "text", "id": "hero_cta1_url", "label": "Primary CTA link", "default": "#ra-founder" },
    { "type": "text", "id": "hero_cta2_label", "label": "Secondary CTA label", "default": "Shop the collection" },
    { "type": "url", "id": "hero_cta2_url", "label": "Secondary CTA link" },

    { "type": "header", "content": "Intro statement" },
    { "type": "text", "id": "intro_idx", "label": "Eyebrow", "default": "Rangtarini — the house" },
    { "type": "inline_richtext", "id": "intro_lead", "label": "Lead statement", "info": "Italicise words to accent them in gold.", "default": "A name for the woman who <em>colours the world</em> — and the jewellery she refuses to take off." },
    { "type": "textarea", "id": "intro_body", "label": "Supporting paragraph", "default": "The name means \"she who colours the world.\" We built the house in her image — unhurried, certain, the kind of woman who finds one piece and keeps it for thirty years. Everything we make is meant to be worn that long." },
    { "type": "text", "id": "intro_deva", "label": "Devanagari accent", "default": "रंगतारिणी" },

    { "type": "header", "content": "01 · The founder" },
    { "type": "image_picker", "id": "founder_image", "label": "Founder portrait" },
    { "type": "text", "id": "founder_eyebrow", "label": "Eyebrow", "default": "01 — The woman behind it" },
    { "type": "richtext", "id": "founder_headline", "label": "Headline", "default": "<p>I don't trend-chase.<br><em>I curate.</em></p>" },
    { "type": "text", "id": "founder_deva", "label": "Devanagari accent", "default": "भूमिका" },
    { "type": "richtext", "id": "founder_body", "label": "Body", "default": "<p>I grew up in Jodhpur, surrounded by jewellery the way most children are surrounded by toys — at weddings, at temples, at Sunday markets.</p><p>I didn't study jewellery. I absorbed it. I learned to read a piece — whether it carries something real, or whether it's just surface.</p><p>So every piece at Rangtarini meets one test before it earns its name. <strong>If it doesn't feel worthy — it doesn't make the cut.</strong></p>" },
    { "type": "text", "id": "founder_name", "label": "Founder name", "default": "Bhoomika Ranawat" },
    { "type": "text", "id": "founder_role", "label": "Founder role / caption", "default": "Founder · Rangtarini" },
    { "type": "text", "id": "founder_test", "label": "Pull-quote question", "default": "Does it feel <em>worthy?</em>" },
    { "type": "text", "id": "founder_test_note", "label": "Pull-quote note", "default": "The only question that matters" },

    { "type": "header", "content": "02 · Why we exist (manifesto)" },
    { "type": "text", "id": "mission_eyebrow", "label": "Eyebrow", "default": "02 — Why we exist" },
    { "type": "richtext", "id": "mission_quote", "label": "Statement", "default": "<p>Fine Indian jewellery has always existed. What hasn't — is <em>access</em> to it.</p>" },
    { "type": "richtext", "id": "mission_body", "label": "Supporting paragraphs", "default": "<p>The intricate meenakari, the kundan settings, the filigree jhumkas — designs with centuries of lineage — have been quietly out of reach for the very women who grew up loving them.</p><p>So we built Rangtarini around silver — not the untouchable price of gold. The same hands, the same lineage, <em>without asking you to choose between what's authentic and what's affordable.</em></p>" },

    { "type": "header", "content": "03 · Where we are" },
    { "type": "image_picker", "id": "origin_image", "label": "Place image" },
    { "type": "text", "id": "origin_eyebrow", "label": "Eyebrow", "default": "03 — Where we are" },
    { "type": "richtext", "id": "origin_headline", "label": "Headline", "default": "<p>Udaipur is not <em>just our address.</em></p>" },
    { "type": "richtext", "id": "origin_body", "label": "Body", "default": "<p>We are based in Udaipur — the city of lakes, of havelis, of a particular unhurried elegance that finds its way into everything made here.</p><p>Udaipur does not shout. It does not perform. It simply <em>is.</em> That quiet confidence is what we hope every Rangtarini piece carries.</p>" },
    { "type": "text", "id": "origin_coord", "label": "Coordinate caption", "default": "Udaipur · 24.5854° N, 73.7125° E" },

    { "type": "header", "content": "04 · What we make" },
    { "type": "text", "id": "mat_eyebrow", "label": "Eyebrow", "default": "04 — What we make" },
    { "type": "text", "id": "mat_headline", "label": "Headline", "default": "Three materials. One standard." },
    { "type": "textarea", "id": "mat_sub", "label": "Meta", "default": "Handcrafted · selected by hand. United by intent, not metal." },

    { "type": "header", "content": "05 · Bespoke" },
    { "type": "text", "id": "bespoke_eyebrow", "label": "Eyebrow", "default": "05 — Made to order" },
    { "type": "richtext", "id": "bespoke_headline", "label": "Headline", "default": "<p>A piece that exists <em>once.</em></p>" },
    { "type": "textarea", "id": "bespoke_chips", "label": "Chips (one per line)", "default": "Bridal commissions\nJadau kundan\nTemple silver\nRestorations" },
    { "type": "textarea", "id": "bespoke_body", "label": "Body", "default": "Send a reference, a sketch, or your grandmother's piece that needs a second life. Our bench replies with a plan, and a date." },
    { "type": "text", "id": "bespoke_cta_label", "label": "CTA label", "default": "Start on WhatsApp" },
    { "type": "url", "id": "bespoke_cta_url", "label": "CTA link" },
    { "type": "text", "id": "bespoke_note", "label": "Note", "default": "Replies within hours · 10am–7pm IST" },
    { "type": "text", "id": "bespoke_email", "label": "Bespoke email", "default": "bespoke@rangtarini.com" },

    { "type": "header", "content": "Closing" },
    { "type": "richtext", "id": "signoff_quote", "label": "Closing statement", "default": "<p>Every piece we add is another step toward making regal Indian jewellery <em>truly everyone's.</em></p>" },
    { "type": "text", "id": "signoff_name", "label": "Name", "default": "Bhoomika Ranawat" },
    { "type": "text", "id": "signoff_title", "label": "Role", "default": "Founder · Rangtarini" },
    { "type": "text", "id": "signoff_shop_label", "label": "CTA label", "default": "Shop the collection" },
    { "type": "url", "id": "signoff_shop_url", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "number", "label": "Number", "default": "01" },
        { "type": "text", "id": "tag", "label": "Kicker", "default": "925 Sterling" },
        { "type": "text", "id": "name", "label": "Name", "default": "Pure Silver" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Authentic 925 sterling silver, BIS hallmarked. Made to be worn for a lifetime." }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "About Page",
      "blocks": [
        { "type": "material", "settings": { "number": "01", "tag": "925 Sterling", "name": "Pure Silver" } },
        { "type": "material", "settings": { "number": "02", "tag": "Gold Plated", "name": "Gold-Plated Silver" } },
        { "type": "material", "settings": { "number": "03", "tag": "Silver Alloy", "name": "Gold-Plated Alloy" } }
      ]
    }
  ]
}
{% endschema %}
