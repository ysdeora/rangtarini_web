<style>
  .rt-craft { background: var(--rt-ink); color: var(--rt-paper); border-bottom: 1px solid var(--rt-ink); }

  /* ── Cinematic media ── */
  .rt-craft__media { position: relative; height: clamp(420px, 78vh, 760px); overflow: hidden; }
  .rt-craft__plx { position: absolute; inset: -8% 0; will-change: transform; }
  .rt-craft__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
  .rt-craft__scrim { position: absolute; inset: 0; z-index: 1; pointer-events: none; background: linear-gradient(to top, rgba(5,4,2,0.9), rgba(5,4,2,0.1) 55%); }
  .rt-craft__deva-tr { position: absolute; right: var(--rt-pad); top: 24px; z-index: 2; font-family: var(--rt-font-deva); font-size: 24px; font-weight: 600; color: var(--rt-gold); }
  .rt-craft__title { position: absolute; left: 0; bottom: 0; z-index: 2; padding: 0 var(--rt-pad) clamp(28px, 4vw, 52px); }
  .rt-craft__eyebrow { font-family: var(--rt-font-grotesk); font-size: 10px; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase; color: var(--rt-gold); }
  .rt-craft__headline {
    font-family: var(--rt-font-grotesk); font-size: clamp(40px, 7vw, 120px); font-weight: 900;
    letter-spacing: -0.04em; text-transform: uppercase; line-height: 0.9; color: var(--rt-paper); margin: 12px 0 0; max-width: 14ch;
  }
  .rt-craft__headline em { font-style: normal; color: var(--rt-gold); }

  /* ── Counter stats ── */
  .rt-craft__stats { display: grid; grid-template-columns: repeat(3, 1fr); border-top: 1px solid var(--rt-line-paper); }
  .rt-craft__stat { padding: clamp(28px, 4vw, 48px) var(--rt-pad); border-right: 1px solid var(--rt-line-paper); }
  .rt-craft__stat:last-child { border-right: none; }
  .rt-craft__big { font-family: var(--rt-font-grotesk); font-weight: 900; font-size: clamp(40px, 5vw, 76px); letter-spacing: -0.03em; line-height: 1; font-variant-numeric: tabular-nums; }
  .rt-craft__big sub { font-size: 0.32em; vertical-align: baseline; letter-spacing: 0.1em; margin-left: 4px; font-weight: 600; bottom: 0; }
  .rt-craft__cap { margin: 12px 0 0; font-family: var(--rt-font-grotesk); font-size: 10px; letter-spacing: 0.26em; text-transform: uppercase; opacity: 0.6; }

  /* ── Foot ── */
  .rt-craft__foot { display: flex; justify-content: space-between; align-items: center; gap: 20px; padding: 22px var(--rt-pad); border-top: 1px solid var(--rt-line-paper); }
  .rt-craft__foot p { margin: 0; max-width: 620px; font-family: var(--rt-font-grotesk); font-size: 13.5px; line-height: 1.75; opacity: 0.8; text-wrap: pretty; }
  .rt-craft__story {
    display: inline-flex; align-items: center; gap: 12px; white-space: nowrap;
    padding: 15px 26px; border: 1px solid var(--rt-paper); color: var(--rt-paper); text-decoration: none;
    font-family: var(--rt-font-grotesk); font-size: 11px; font-weight: 600; letter-spacing: 0.24em; text-transform: uppercase;
    transition: background 0.3s var(--rt-ez), color 0.3s var(--rt-ez), border-color 0.3s var(--rt-ez);
  }
  .rt-craft__story:hover { background: var(--rt-gold); color: var(--rt-ink); border-color: var(--rt-gold); }
  .rt-craft__story .arr { transition: transform 0.3s var(--rt-ez); }
  .rt-craft__story:hover .arr { transform: translateX(5px); }

  @media (max-width: 740px) {
    .rt-craft__media { height: clamp(280px, 50vh, 400px); }
    .rt-craft__stats { grid-template-columns: repeat(3, 1fr); }
    .rt-craft__stat { padding: 18px 8px; text-align: center; }
    .rt-craft__big { font-size: clamp(24px, 7.5vw, 38px); }
    .rt-craft__cap { margin-top: 6px; font-size: 8px; letter-spacing: 0.12em; }
    .rt-craft__foot { flex-direction: column; align-items: flex-start; gap: 14px; }
    .rt-craft__foot p { font-size: 12.5px; }
    .rt-craft__story { width: 100%; justify-content: center; }
  }
  @media (prefers-reduced-motion: reduce) { .rt-craft__plx { inset: 0; transform: none !important; } }
</style>

<section class="rt-craft">

  <div class="rt-craft__media">
    <div class="rt-craft__plx" data-craft-plx>
      {%- if section.settings.image != blank -%}
        <img class="rt-craft__bg"
          src="{{ section.settings.image | image_url: width: 1600 }}"
          srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1200 }} 1200w, {{ section.settings.image | image_url: width: 1600 }} 1600w, {{ section.settings.image | image_url: width: 2200 }} 2200w"
          sizes="100vw"
          alt="{{ section.settings.image_alt | default: 'Rangtarini karkhana' | escape }}"
          loading="lazy" decoding="async">
      {%- else -%}
        <img class="rt-craft__bg" src="https://cdn.shopify.com/s/files/1/0955/2301/2971/files/worker_poster.jpg?v=1776532899" alt="Rangtarini karkhana" loading="lazy">
      {%- endif -%}
    </div>
    <div class="rt-craft__scrim"></div>
    {%- if section.settings.deva != blank -%}<span class="rt-craft__deva-tr">{{ section.settings.deva }}</span>{%- endif -%}
    <div class="rt-craft__title">
      {%- if section.settings.eyebrow != blank -%}<span class="rt-craft__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="rt-craft__headline rt-mask"><span>{{ section.settings.headline | default: 'Made by hand. Made to outlive.' }}</span></h2>
    </div>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="rt-craft__stats">
      {%- for block in section.blocks -%}
        <div class="rt-craft__stat" {{ block.shopify_attributes }} data-rt-reveal style="--rt-reveal-delay: {{ forloop.index0 | times: 120 }}ms">
          <div class="rt-craft__big">
            <span class="rt-craft__count" data-to="{{ block.settings.value | escape }}">{{ block.settings.value }}</span>{%- if block.settings.unit != blank -%}<sub>{{ block.settings.unit }}</sub>{%- endif -%}
          </div>
          <p class="rt-craft__cap">{{ block.settings.label | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="rt-craft__foot">
    {%- if section.settings.foot_text != blank -%}<p>{{ section.settings.foot_text }}</p>{%- endif -%}
    <a href="{{ section.settings.story_url | default: '/pages/about-us' }}" class="rt-craft__story">
      {{ section.settings.story_label | default: 'Read the craft story' }} <span class="arr" aria-hidden="true">→</span>
    </a>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* Count-up */
    var counters = root.querySelectorAll('.rt-craft__count');
    function fmt(n, dec) { return dec > 0 ? n.toFixed(dec) : Math.round(n).toString(); }
    function run(el) {
      var raw = el.getAttribute('data-to') || '0';
      var target = parseFloat(raw);
      if (isNaN(target)) return;
      var dec = (raw.split('.')[1] || '').length;
      if (reduce) { el.textContent = fmt(target, dec); return; }
      var start = null, dur = 1300;
      function tick(ts) {
        if (start === null) start = ts;
        var p = Math.min((ts - start) / dur, 1);
        var eased = 1 - Math.pow(1 - p, 3);
        el.textContent = fmt(target * eased, dec);
        if (p < 1) requestAnimationFrame(tick); else el.textContent = fmt(target, dec);
      }
      requestAnimationFrame(tick);
    }
    if ('IntersectionObserver' in window && !reduce) {
      var io = new IntersectionObserver(function (entries, obs) {
        entries.forEach(function (e) { if (e.isIntersecting) { run(e.target); obs.unobserve(e.target); } });
      }, { threshold: 0.5 });
      counters.forEach(function (c) { io.observe(c); });
    } else {
      counters.forEach(run);
    }

    /* Light parallax on the media */
    var plx = root.querySelector('[data-craft-plx]');
    if (plx && !reduce) {
      var ticking = false;
      window.addEventListener('scroll', function () {
        if (ticking) return; ticking = true;
        requestAnimationFrame(function () {
          var r = plx.getBoundingClientRect();
          var vh = window.innerHeight || 1;
          var prog = (r.top + r.height / 2 - vh / 2) / vh; /* -~1..1 */
          plx.style.transform = 'translateY(' + (prog * -36) + 'px)';
          ticking = false;
        });
      }, { passive: true });
    }
  }());
</script>

{% schema %}
{
  "name": "Craft Story",
  "class": "rt-craft-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image (karkhana / craft)" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "04 — The workshop" },
    { "type": "text", "id": "headline", "label": "Headline", "info": "Wrap a word in <em></em> to gild it.", "default": "Made by hand. Made to <em>outlive.</em>" },
    { "type": "text", "id": "deva", "label": "Devanagari accent", "default": "रंगतारिणी" },
    { "type": "textarea", "id": "foot_text", "label": "Footer paragraph", "default": "No two pieces leave the bench identical — the stone decides the setting, the hand decides the line. We hold the techniques steady and let the forms move with you." },
    { "type": "url", "id": "story_url", "label": "Story link" },
    { "type": "text", "id": "story_label", "label": "Story link label", "default": "Read the craft story" }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "value", "label": "Value", "info": "Number that counts up (decimals allowed, e.g. 92.5).", "default": "72" },
        { "type": "text", "id": "unit", "label": "Unit", "default": "HRS" },
        { "type": "text", "id": "label", "label": "Caption", "default": "Bench time per jadau set" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Craft Story",
      "blocks": [
        { "type": "stat", "settings": { "value": "72", "unit": "HRS", "label": "Bench time per jadau set" } },
        { "type": "stat", "settings": { "value": "3", "unit": "GEN", "label": "Generations of karigars" } },
        { "type": "stat", "settings": { "value": "92.5", "unit": "STG", "label": "Hallmarked sterling standard" } }
      ]
    }
  ]
}
{% endschema %}
