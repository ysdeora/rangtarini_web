      </a>
    </div>
  </div>

  <div class="rt-ft__rule"></div>

  <nav class="rt-ft__nav" aria-label="Footer">
    <a href="/collections/all" class="rt-ft__nav-link">Shop</a>
    <a href="/pages/about-us" class="rt-ft__nav-link">About</a>
    <a href="/pages/returns-exchange" class="rt-ft__nav-link">Returns</a>
    <a href="/pages/contact" class="rt-ft__nav-link">Contact</a>
    <a href="/policies/privacy-policy" class="rt-ft__nav-link">Privacy Policy</a>
    <a href="/pages/1-year-warranty" class="rt-ft__nav-link">Warranty</a>
    <a href="/blogs/jewellery-guide" class="rt-ft__nav-link">Journal</a>
  </nav>

  <div class="rt-ft__bottom">
    <span class="rt-ft__copy">© {{ 'now' | date: '%Y' }} Rangtarini · All rights reserved</span>
    <span class="rt-ft__hallmark">BIS Hallmarked · 925 Silver · Made in India</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "rt-footer-section",
  "presets": [{"name": "Footer"}],
  "settings": [
    {
      "type": "text",
      "id": "wordmark",
      "label": "Brand wordmark",
      "default": "Rangtarini"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline below Devanagari",
      "default": "Handcrafted in India · Since MMXXI"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp number (with country code, no +)",
      "default": "919251110762"
    }
  ]
}
{% endschema %}
