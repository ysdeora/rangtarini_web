<style>
  .rt-ft {
    background: var(--rt-ink);
    color: var(--rt-paper);
    border-top: 1px solid rgba(239,236,228,0.1);
  }

  /* ── Giant wordmark ── */
  .rt-ft__hero {
    padding: 48px 0 0;
    text-align: center;
    border-bottom: 1px solid rgba(239,236,228,0.1);
    overflow: hidden;
  }
  .rt-ft__wordmark {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(56px, 13vw, 192px);
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--rt-paper);
    line-height: 0.88;
    margin: 0;
    text-decoration: none;
    display: block;
    white-space: nowrap;
  }
  .rt-ft__deva {
    font-family: var(--rt-font-deva);
    font-size: clamp(20px, 2.4vw, 34px);
    font-weight: 600;
    color: var(--rt-gold);
    display: block;
    margin: 16px 0 40px;
    letter-spacing: 0;
  }

  /* ── 5-column grid ── */
  .rt-ft__cols {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
  }
  .rt-ft__col {
    padding: 44px 28px;
    border-right: 1px solid rgba(239,236,228,0.1);
  }
  .rt-ft__col:last-child { border-right: none; }

  .rt-ft__col-heading {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--rt-gold);
    display: block;
    margin-bottom: 24px;
  }
  .rt-ft__desc {
    font-family: var(--rt-font-grotesk);
    font-size: 13px;
    line-height: 1.65;
    color: var(--rt-paper);
    opacity: 0.7;
    margin: 0 0 24px;
  }

  /* Social buttons */
  .rt-ft__social {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: flex-start;
  }
  .rt-ft__social-btn {
    display: inline-block;
    padding: 8px 18px;
    border: 1px solid rgba(239,236,228,0.3);
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-paper);
    text-decoration: none;
    transition: border-color 200ms, opacity 200ms;
  }
  .rt-ft__social-btn:hover {
    border-color: var(--rt-paper);
    opacity: 0.85;
  }

  /* Nav links */
  .rt-ft__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .rt-ft__link {
    font-family: var(--rt-font-grotesk);
    font-size: 14px;
    font-weight: 400;
    color: var(--rt-paper);
    opacity: 0.75;
    text-decoration: none;
    transition: opacity 200ms;
    display: block;
  }
  .rt-ft__link:hover { opacity: 1; }

  /* ── Bottom bar ── */
  .rt-ft__bottom {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
    border-top: 1px solid rgba(239,236,228,0.1);
    padding: 18px 28px;
  }
  .rt-ft__copy {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rt-paper);
    opacity: 0.7;
  }
  .rt-ft__payments {
    display: flex;
    gap: 20px;
    align-items: center;
    justify-content: center;
  }
  .rt-ft__payment {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--rt-paper);
    opacity: 0.4;
  }
  .rt-ft__origin {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rt-paper);
    opacity: 0.38;
    text-align: right;
  }

  @media (max-width: 990px) {
    .rt-ft__cols { grid-template-columns: repeat(3, 1fr); }
    .rt-ft__col:nth-child(3) { border-right: none; }
    .rt-ft__col:nth-child(4),
    .rt-ft__col:nth-child(5) { border-top: 1px solid rgba(239,236,228,0.1); }
    .rt-ft__col:nth-child(5) { border-right: none; }
  }
  @media (max-width: 749px) {
    .rt-ft__cols { grid-template-columns: 1fr 1fr; }
    .rt-ft__col { padding: 28px 20px; }
    .rt-ft__col:nth-child(odd)  { border-right: 1px solid rgba(239,236,228,0.1); }
    .rt-ft__col:nth-child(even) { border-right: none; }
    .rt-ft__col:nth-child(n+3)  { border-top: 1px solid rgba(239,236,228,0.1); }
    .rt-ft__bottom {
      grid-template-columns: 1fr;
      padding: 20px;
      gap: 12px;
    }
    .rt-ft__payments { justify-content: flex-start; }
    .rt-ft__origin   { text-align: left; }
  }
</style>

{%- comment %} Helper macro: render a nav column from a linklist, falling back to a static list {%- endcomment %}

<footer class="rt-ft" aria-label="Site footer">

  <div class="rt-ft__hero">
    <a href="/" class="rt-ft__wordmark">{{ section.settings.wordmark | default: 'Rangtarini' }}</a>
    <span class="rt-ft__deva">रंगतारिणी</span>
  </div>

  <div class="rt-ft__cols">

    <!-- Studio -->
    <div class="rt-ft__col">
      <span class="rt-ft__col-heading">{{ section.settings.heading_studio | default: 'Studio' }}</span>
      <p class="rt-ft__desc">{{ section.settings.studio_desc | default: 'Handmade goldplated and silver 925 jewellery. Made in Jaipur.' }}</p>
      <div class="rt-ft__social">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="rt-ft__social-btn">Instagram</a>
        {%- endif -%}
        {%- if section.settings.whatsapp_number != blank -%}
          <a href="https://wa.me/{{ section.settings.whatsapp_number }}" target="_blank" rel="noopener" class="rt-ft__social-btn">WhatsApp</a>
        {%- endif -%}
      </div>
    </div>

    <!-- Shop -->
    <div class="rt-ft__col">
      <span class="rt-ft__col-heading">{{ section.settings.heading_shop | default: 'Shop' }}</span>
      <ul class="rt-ft__links">
        {%- assign shop_links = linklists[section.settings.shop_menu].links -%}
        {%- if shop_links.size > 0 -%}
          {%- for link in shop_links -%}
            <li><a href="{{ link.url }}" class="rt-ft__link">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/collections/necklaces-sets"       class="rt-ft__link">Necklaces &amp; Sets</a></li>
          <li><a href="/collections/earrings"             class="rt-ft__link">Earrings</a></li>
          <li><a href="/collections/rings"                class="rt-ft__link">Rings</a></li>
          <li><a href="/collections/maang-tikka-rakhdi"   class="rt-ft__link">Maang Tikka</a></li>
          <li><a href="/collections/payal-anklets"        class="rt-ft__link">Payal</a></li>
          <li><a href="/collections/bangles-bracelets"    class="rt-ft__link">Bangles</a></li>
        {%- endif -%}
      </ul>
    </div>

    <!-- Edits -->
    <div class="rt-ft__col">
      <span class="rt-ft__col-heading">{{ section.settings.heading_edits | default: 'Edits' }}</span>
      <ul class="rt-ft__links">
        {%- assign edits_links = linklists[section.settings.edits_menu].links -%}
        {%- if edits_links.size > 0 -%}
          {%- for link in edits_links -%}
            <li><a href="{{ link.url }}" class="rt-ft__link">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/collections/bridal"   class="rt-ft__link">SS26 / Bridal</a></li>
          <li><a href="/collections/festive"  class="rt-ft__link">Festive 2026</a></li>
          <li><a href="/collections/everyday" class="rt-ft__link">Everyday silver</a></li>
          <li><a href="/collections/all"      class="rt-ft__link">Under &#8377;5,000</a></li>
          <li><a href="/collections/gifting"  class="rt-ft__link">Gifting</a></li>
        {%- endif -%}
      </ul>
    </div>

    <!-- Help -->
    <div class="rt-ft__col">
      <span class="rt-ft__col-heading">{{ section.settings.heading_help | default: 'Help' }}</span>
      <ul class="rt-ft__links">
        {%- assign help_links = linklists[section.settings.help_menu].links -%}
        {%- if help_links.size > 0 -%}
          {%- for link in help_links -%}
            <li><a href="{{ link.url }}" class="rt-ft__link">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/pages/returns-exchange" class="rt-ft__link">Shipping &amp; returns</a></li>
          <li><a href="/pages/care-guide"       class="rt-ft__link">Care guide</a></li>
          <li><a href="/pages/contact"          class="rt-ft__link">Track order</a></li>
          <li><a href="/pages/contact"          class="rt-ft__link">Contact</a></li>
        {%- endif -%}
      </ul>
    </div>

    <!-- About -->
    <div class="rt-ft__col">
      <span class="rt-ft__col-heading">{{ section.settings.heading_about | default: 'About' }}</span>
      <ul class="rt-ft__links">
        {%- assign about_links = linklists[section.settings.about_menu].links -%}
        {%- if about_links.size > 0 -%}
          {%- for link in about_links -%}
            <li><a href="{{ link.url }}" class="rt-ft__link">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/pages/about-us"         class="rt-ft__link">Our story</a></li>
          <li><a href="/blogs/jewellery-guide"  class="rt-ft__link">Journal</a></li>
        {%- endif -%}
      </ul>
    </div>

  </div>

  <div class="rt-ft__bottom">
    <span class="rt-ft__copy">&#169; {{ 'now' | date: '%Y' }} {{ section.settings.wordmark | default: 'Rangtarini' }} &middot; {{ section.settings.email | default: 'info@rangtarini.com' }}</span>
    <div class="rt-ft__payments">
      <span class="rt-ft__payment">Visa</span>
      <span class="rt-ft__payment">Mastercard</span>
      <span class="rt-ft__payment">UPI</span>
      <span class="rt-ft__payment">RuPay</span>
    </div>
    <span class="rt-ft__origin">{{ section.settings.origin_text | default: 'Made in Jaipur &middot; Shipped from Mumbai' }}</span>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "class": "rt-footer-section",
  "settings": [
    {
      "type": "text",
      "id": "wordmark",
      "label": "Brand wordmark",
      "default": "Rangtarini"
    },
    {
      "type": "textarea",
      "id": "studio_desc",
      "label": "Studio description",
      "default": "Handmade goldplated and silver 925 jewellery. Made in Jaipur."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp number (with country code, no +)",
      "default": "919251110762"
    },
    {
      "type": "header",
      "content": "Column headings"
    },
    {
      "type": "text",
      "id": "heading_studio",
      "label": "Studio column heading",
      "default": "Studio"
    },
    {
      "type": "text",
      "id": "heading_shop",
      "label": "Shop column heading",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "heading_edits",
      "label": "Edits column heading",
      "default": "Edits"
    },
    {
      "type": "text",
      "id": "heading_help",
      "label": "Help column heading",
      "default": "Help"
    },
    {
      "type": "text",
      "id": "heading_about",
      "label": "About column heading",
      "default": "About"
    },
    {
      "type": "header",
      "content": "Navigation menus",
      "info": "Create menus in Online Store > Navigation and assign them here. Falls back to default links if left empty."
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop column menu"
    },
    {
      "type": "link_list",
      "id": "edits_menu",
      "label": "Edits column menu"
    },
    {
      "type": "link_list",
      "id": "help_menu",
      "label": "Help column menu"
    },
    {
      "type": "link_list",
      "id": "about_menu",
      "label": "About column menu"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "info@rangtarini.com"
    },
    {
      "type": "text",
      "id": "origin_text",
      "label": "Origin / shipping line",
      "default": "Made in Jaipur · Shipped from Mumbai"
    }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
