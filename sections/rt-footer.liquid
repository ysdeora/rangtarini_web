<style>
  .rt-ft {
    background: var(--rt-ink);
    color: var(--rt-paper);
    padding: 72px 40px 40px;
    border-top: 1px solid rgba(239,236,228,0.1);
  }
  .rt-ft__top {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 40px;
    margin-bottom: 56px;
  }
  .rt-ft__wordmark {
    font-family: var(--rt-font-grotesk);
    font-size: clamp(36px, 5vw, 72px);
    font-weight: 900;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--rt-paper);
    line-height: 0.9;
    margin: 0 0 10px;
    text-decoration: none;
    display: block;
  }
  .rt-ft__deva {
    font-family: var(--rt-font-deva);
    font-size: 20px;
    font-weight: 600;
    color: var(--rt-gold);
    display: block;
    margin-bottom: 20px;
  }
  .rt-ft__tagline {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rt-paper);
    opacity: 0.4;
    display: block;
  }
  .rt-ft__social {
    display: flex;
    gap: 20px;
    align-items: center;
    padding-top: 6px;
  }
  .rt-ft__social-link {
    color: var(--rt-paper);
    opacity: 0.55;
    transition: opacity 220ms;
    display: inline-flex;
    align-items: center;
  }
  .rt-ft__social-link:hover { opacity: 1; }
  .rt-ft__social-link svg {
    width: 22px;
    height: 22px;
    fill: currentColor;
    display: block;
  }
  .rt-ft__rule {
    height: 1px;
    background: var(--rt-paper);
    opacity: 0.1;
    margin-bottom: 40px;
  }
  .rt-ft__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 40px;
    margin-bottom: 48px;
  }
  .rt-ft__nav-link {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-paper);
    opacity: 0.5;
    text-decoration: none;
    transition: opacity 220ms;
  }
  .rt-ft__nav-link:hover { opacity: 1; }
  .rt-ft__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    border-top: 1px solid rgba(239,236,228,0.1);
    padding-top: 24px;
  }
  .rt-ft__copy {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--rt-paper);
    opacity: 0.3;
  }
  .rt-ft__hallmark {
    font-family: var(--rt-font-grotesk);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--rt-gold);
    opacity: 0.65;
  }

  @media (max-width: 749px) {
    .rt-ft { padding: 48px 20px 32px; }
    .rt-ft__top {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-bottom: 40px;
    }
    .rt-ft__wordmark { font-size: 40px; }
    .rt-ft__nav { gap: 8px 28px; }
    .rt-ft__bottom { flex-direction: column; align-items: flex-start; gap: 10px; }
  }
</style>

<footer class="rt-ft" aria-label="Site footer">
  <div class="rt-ft__top">
    <div>
      <a href="/" class="rt-ft__wordmark">{{ section.settings.wordmark | default: 'Rangtarini' }}</a>
      <span class="rt-ft__deva">रंगतारिणी</span>
      <span class="rt-ft__tagline">{{ section.settings.tagline | default: 'Handcrafted in India · Since MMXXI' }}</span>
    </div>
    <div class="rt-ft__social">
