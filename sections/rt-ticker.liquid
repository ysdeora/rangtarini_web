<style>
  .rt-ticker {
    background: var(--rt-ink);
    color: var(--rt-paper);
    overflow: hidden;
    padding: 5px 0;
    border-bottom: 1px solid var(--rt-ink);
  }
  @keyframes rt-ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }
  .rt-ticker__track {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    animation: rt-ticker-scroll {{ section.settings.speed }}s linear infinite;
  }
  .rt-ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 42px;
    padding: 0 21px;
  }
  .rt-ticker__dia {
    width: 4px; height: 4px;
    background: var(--rt-gold);
    transform: rotate(45deg);
    flex: none;
  }
  .rt-ticker__en {
    font-family: var(--rt-font-grotesk);
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--rt-paper);
    opacity: 0.85;
    line-height: 1;
  }
  .rt-ticker__dv {
    font-family: var(--rt-font-deva);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0;
    color: var(--rt-gold);
    opacity: 0.95;
    line-height: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .rt-ticker__track { animation: none; }
  }
</style>

{%- comment -%} Render blocks three times for seamless infinite scroll {%- endcomment -%}
<div class="rt-ticker" aria-hidden="true">
  <div class="rt-ticker__track">
    {%- for _i in (1..3) -%}
      {%- for block in section.blocks -%}
        <span class="rt-ticker__item" {{ block.shopify_attributes }}>
          {%- if block.type == 'deva' -%}
            <span class="rt-ticker__dv">{{ block.settings.text | default: 'रंगतारिणी' }}</span>
          {%- else -%}
            <span class="rt-ticker__en">{{ block.settings.text | escape }}</span>
          {%- endif -%}
          <span class="rt-ticker__dia" aria-hidden="true"></span>
        </span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Ticker Bar",
  "class": "rt-ticker-section",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "s",
      "default": 60,
      "info": "Higher = slower"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message",
          "default": "Free Shipping — Pan-India"
        }
      ]
    },
    {
      "type": "deva",
      "name": "Devanagari separator",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "रंगतारिणी",
          "info": "Displayed in gold Devanagari style"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ticker Bar",
      "blocks": [
        { "type": "text", "settings": { "text": "Free Shipping — Pan-India" } },
        { "type": "deva", "settings": { "text": "रंगतारिणी" } },
        { "type": "text", "settings": { "text": "BIS Hallmarked — 925 Silver" } },
        { "type": "text", "settings": { "text": "7-Day Exchange" } },
        { "type": "deva", "settings": { "text": "रंगतारिणी" } },
        { "type": "text", "settings": { "text": "Lifetime Polish & Resizing" } },
        { "type": "deva", "settings": { "text": "रंगतारिणी" } }
      ]
    }
  ]
}
{% endschema %}
