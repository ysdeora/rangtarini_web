{"sections":{"custom_liquid_MfEhdt":{"type":"custom-liquid","disabled":true,"name":"About Us Updated","settings":{"custom_liquid":"<style>\n@import url('https:\/\/fonts.googleapis.com\/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap');\n\n.rt-about * { box-sizing: border-box; margin: 0; padding: 0; }\n\n.rt-about {\n  font-family: 'Jost', sans-serif;\n  font-weight: 300;\n  color: #f5f0e8;\n  background: #0a0a0a;\n  -webkit-font-smoothing: antialiased;\n}\n\n.rt-about a { text-decoration: none; }\n\n\/* ── Shared ── *\/\n.rt-label {\n  font-family: 'Jost', sans-serif;\n  font-size: 1.8rem;\n  letter-spacing: 0.4em;\n  text-transform: uppercase;\n  color: #c9a84c;\n  display: block;\n  margin-bottom: 1.1rem;\n}\n\n.rt-rule {\n  width: 2.5rem;\n  height: 1px;\n  background: #c9a84c;\n  margin-bottom: 2rem;\n}\n\n\/* ── Reveal ── *\/\n.rt-reveal {\n  opacity: 0;\n  transform: translateY(20px);\n  transition: opacity 0.7s ease, transform 0.7s ease;\n}\n.rt-reveal.rt-visible { opacity: 1; transform: translateY(0); }\n.rt-d1 { transition-delay: 0.1s; }\n.rt-d2 { transition-delay: 0.2s; }\n.rt-d3 { transition-delay: 0.3s; }\n\n\n\/* ══════════════════════════\n   1. HERO\n══════════════════════════ *\/\n.rt-hero {\n  background: #0a0a0a;\n  padding: 4.5rem 4rem 4rem;\n  border-bottom: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-hero__headline {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(3.8rem, 7vw, 7rem);\n  font-weight: 300;\n  line-height: 1.08;\n  color: #f5f0e8;\n  margin-bottom: 2rem;\n}\n\n.rt-hero__headline em {\n  font-style: italic;\n  color: #e8d5a3;\n}\n\n.rt-hero__sub {\n  font-size: 1.4rem;\n  line-height: 1.9;\n  color: #aaa;\n  max-width: 52ch;\n}\n\n\n\/* ══════════════════════════\n   2. FOUNDER\n══════════════════════════ *\/\n.rt-founder {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  border-bottom: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-founder__img-col {\n  background: #141414;\n  position: relative;\n  min-height: 480px;\n  overflow: hidden;\n}\n\n.rt-founder__img-col img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  object-position: top center;\n  display: block;\n}\n\n.rt-founder__img-col:not(:has(img)) {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n.rt-founder__img-col:not(:has(img))::after {\n  content: 'PHOTO';\n  font-size: 0.6rem;\n  letter-spacing: 0.4em;\n  color: rgba(201,168,76,0.2);\n}\n\n.rt-founder__copy {\n  background: #111;\n  padding: 4rem 3.5rem;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n\n.rt-founder__headline {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(2.8rem, 4vw, 4.2rem);\n  font-weight: 300;\n  line-height: 1.15;\n  color: #f5f0e8;\n  margin-bottom: 2rem;\n}\n\n.rt-founder__headline em {\n  font-style: italic;\n  color: #e8d5a3;\n}\n\n.rt-founder__body p {\n  font-size: 1.3rem;\n  line-height: 1.9;\n  color: #aaa;\n  margin-bottom: 1.35rem;\n}\n\n.rt-founder__body p:last-child { margin-bottom: 0; }\n\n.rt-founder__body strong {\n  color: #f5f0e8;\n  font-weight: 400;\n}\n\n\n\/* ══════════════════════════\n   3. MISSION PULL QUOTE\n══════════════════════════ *\/\n.rt-mission {\n  padding: 4.5rem 4rem;\n  background: #0d0d0d;\n  border-bottom: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-mission__quote {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(2.2rem, 3.5vw, 3.6rem);\n  font-weight: 300;\n  font-style: italic;\n  line-height: 1.4;\n  color: #f5f0e8;\n  max-width: 28ch;\n  margin-bottom: 2.5rem;\n  position: relative;\n  padding-left: 2rem;\n  border-left: 2px solid #c9a84c;\n}\n\n.rt-mission__body p {\n  font-size: 1.3rem;\n  line-height: 1.9;\n  color: #aaa;\n  max-width: 62ch;\n  margin-bottom: 1.2rem;\n}\n\n.rt-mission__body p:last-child { margin-bottom: 0; }\n\n.rt-mission__body em {\n  color: #f5f0e8;\n  font-style: normal;\n}\n\n\n\/* ══════════════════════════\n   4. RAJASTHAN\n══════════════════════════ *\/\n.rt-city {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  border-bottom: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-city__copy {\n  padding: 4rem 3.5rem;\n  background: #111;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  border-right: 1px solid rgba(201,168,76,0.1);\n}\n\n.rt-city__headline {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(2.6rem, 3.5vw, 3.8rem);\n  font-weight: 300;\n  line-height: 1.15;\n  color: #f5f0e8;\n  margin-bottom: 2rem;\n}\n\n.rt-city__headline em {\n  font-style: italic;\n  color: #e8d5a3;\n}\n\n.rt-city__body p {\n  font-size: 1.3rem;\n  line-height: 1.9;\n  color: #aaa;\n  margin-bottom: 1.2rem;\n}\n.rt-city__body p:last-child { margin-bottom: 0; }\n\n.rt-city__img-col {\n  background: #141414;\n  position: relative;\n  overflow: hidden;\n  min-height: 420px;\n}\n\n.rt-city__img-col img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n  transition: transform 0.8s ease;\n}\n\n.rt-city__img-col:hover img { transform: scale(1.04); }\n\n.rt-city__img-col:not(:has(img))::after {\n  content: 'RAJASTHAN';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%,-50%);\n  font-size: 0.6rem;\n  letter-spacing: 0.4em;\n  color: rgba(201,168,76,0.2);\n}\n\n\n\/* ══════════════════════════\n   5. MATERIALS\n══════════════════════════ *\/\n.rt-materials {\n  background: #0a0a0a;\n  padding: 4.5rem 4rem;\n  border-bottom: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-materials__header {\n  margin-bottom: 2.75rem;\n}\n\n.rt-materials__headline {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(2.6rem, 3.5vw, 3.6rem);\n  font-weight: 300;\n  color: #f5f0e8;\n  margin-bottom: 0.9rem;\n}\n\n.rt-materials__sub {\n  font-size: 1.25rem;\n  color: #888;\n  line-height: 1.75;\n  max-width: 55ch;\n}\n\n.rt-mat-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  border: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-mat-item {\n  padding: 3rem 2.5rem;\n  border-right: 1px solid rgba(201,168,76,0.12);\n  transition: background 0.3s ease;\n}\n\n.rt-mat-item:last-child { border-right: none; }\n.rt-mat-item:hover { background: rgba(201,168,76,0.03); }\n\n.rt-mat-num {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 2.8rem;\n  font-weight: 300;\n  color:#D3D3D3;\n  line-height: 1;\n  margin-bottom: 1.1rem;\n}\n\n.rt-mat-tag {\n  display: inline-block;\n  font-size: 0.85rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #c9a84c;\n  border: 1px solid rgba(201,168,76,0.3);\n  padding: 0.3rem 0.85rem;\n  margin-bottom: 0.9rem;\n}\n\n.rt-mat-name {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 2.1rem;\n  font-weight: 400;\n  color: #f5f0e8;\n  margin-bottom: 0.9rem;\n}\n\n.rt-mat-desc {\n  font-size: 1.15rem;\n  line-height: 1.8;\n  color: #888;\n}\n\n\n\/* ══════════════════════════\n   6. CUSTOM + CLOSING\n══════════════════════════ *\/\n.rt-closing {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  border-bottom: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-custom {\n  padding: 4rem 3.5rem;\n  background: #111;\n  border-right: 1px solid rgba(201,168,76,0.1);\n}\n\n.rt-custom__headline {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(2.6rem, 3.2vw, 3.4rem);\n  font-weight: 300;\n  color: #f5f0e8;\n  line-height: 1.15;\n  margin-bottom: 1.5rem;\n}\n\n.rt-custom__headline em {\n  font-style: italic;\n  color: #e8d5a3;\n}\n\n.rt-custom__body {\n  font-size: 1.25rem;\n  color: #aaa;\n  line-height: 1.9;\n  margin-bottom: 2.5rem;\n}\n\n.rt-custom__cta {\n  display: inline-block;\n  font-family: 'Jost', sans-serif;\n  font-size: 0.88rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #0a0a0a;\n  background: #c9a84c;\n  padding: 1.1rem 2.5rem;\n  transition: background 0.2s ease;\n}\n\n.rt-custom__cta:hover { background: #e8d5a3; }\n\n.rt-signoff {\n  padding: 4rem 3.5rem;\n  background: #0d0d0d;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n\n.rt-signoff__statement {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(1.9rem, 2.5vw, 2.6rem);\n  font-weight: 300;\n  font-style: italic;\n  line-height: 1.55;\n  color: #f5f0e8;\n  margin-bottom: 2.5rem;\n}\n\n.rt-signoff__name {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 1.5rem;\n  color: #c9a84c;\n  margin-bottom: 0.4rem;\n}\n\n.rt-signoff__title {\n  font-size: 0.88rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #555;\n}\n\n.rt-signoff__shop {\n  display: inline-block;\n  margin-top: 2.5rem;\n  font-size: 0.88rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #f5f0e8;\n  border-bottom: 1px solid #c9a84c;\n  padding-bottom: 0.3rem;\n  transition: color 0.2s ease;\n}\n\n.rt-signoff__shop:hover { color: #c9a84c; }\n\n\n\/* ══════════════════════════\n   MOBILE\n══════════════════════════ *\/\n@media (max-width: 749px) {\n  .rt-hero { padding: 3.5rem 2rem 3rem; }\n\n  .rt-founder { grid-template-columns: 1fr; }\n  .rt-founder__img-col { min-height: 300px; aspect-ratio: 4\/3; }\n  .rt-founder__copy { padding: 3rem 2rem; }\n\n  .rt-mission { padding: 3.5rem 2rem; }\n\n  .rt-city { grid-template-columns: 1fr; }\n  .rt-city__img-col { min-height: 260px; order: -1; border-right: none; }\n  .rt-city__copy { padding: 3rem 2rem; border-right: none; border-top: 1px solid rgba(201,168,76,0.1); }\n\n  .rt-materials { padding: 3.5rem 2rem; }\n  .rt-mat-grid { grid-template-columns: 1fr; }\n  .rt-mat-item { border-right: none; border-bottom: 1px solid rgba(201,168,76,0.12); padding: 2.5rem 1.75rem; }\n  .rt-mat-item:last-child { border-bottom: none; }\n\n  .rt-closing { grid-template-columns: 1fr; }\n  .rt-custom { padding: 3rem 2rem; border-right: none; border-bottom: 1px solid rgba(201,168,76,0.12); }\n  .rt-signoff { padding: 3rem 2rem; }\n}\n<\/style>\n\n\n<div class=\"rt-about\">\n\n  <!-- 1. HERO -->\n  <!-- CHANGED: \"Based in Udaipur.\" → \"Made in Rajasthan.\" -->\n  <div class=\"rt-hero\">\n    <span class=\"rt-label rt-reveal\">About Us<\/span>\n    <div class=\"rt-rule rt-reveal rt-d1\"><\/div>\n    <h1 class=\"rt-hero__headline rt-reveal rt-d2\">\n      Born in Jodhpur.<br>\n      Made in Rajasthan.<br>\n      <em>Worn Everywhere.<\/em>\n    <\/h1>\n    <p class=\"rt-hero__sub rt-reveal rt-d3\">\n      Handcrafted Indian jewelry, rooted in Rajasthan. Regal by design. Yours to wear.\n    <\/p>\n  <\/div>\n\n\n  <!-- 2. FOUNDER — unchanged -->\n  <div class=\"rt-founder\">\n    <div class=\"rt-founder__img-col\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0955\/2301\/2971\/files\/Bhumika_Photo.jpg?v=1774703914\" alt=\"Bhoomika Ranawat\">\n    <\/div>\n    <div class=\"rt-founder__copy\">\n      <span class=\"rt-label rt-reveal\">The Woman Behind It<\/span>\n      <div class=\"rt-rule rt-reveal rt-d1\"><\/div>\n      <h2 class=\"rt-founder__headline rt-reveal rt-d2\">\n        <em>I don't trend-chase.<\/em><br>I curate.\n      <\/h2>\n      <div class=\"rt-founder__body\">\n        <p class=\"rt-reveal rt-d3\">My name is <strong>Bhoomika Ranawat<\/strong>. I grew up in Jodhpur — surrounded by jewelry the way most children are surrounded by toys. At weddings, at temples, at Sunday markets.<\/p>\n        <p class=\"rt-reveal\">Silver anklets. Gold chokers. Jhumkas passed from mother to daughter like quiet heirlooms. I didn't study jewelry. I absorbed it. I learned to read a piece — whether it carries something real, or whether it's just surface.<\/p>\n        <p class=\"rt-reveal\">Every piece at Rangtarini passes one test: <strong>does it feel worthy?<\/strong> Worthy of the craft. Worthy of the woman who will wear it. If it doesn't — it doesn't make the cut.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n\n\n  <!-- 3. MISSION — unchanged -->\n  <div class=\"rt-mission\">\n    <span class=\"rt-label rt-reveal\">Why We Exist<\/span>\n    <blockquote class=\"rt-mission__quote rt-reveal rt-d1\">\n      Fine Indian jewelry has always existed. What hasn't always existed — is access to it.\n    <\/blockquote>\n    <div class=\"rt-mission__body\">\n      <p class=\"rt-reveal rt-d2\">The intricate meenakari work, the kundan settings, the filigree jhumkas — designs with centuries of lineage — out of reach for the very women who grew up loving them. <em>Rangtarini changes that.<\/em><\/p>\n      <p class=\"rt-reveal rt-d3\">By working with 925 sterling silver and gold-plated silver, we bring regal, handcrafted Indian jewelry into everyday life — <em>without asking you to choose between authenticity and affordability.<\/em> <\/p>\n    <\/div>\n  <\/div>\n\n\n  <!-- 4. RAJASTHAN -->\n  <!-- CHANGED: headline + body — removed \"based in Udaipur\", reframed as inspiration\/aesthetic -->\n  <div class=\"rt-city\">\n    <div class=\"rt-city__copy\">\n      <span class=\"rt-label rt-reveal\">Where We Come From<\/span>\n      <div class=\"rt-rule rt-reveal rt-d1\"><\/div>\n      <h2 class=\"rt-city__headline rt-reveal rt-d2\">\n        Rajasthan Is Not<br><em>Just Our Origin.<\/em>\n      <\/h2>\n      <div class=\"rt-city__body\">\n        <p class=\"rt-reveal rt-d3\">Rangtarini is rooted in Rajasthan — its havelis, its lakes, its centuries of craft. A land where jewelry has never been mere decoration. It has always been identity.<\/p>\n        <p class=\"rt-reveal\">That quiet confidence — unhurried, unperformed — is what we hope every Rangtarini piece carries. Not jewelry that demands attention. Jewelry that earns it.<\/p>\n      <\/div>\n    <\/div>\n    <div class=\"rt-city__img-col\">\n      <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0955\/2301\/2971\/files\/Udaipur_photo.jpg?v=1774704183\" alt=\"Rajasthan\">\n    <\/div>\n  <\/div>\n\n\n  <!-- 5. MATERIALS — unchanged -->\n  <div class=\"rt-materials\">\n    <div class=\"rt-materials__header\">\n      <span class=\"rt-label rt-reveal\">What We Make<\/span>\n      <h2 class=\"rt-materials__headline rt-reveal rt-d1\">Three Materials. One Standard.<\/h2>\n      <p class=\"rt-materials__sub rt-reveal rt-d2\">Every piece is handcrafted and selected by hand. What unites them is not material — it is intent.<\/p>\n    <\/div>\n    <div class=\"rt-mat-grid\">\n      <div class=\"rt-mat-item rt-reveal\">\n        <div class=\"rt-mat-num\">01<\/div>\n        <span class=\"rt-mat-tag\">925 Sterling<\/span>\n        <h3 class=\"rt-mat-name\">Pure Silver<\/h3>\n        <p class=\"rt-mat-desc\">Authentic 925 sterling silver, BIS hallmarked. No compromise, no coating. Made to last a lifetime.<\/p>\n      <\/div>\n      <div class=\"rt-mat-item rt-reveal rt-d1\">\n        <div class=\"rt-mat-num\">02<\/div>\n        <span class=\"rt-mat-tag\">Gold Plated<\/span>\n        <h3 class=\"rt-mat-name\">Gold-Plated Silver<\/h3>\n        <p class=\"rt-mat-desc\">The warmth of gold, the integrity of a pure silver base. For everyday luxury and occasion dressing alike.<\/p>\n      <\/div>\n      <div class=\"rt-mat-item rt-reveal rt-d2\">\n        <div class=\"rt-mat-num\">03<\/div>\n        <span class=\"rt-mat-tag\">Silver Alloy<\/span>\n        <h3 class=\"rt-mat-name\">Gold-Plated Alloy<\/h3>\n        <p class=\"rt-mat-desc\">Thoughtfully designed pieces at accessible price points — without sacrificing the Rangtarini standard of design.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n\n\n  <!-- 6. CUSTOM + CLOSING — unchanged -->\n  <div class=\"rt-closing\">\n    <div class=\"rt-custom\">\n      <span class=\"rt-label rt-reveal\">Bespoke<\/span>\n      <div class=\"rt-rule rt-reveal rt-d1\"><\/div>\n      <h2 class=\"rt-custom__headline rt-reveal rt-d2\">\n        Some Stories<br><em>Are Singular.<\/em>\n      <\/h2>\n      <p class=\"rt-custom__body rt-reveal rt-d3\">For the bride with a vision. The daughter recreating her mother's piece. The woman who knows exactly what she wants and hasn't found it yet. One conversation at a time, from concept to creation.<\/p>\n      <a href=\"https:\/\/wa.me\/919251110762?text=Hi%20Rangtarini%2C%20I%27d%20like%20to%20discuss%20a%20custom%20design\" class=\"rt-custom__cta rt-reveal\">Start a Conversation<\/a>\n    <\/div>\n\n    <div class=\"rt-signoff\">\n      <p class=\"rt-signoff__statement rt-reveal\">\n        \"Every piece we add is another step toward making regal Indian jewelry truly everyone's.\"\n      <\/p>\n      <p class=\"rt-signoff__name rt-reveal rt-d1\">Bhoomika Ranawat<\/p>\n      <p class=\"rt-signoff__title rt-reveal rt-d2\">Founder, Rangtarini<\/p>\n      <a href=\"\/collections\/all\" class=\"rt-signoff__shop rt-reveal rt-d3\">Shop the Collection<\/a>\n    <\/div>\n  <\/div>\n\n<\/div>\n\n\n<script>\n(function(){\n  var els = document.querySelectorAll('.rt-reveal');\n  if (!els.length) return;\n  var obs = new IntersectionObserver(function(entries){\n    entries.forEach(function(e){\n      if (e.isIntersecting){\n        e.target.classList.add('rt-visible');\n        obs.unobserve(e.target);\n      }\n    });\n  }, { threshold: 0.1 });\n  els.forEach(function(el){ obs.observe(el); });\n})();\n<\/script>","color_scheme":"","padding_top":0,"padding_bottom":0}},"custom_liquid_DWDAhk":{"type":"custom-liquid","name":"About Us Old","settings":{"custom_liquid":"<style>\n@import url('https:\/\/fonts.googleapis.com\/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap');\n\n.rt-about * { box-sizing: border-box; margin: 0; padding: 0; }\n\n.rt-about {\n  font-family: 'Jost', sans-serif;\n  font-weight: 300;\n  color: #f5f0e8;\n  background: #0a0a0a;\n  -webkit-font-smoothing: antialiased;\n}\n\n.rt-about a { text-decoration: none; }\n\n\/* ── Shared ── *\/\n.rt-label {\n  font-family: 'Jost', sans-serif;\n  font-size: 1.8rem;\n  letter-spacing: 0.4em;\n  text-transform: uppercase;\n  color: #c9a84c;\n  display: block;\n  margin-bottom: 1.1rem;\n}\n\n.rt-rule {\n  width: 2.5rem;\n  height: 1px;\n  background: 