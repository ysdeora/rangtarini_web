ty__img-col {\n  background: #141414;\n  position: relative;\n  overflow: hidden;\n  min-height: 420px;\n}\n\n.rt-city__img-col img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n  transition: transform 0.8s ease;\n}\n\n.rt-city__img-col:hover img { transform: scale(1.04); }\n\n.rt-city__img-col:not(:has(img))::after {\n  content: 'UDAIPUR';\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%,-50%);\n  font-size: 0.6rem;\n  letter-spacing: 0.4em;\n  color: rgba(201,168,76,0.2);\n}\n\n\n\/* ══════════════════════════\n   5. MATERIALS\n══════════════════════════ *\/\n.rt-materials {\n  background: #0a0a0a;\n  padding: 4.5rem 4rem;\n  border-bottom: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-materials__header {\n  margin-bottom: 2.75rem;\n}\n\n.rt-materials__headline {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(2.6rem, 3.5vw, 3.6rem);\n  font-weight: 300;\n  color: #f5f0e8;\n  margin-bottom: 0.9rem;\n}\n\n.rt-materials__sub {\n  font-size: 1.25rem;\n  color: #888;\n  line-height: 1.75;\n  max-width: 55ch;\n}\n\n.rt-mat-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  border: 1px solid rgba(201,168,76,0.12);\n}\n\n.rt-mat-item {\n  padding: 3rem 2.5rem;\n  border-right: 1px solid rgba(201,168,76,0.12);\n  transition: background 0.3s ease;\n}\n\n.rt-mat-item:last-child { border-right: none; }\n.rt-mat-item:hover { background: rgba(201,168,76,0.03); }\n\n.rt-mat-num {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 2.8rem;\n  font-weight: 300;\n  color:#D3D3D3;\n  line-height: 1;\n  margin-bottom: 1.1rem;\n}\n\n.rt-mat-tag {\n  display: inline-block;\n  font-size: 0.85rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #c9a84c;\n  border: 1px solid rgba(201,168,76,0.3);\n  padding: 0.3rem 0.85rem;\n  margin-bottom: 0.9rem;\n}\n\n.rt-mat-name {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 2.1rem;\n  font-weight: 400;\n  color: #f5f