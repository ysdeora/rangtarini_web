{"sections":{"custom_liquid_eCb363":{"type":"custom-liquid","name":"Contact Us","settings":{"custom_liquid":"<style>\n@import url('https:\/\/fonts.googleapis.com\/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap');\n\n.rt-contact * { box-sizing: border-box; margin: 0; padding: 0; }\n\n.rt-contact {\n  font-family: 'Jost', sans-serif;\n  font-weight: 300;\n  color: #f5f0e8;\n  background: #0a0a0a;\n  -webkit-font-smoothing: antialiased;\n  min-height: 80vh;\n}\n\n\/* ── Shared ── *\/\n.rt-contact .rt-label {\n  font-family: 'Jost', sans-serif;\n  font-size: 1.8rem;\n  letter-spacing: 0.4em;\n  text-transform: uppercase;\n  color: #c9a84c;\n  display: block;\n  margin-bottom: 1.1rem;\n}\n\n.rt-contact .rt-rule {\n  width: 2.5rem;\n  height: 1px;\n  background: #c9a84c;\n  margin-bottom: 2rem;\n}\n\n\/* ── Reveal ── *\/\n.rt-contact .rt-reveal {\n  opacity: 0;\n  transform: translateY(20px);\n  transition: opacity 0.7s ease, transform 0.7s ease;\n}\n.rt-contact .rt-reveal.rt-visible { opacity: 1; transform: translateY(0); }\n.rt-contact .rt-d1 { transition-delay: 0.1s; }\n.rt-contact .rt-d2 { transition-delay: 0.2s; }\n.rt-contact .rt-d3 { transition-delay: 0.3s; }\n.rt-contact .rt-d4 { transition-delay: 0.4s; }\n\n\n\/* ══════════════════════════\n   LAYOUT\n══════════════════════════ *\/\n.rt-contact-inner {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  min-height: 80vh;\n  border-top: 1px solid rgba(201,168,76,0.12);\n}\n\n\/* ── Left: Info ── *\/\n.rt-contact-info {\n  padding: 5rem 4rem;\n  background: #0d0d0d;\n  border-right: 1px solid rgba(201,168,76,0.12);\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n}\n\n.rt-contact-info__top {}\n\n.rt-contact__headline {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: clamp(3.5rem, 5.5vw, 6rem);\n  font-weight: 300;\n  line-height: 1.05;\n  color: #f5f0e8;\n  margin-bottom: 2.5rem;\n}\n\n.rt-contact__headline em {\n  font-style: italic;\n  color: #e8d5a3;\n}\n\n.rt-contact__tagline {\n  font-size: 1.6rem;\n  line-height: 1.9;\n  color: #888;\n  max-width: 36ch;\n  margin-bottom: 4rem;\n}\n\n\/* Channel links *\/\n.rt-channels {\n  display: flex;\n  flex-direction: column;\n  gap: 0;\n}\n\n.rt-channel {\n  display: flex;\n  align-items: center;\n  gap: 1.75rem;\n  padding: 2rem 0;\n  border-top: 1px solid rgba(201,168,76,0.1);\n  text-decoration: none;\n  transition: background 0.2s ease;\n}\n\n.rt-channel:last-child {\n  border-bottom: 1px solid rgba(201,168,76,0.1);\n}\n\n.rt-channel__icon {\n  width: 3.2rem;\n  height: 3.2rem;\n  border: 1px solid rgba(201,168,76,0.25);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  transition: border-color 0.2s ease, background 0.2s ease;\n}\n\n.rt-channel__icon svg {\n  width: 1.4rem;\n  height: 1.4rem;\n  fill: #c9a84c;\n  transition: fill 0.2s ease;\n}\n\n.rt-channel:hover .rt-channel__icon {\n  background: rgba(201,168,76,0.06);\n  border-color: #c9a84c;\n}\n\n.rt-channel__label {\n  font-size: 0.9rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #888;\n  margin-bottom: 0.3rem;\n}\n\n.rt-channel__value {\n  font-family: 'Cormorant Garamond', serif;\n  font-size: 1.6rem;\n  font-weight: 300;\n  color: #f5f0e8;\n  transition: color 0.2s ease;\n}\n\n.rt-channel:hover .rt-channel__value {\n  color: #c9a84c;\n}\n\n\/* ── Right: Form ── *\/\n.rt-contact-form {\n  padding: 5rem 4rem;\n  background: #111;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n\n.rt-form-group {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 1.2rem;\n  margin-bottom: 1.2rem;\n}\n\n.rt-form-field {\n  display: flex;\n  flex-direction: column;\n  margin-bottom: 1.2rem;\n}\n\n.rt-form-field--full {\n  grid-column: 1 \/ -1;\n}\n\n.rt-form-field label {\n  font-size: 0.85rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #999;\n  margin-bottom: 0.75rem;\n}\n\n.rt-form-field input,\n.rt-form-field textarea {\n  background: transparent;\n  border: none;\n  border-bottom: 1px solid rgba(201,168,76,0.2);\n  padding: 0.85rem 0;\n  font-family: 'Jost', sans-serif;\n  font-size: 1.5rem;\n  font-weight: 300;\n  color: #f5f0e8;\n  outline: none;\n  transition: border-color 0.2s ease;\n  width: 100%;\n  -webkit-appearance: none;\n  border-radius: 0;\n}\n\n.rt-form-field input::placeholder,\n.rt-form-field textarea::placeholder {\n  color: #666;\n}\n\n.rt-form-field input:focus,\n.rt-form-field textarea:focus {\n  border-bottom-color: #c9a84c;\n}\n\n.rt-form-field textarea {\n  resize: none;\n  height: 7rem;\n  line-height: 1.7;\n}\n\n.rt-form-submit {\n  margin-top: 2.5rem;\n  display: flex;\n  align-items: center;\n  gap: 1.5rem;\n}\n\n.rt-form-submit button {\n  font-family: 'Jost', sans-serif;\n  font-size: 0.88rem;\n  letter-spacing: 0.3em;\n  text-transform: uppercase;\n  color: #0a0a0a;\n  background: #c9a84c;\n  border: none;\n  padding: 1.1rem 3rem;\n  cursor: pointer;\n  transition: background 0.2s ease;\n}\n\n.rt-form-submit button:hover { background: #e8d5a3; }\n\n.rt-form-note {\n  font-size: 1.2rem;\n  color: #777;\n  line-height: 1.6;\n}\n\n\n\/* ══════════════════════════\n   MOBILE\n══════════════════════════ *\/\n@media (max-width: 749px) {\n  .rt-contact-inner {\n    grid-template-columns: 1fr;\n  }\n\n  .rt-contact-info {\n    padding: 3.5rem 2rem;\n    border-right: none;\n    border-bottom: 1px solid rgba(201,168,76,0.12);\n  }\n\n  .rt-contact__headline { font-size: clamp(3rem, 10vw, 4.5rem); }\n\n  .rt-contact-form {\n    padding: 3.5rem 2rem;\n  }\n\n  .rt-form-group {\n    grid-template-columns: 1fr;\n  }\n}\n<\/style>\n\n\n<div class=\"rt-contact\">\n  <div class=\"rt-contact-inner\">\n\n    <!-- LEFT: Info -->\n    <div class=\"rt-contact-info\">\n      <div class=\"rt-contact-info__top\">\n        <span class=\"rt-label rt-reveal\">Get In Touch<\/span>\n        <div class=\"rt-rule rt-reveal rt-d1\"><\/div>\n        <h1 class=\"rt-contact__headline rt-reveal rt-d2\">\n          Let's<br><em>Talk.<\/em>\n        <\/h1>\n        <p class=\"rt-contact__tagline rt-reveal rt-d3\">\n          Questions about an order, a custom piece, or just curious — we're here.\n        <\/p>\n      <\/div>\n\n      <div class=\"rt-channels rt-reveal rt-d4\">\n\n        <!-- Email -->\n        <a href=\"mailto:info@rangtarini.com\" class=\"rt-channel\">\n          <div class=\"rt-channel__icon\">\n            <svg viewBox=\"0 0 24 24\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M20 4H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z\"\/>\n            <\/svg>\n          <\/div>\n          <div>\n            <div class=\"rt-channel__label\">Email<\/div>\n            <div class=\"rt-channel__value\">info@rangtarini.com<\/div>\n          <\/div>\n        <\/a>\n\n        <!-- WhatsApp -->\n        <a href=\"https:\/\/wa.me\/919251110762\" target=\"_blank\" class=\"rt-channel\">\n          <div class=\"rt-channel__icon\">\n            <svg viewBox=\"0 0 24 24\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n              <path d=\"M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z\"\/>\n            <\/svg>\n          <\/div>\n          <div>\n            <div class=\"rt-channel__label\">WhatsApp<\/div>\n            <div class=\"rt-channel__value\">+91 92511 10762<\/div>\n          <\/div>\n        <\/a>\n\n      <\/div>\n    <\/div>\n\n    <!-- RIGHT: Form -->\n    <div class=\"rt-contact-form\">\n      <span class=\"rt-label rt-reveal\">Send a Message<\/span>\n      <div class=\"rt-rule rt-reveal rt-d1\"><\/div>\n\n      {% form 'contact' %}\n\n        <div class=\"rt-form-group rt-reveal rt-d2\">\n          <div class=\"rt-form-field\">\n            <label for=\"ContactForm-name\">Name<\/label>\n            <input type=\"text\" id=\"ContactForm-name\" name=\"contact[name]\" placeholder=\"Your name\" autocomplete=\"name\">\n          <\/div>\n          <div class=\"rt-form-field\">\n            <label for=\"ContactForm-email\">Email <span aria-hidden=\"true\">*<\/span><\/label>\n            <input type=\"email\" id=\"ContactForm-email\" name=\"contact[email]\" required placeholder=\"your@email.com\" autocomplete=\"email\">\n          <\/div>\n        <\/div>\n\n        <div class=\"rt-form-field rt-reveal rt-d3\">\n          <label for=\"ContactForm-phone\">Phone<\/label>\n          <input type=\"text\" id=\"ContactForm-phone\" name=\"contact[phone]\" placeholder=\"+91 00000 00000\" autocomplete=\"off\">\n        <\/div>\n\n        <div class=\"rt-form-field rt-reveal rt-d3\">\n          <label for=\"ContactForm-body\">Message<\/label>\n          <textarea id=\"ContactForm-body\" name=\"contact[body]\" placeholder=\"Tell us what you're looking for…\"><\/textarea>\n        <\/div>\n\n        <div class=\"rt-form-submit rt-reveal rt-d4\">\n          <button type=\"submit\">Send<\/button>\n          <span class=\"rt-form-note\">We usually reply within 24 hours.<\/span>\n        <\/div>\n\n      {% endform %}\n    <\/div>\n\n  <\/div>\n<\/div>\n\n\n<script>\n(function(){\n  var els = document.querySelectorAll('.rt-contact .rt-reveal');\n  if (!els.length) return;\n  var obs = new IntersectionObserver(function(entries){\n    entries.forEach(function(e){\n      if (e.isIntersecting){\n        e.target.classList.add('rt-visible');\n        obs.unobserve(e.target);\n      }\n    });\n  }, { threshold: 0.1 });\n  els.forEach(function(el){ obs.observe(el); });\n})();\n<\/script>","color_scheme":"","padding_top":0,"padding_bottom":0}},"main":{"type":"main-page","disabled":true,"settings":{"padding_top":36,"padding_bottom":36}},"form":{"type":"contact-form","disabled":true,"settings":{"heading":"","heading_size":"h1","color_scheme":"scheme-1","padding_top":36,"padding_bottom":36}}},"order":["custom_liquid_eCb363","main","form"]}